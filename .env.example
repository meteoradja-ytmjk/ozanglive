PORT=7575

# Base URL of your application (used for OAuth callback)
# For local development: http://localhost:7575
# For VPS/production: https://yourdomain.com
BASE_URL=http://localhost:7575

# Session secret - REQUIRED for session management
# Generate using: node generate-secret.js
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-here-change-this-in-production

# Encryption key for sensitive data (YouTube credentials, etc.)
# Generate using: node generate-encryption-key.js
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be 64 hex characters (32 bytes)
ENCRYPTION_KEY=your-encryption-key-here-64-hex-characters

# Upload Configuration (Optional)
# Chunk size for large file uploads (in MB)
UPLOAD_CHUNK_SIZE_MB=0.5
# Number of concurrent chunk uploads
UPLOAD_CHUNK_CONCURRENCY=4
# Threshold for using chunked uploads (in MB)
UPLOAD_CHUNK_THRESHOLD_MB=1
# Concurrency for video/audio processing
UPLOAD_PROCESSING_CONCURRENCY=1

# Database Configuration (Optional)
# SQLite busy timeout in milliseconds
# DB_BUSY_TIMEOUT=30000

# Node Environment
# NODE_ENV=production