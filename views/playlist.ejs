// Track which media is currently displayed in the View modal so preview can find filepath
let currentViewPlaylistMedia = { videos: [], audios: [] };

// Lightweight HTML escaper for titles inserted via innerHTML
function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/**
 * Single shared media element for previewing playlist items.
 * - Only one preview plays at a time (CPU-friendly).
 * - The element is created lazily on first use, then reused (no DOM churn).
 * - preload="none" so nothing is fetched until the user actually presses play.
 */
function previewMedia(kind, id) {
  const list = kind === 'video' ? currentViewPlaylistMedia.videos : currentViewPlaylistMedia.audios;
  const item = list.find(m => String(m.id) === String(id));
  if (!item || !item.filepath) {
    showToast('Media file not found', 'error');
    return;
  }

  const wrapper = document.getElementById('previewPlayerWrapper');
  const slot = document.getElementById('previewPlayerSlot');
  const titleEl = document.getElementById('previewPlayerTitle');
  const iconEl = document.getElementById('previewPlayerIcon');

  // Stop any current playback before swapping element type
  stopCurrentPreview();

  let el;
  if (kind === 'video') {
    el = document.createElement('video');
    el.controls = true;
    el.preload = 'none';
    el.playsInline = true;
    el.className = 'w-full max-h-[360px] bg-black';
    iconEl.className = 'ti ti-video text-primary flex-shrink-0';
  } else {
    el = document.createElement('audio');
    el.controls = true;
    el.preload = 'none';
    el.className = 'w-full';
    iconEl.className = 'ti ti-music text-primary flex-shrink-0';
  }
  el.src = item.filepath;

  slot.innerHTML = '';
  slot.appendChild(el);
  titleEl.textContent = item.title || (kind === 'video' ? 'Video preview' : 'Audio preview');
  wrapper.classList.remove('hidden');

  // Auto-play once user explicitly requested preview; muted-by-default not needed for audio
  el.play().catch(() => { /* ignore autoplay rejection; user can press play */ });

  // Bring preview into view
  wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function stopCurrentPreview() {
  const slot = document.getElementById('previewPlayerSlot');
  if (!slot) return;
  const media = slot.querySelector('video, audio');
  if (media) {
    try {
      media.pause();
    } catch (_) { /* noop */ }
    // Detaching the source frees the network/decoder buffers immediately
    media.removeAttribute('src');
    media.load();
  }
  slot.innerHTML = '';
}

function closePreviewPlayer() {
  stopCurrentPreview();
  const wrapper = document.getElementById('previewPlayerWrapper');
  if (wrapper) wrapper.classList.add('hidden');
}

/**
 * Render every audio in this playlist into a single seamless audio file and
 * register it in the audio gallery so the user can use it as a streaming
 * source. The default title is prefixed with "playlist - " to keep it
 * distinguishable from regular uploaded audios.
 */
function joinPlaylistAudios(playlistId, btn) {
  if (!playlistId) return;

  const originalHtml = btn ? btn.innerHTML : null;
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader animate-spin mr-1"></i>Processing...';
  }

  fetch(`/api/playlists/${playlistId}/audio-joiner`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
    .then(async (res) => {
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) {
        throw new Error(data.error || data.message || 'Failed to join audio');
      }
      return data;
    })
    .then((data) => {
      const title = data.audio && data.audio.title ? data.audio.title : 'Joined audio';
      showToast(`Saved to audio gallery: ${title}`, 'success');
    })
    .catch((err) => {
      console.error('joinPlaylistAudios error:', err);
      showToast(err.message || 'Error joining audio', 'error');
    })
    .finally(() => {
      if (btn) {
        btn.disabled = false;
        if (originalHtml) btn.innerHTML = originalHtml;
      }
    });
}

function deletePlaylist(playlistId, playlistName) {
  if (confirm(`Are you sure you want to delete "${playlistName}"?`)) {
    fetch(`/api/playlists/${playlistId}`, {
      method: 'DELETE'
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        showToast('Playlist deleted successfully', 'success');
        location.reload();
      } else {
        showToast(data.message || 'Error deleting playlist', 'error');
      }
    })
    .catch(error => {
      console.error('Error deleting playlist:', error);
      showToast('Error deleting playlist', 'error');
    });
  }
}

