<% layout('layout') -%>

<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold">Playlist Manager</h2>
    <p class="text-gray-400 text-sm mt-1">Create and manage playlists for streaming</p>
  </div>
  <div class="flex flex-wrap gap-3">
    <button onclick="openCreatePlaylistModal()"
      class="flex items-center gap-2 bg-primary hover:bg-secondary text-white px-4 py-2 rounded-lg transition-colors">
      <i class="ti ti-plus"></i>
      <span>Create Playlist</span>
    </button>
  </div>
</div>

<div class="bg-gray-800 rounded-lg p-4 mb-6">
  <div class="flex flex-row items-center gap-3">
    <div class="relative w-full sm:w-80 md:w-96">
      <input type="text" id="searchPlaylists" placeholder="Search playlists..."
        class="w-full bg-dark-700 text-white pl-9 pr-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
      <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
    </div>
    <div class="w-32">
      <select id="sortPlaylists"
        class="w-full bg-dark-700 border border-gray-600 text-white px-3 py-2.5 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        <option value="newest">Newest</option>
        <option value="oldest">Oldest</option>
        <option value="name">Name</option>
      </select>
    </div>
  </div>
</div>

<div id="playlistsContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
  <% if (playlists && playlists.length > 0) { %>
    <% playlists.forEach(function(playlist) { %>
      <div class="bg-gray-800 rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow playlist-card h-32" 
           data-playlist-id="<%= playlist.id %>" 
           data-created-at="<%= playlist.created_at %>" 
           data-updated-at="<%= playlist.updated_at %>">
        <div class="p-4 h-full flex flex-col justify-between">
          <div class="flex flex-col">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-semibold text-lg truncate flex-1 pr-2"><%= playlist.name %></h3>
              <div class="flex items-center gap-1 flex-shrink-0">
                <button class="bg-primary hover:bg-secondary text-white w-8 h-8 flex items-center justify-center rounded-lg transition-colors" onclick="viewPlaylist('<%= playlist.id %>')">
                  <i class="ti ti-eye text-sm"></i>
                </button>
                <button class="bg-emerald-600 hover:bg-emerald-700 text-white w-8 h-8 flex items-center justify-center rounded-lg transition-colors" onclick="editPlaylist('<%= playlist.id %>')">
                  <i class="ti ti-pencil text-sm"></i>
                </button>
                <button class="bg-red-600 hover:bg-red-700 text-white w-8 h-8 flex items-center justify-center rounded-lg transition-colors" onclick="deletePlaylist('<%= playlist.id %>', '<%= playlist.name %>')">
                  <i class="ti ti-trash text-sm"></i>
                </button>
              </div>
            </div>
            <p class="text-gray-400 text-sm line-clamp-2"><%= playlist.description || 'No description' %></p>
          </div>
          
          <div class="flex items-center justify-between text-sm text-gray-400 mt-auto">
            <span class="flex items-center gap-2">
              <span><i class="ti ti-video mr-1"></i><%= playlist.video_count || 0 %></span>
              <span><i class="ti ti-music mr-1"></i><%= playlist.audio_count || 0 %></span>
            </span>
            <span class="flex items-center gap-1">
              <i class="ti ti-<%= (playlist.shuffle || playlist.is_shuffle) ? 'arrows-shuffle' : 'list-numbers' %>"></i>
              <%= (playlist.shuffle || playlist.is_shuffle) ? 'Shuffle' : 'Sequential' %>
            </span>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-span-full text-center py-12">
      <i class="ti ti-playlist text-6xl text-gray-600 mb-4"></i>
      <h3 class="text-xl font-semibold mb-2">No playlists yet</h3>
      <p class="text-gray-400 mb-4">Create your first playlist to get started</p>
      <button onclick="openCreatePlaylistModal()" 
        class="bg-primary hover:bg-secondary text-white px-6 py-3 rounded-lg transition-colors">
        <i class="ti ti-plus mr-2"></i>
        Create Playlist
      </button>
    </div>
  <% } %>
</div>

<div class="mt-6 flex items-center justify-between">
  <p class="text-sm text-gray-400" id="paginationInfo">Showing 1-<%= Math.min(8, playlists ? playlists.length : 0) %> of <%= playlists ? playlists.length : 0 %> playlists</p>
  <div class="flex items-center gap-2" id="paginationControls">
    <button type="button" class="w-9 h-9 flex items-center justify-center rounded-lg bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors" id="prevPage" onclick="changePage(-1)">
      <i class="ti ti-chevron-left"></i>
    </button>
    <div id="pageNumbers" class="flex items-center gap-2"></div>
    <button type="button" class="w-9 h-9 flex items-center justify-center rounded-lg bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors" id="nextPage" onclick="changePage(1)">
      <i class="ti ti-chevron-right"></i>
    </button>
  </div>
</div>

<!-- Create/Edit Playlist Modal -->
<div id="playlistModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
  <div class="bg-gray-800 rounded-lg p-6 w-full max-w-4xl mx-4 max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-gray-700">
      <h3 id="modalTitle" class="text-xl font-semibold">Create New Playlist</h3>
      <button onclick="closePlaylistModal()" class="text-gray-400 hover:text-white">
        <i class="ti ti-x text-xl"></i>
      </button>
    </div>
    
    <form id="playlistForm" class="space-y-6">
      <input type="hidden" id="playlistId" name="playlistId">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="playlistName" class="block text-sm font-medium mb-2">Playlist Name</label>
          <input type="text" id="playlistName" name="name" required placeholder="Enter playlist name..."
            class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        </div>
        
        <div>
            <div class="flex items-center mb-2">
              <label for="playlistShuffle" class="text-sm font-medium">Playback Mode</label>
              <div class="relative ml-2 group">
                <i class="ti ti-help-circle text-gray-400 hover:text-primary cursor-help"></i>
                <div class="absolute left-full top-1/2 -translate-y-1/2 ml-2 hidden group-hover:block w-64 p-3 bg-dark-600 text-xs text-gray-200 rounded-md shadow-lg z-10">
                  <div class="space-y-2">
                    <div><strong>Sequential:</strong> Video berurutan sesuai urutan dalam playlist</div>
                    <div><strong>Shuffle:</strong> Video diacak secara random</div>
                  </div>
                  <div class="absolute right-full top-1/2 -translate-y-1/2 border-4 border-transparent border-r-dark-600"></div>
                </div>
              </div>
            </div>
          <select id="playlistShuffle" name="shuffle"
            class="w-full bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="false">Sequential</option>
            <option value="true">Shuffle</option>
          </select>
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium mb-3">Select Media</label>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Available Media (Left Column) -->
          <div>
            <!-- Tab Buttons for Available Media -->
            <div class="flex w-full mb-3 border border-gray-600 rounded-lg overflow-hidden bg-gray-800/50">
              <button type="button" id="availableVideosTab" onclick="switchAvailableTab('videos')" 
                class="flex-1 px-4 py-2 text-sm font-medium text-center border-b-2 border-primary text-primary bg-primary/20">
                <i class="ti ti-video mr-1"></i>Videos
              </button>
              <div class="w-px bg-gray-600"></div>
              <button type="button" id="availableAudiosTab" onclick="switchAvailableTab('audios')" 
                class="flex-1 px-4 py-2 text-sm font-medium text-center border-b-2 border-transparent text-gray-400 hover:text-white hover:bg-gray-700/50">
                <i class="ti ti-music mr-1"></i>Audios
              </button>
            </div>
            
            <!-- Available Videos Panel -->
            <div id="availableVideosPanel" class="bg-dark-700 rounded-lg border border-gray-600 shadow-lg">
              <div class="p-2 border-b border-gray-600/50">
                <div class="relative">
                  <input type="text" id="searchVideos" placeholder="Search videos..."
                    class="w-full bg-dark-800 text-white pl-8 pr-4 py-2 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary border border-gray-700">
                  <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                </div>
              </div>
              <div id="availableVideos" class="p-2 space-y-1 min-h-[220px] max-h-60 overflow-y-auto custom-scrollbar">
                <!-- Rendered dynamically by JS with folder grouping -->
              </div>
            </div>
            
            <!-- Available Audios Panel -->
            <div id="availableAudiosPanel" class="bg-dark-700 rounded-lg border border-gray-600 shadow-lg hidden">
              <div class="p-2 border-b border-gray-600/50">
                <div class="relative">
                  <input type="text" id="searchAudios" placeholder="Search audios..."
                    class="w-full bg-dark-800 text-white pl-8 pr-4 py-2 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary border border-gray-700">
                  <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                </div>
              </div>
              <div id="availableAudios" class="p-2 space-y-1 min-h-[220px] max-h-60 overflow-y-auto custom-scrollbar">
                <!-- Rendered dynamically by JS with folder grouping -->
              </div>
            </div>
          </div>
          
          <!-- Selected Media (Right Column) -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm font-medium text-gray-300"><i class="ti ti-playlist mr-1"></i>Selected Media</span>
              <span class="text-xs text-gray-500" id="selectedMediaCount">0 items</span>
            </div>
            
            <!-- Single combined panel for selected videos + audios -->
            <div class="bg-dark-700 rounded-lg border border-gray-600 p-3 min-h-[280px] max-h-80 overflow-y-auto custom-scrollbar">
              <div id="selectedMedia" class="space-y-2 min-h-[100px]">
                <p id="noMediaMessage" class="text-gray-400 text-sm text-center py-8">No media selected</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="flex justify-end gap-3 pt-4 border-t border-gray-700">
        <button type="button" onclick="closePlaylistModal()" 
          class="px-4 py-2 text-gray-400 hover:text-white transition-colors">
          Cancel
        </button>
        <button type="submit" 
          class="bg-primary hover:bg-secondary text-white px-6 py-2 rounded-lg transition-colors">
          <span id="submitButtonText">Create Playlist</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- View Playlist Modal -->
<div id="viewPlaylistModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
  <div class="bg-gray-800 rounded-lg p-6 w-full max-w-4xl mx-4 max-h-[90vh] overflow-y-auto">
    <div class="flex items-start justify-between mb-6 pb-4 border-b border-gray-700">
      <div>
        <h3 id="viewPlaylistTitle" class="text-xl font-semibold">Playlist Details</h3>
        <p id="viewPlaylistDescription" class="text-gray-400 text-sm mt-1"></p>
      </div>
      <button onclick="closeViewPlaylistModal()" class="text-gray-400 hover:text-white">
        <i class="ti ti-x text-xl"></i>
      </button>
    </div>
    
    <div class="mb-4 flex items-center justify-between">
      <div class="flex items-center gap-4 text-sm text-gray-400">
        <span id="viewVideoCount">0 videos</span>
        <span id="viewPlaybackMode" class="flex items-center gap-1">
          <i class="ti ti-list-numbers"></i>
          Sequential
        </span>
      </div>
      <div class="flex gap-2">
        <button id="editPlaylistBtn" class="bg-primary hover:bg-secondary text-white px-4 py-2 rounded-lg text-sm transition-colors">
          <i class="ti ti-pencil mr-1"></i>
          Edit
        </button>
      </div>
    </div>

    <!-- Shared preview player (single instance to keep CPU/memory low) -->
    <div id="previewPlayerWrapper" class="hidden mb-4 bg-dark-800 rounded-lg border border-gray-700 overflow-hidden">
      <div class="flex items-center justify-between px-3 py-2 border-b border-gray-700 bg-dark-700">
        <div class="flex items-center gap-2 min-w-0">
          <i id="previewPlayerIcon" class="ti ti-player-play text-primary flex-shrink-0"></i>
          <span id="previewPlayerTitle" class="text-sm font-medium truncate"></span>
        </div>
        <button type="button" onclick="closePreviewPlayer()" class="text-gray-400 hover:text-white flex-shrink-0" title="Close preview">
          <i class="ti ti-x"></i>
        </button>
      </div>
      <div id="previewPlayerSlot" class="bg-black"></div>
    </div>
    
    <div id="playlistVideos" class="space-y-2">
      <!-- Videos will be loaded here -->
    </div>
  </div>
</div>

<script>
let selectedVideos = [];
let selectedAudios = [];
let currentPlaylistId = null;
let allVideos = <%- JSON.stringify(videos || []) %>;
let allAudios = <%- JSON.stringify(audios || []) %>;

// Tab switching functions
function switchAvailableTab(tab) {
  const videosTab = document.getElementById('availableVideosTab');
  const audiosTab = document.getElementById('availableAudiosTab');
  const videosPanel = document.getElementById('availableVideosPanel');
  const audiosPanel = document.getElementById('availableAudiosPanel');
  
  if (tab === 'videos') {
    videosTab.classList.add('border-primary', 'text-primary', 'bg-primary/20');
    videosTab.classList.remove('border-transparent', 'text-gray-400', 'hover:bg-gray-700/50');
    audiosTab.classList.remove('border-primary', 'text-primary', 'bg-primary/20');
    audiosTab.classList.add('border-transparent', 'text-gray-400', 'hover:bg-gray-700/50');
    videosPanel.classList.remove('hidden');
    audiosPanel.classList.add('hidden');
  } else {
    audiosTab.classList.add('border-primary', 'text-primary', 'bg-primary/20');
    audiosTab.classList.remove('border-transparent', 'text-gray-400', 'hover:bg-gray-700/50');
    videosTab.classList.remove('border-primary', 'text-primary', 'bg-primary/20');
    videosTab.classList.add('border-transparent', 'text-gray-400', 'hover:bg-gray-700/50');
    audiosPanel.classList.remove('hidden');
    videosPanel.classList.add('hidden');
  }
}

function switchSelectedTab(tab) {
  // No longer needed - single combined panel
}

function openCreatePlaylistModal() {
  currentPlaylistId = null;
  selectedVideos = [];
  selectedAudios = [];
  document.getElementById('modalTitle').textContent = 'Create New Playlist';
  document.getElementById('submitButtonText').textContent = 'Create Playlist';
  document.getElementById('playlistForm').reset();
  document.getElementById('playlistId').value = '';
  // Reset tabs to default (videos)
  switchAvailableTab('videos');
  updateSelectedMediaDisplay();
  updateAvailableVideosDisplay();
  updateAvailableAudiosDisplay();
  document.getElementById('playlistModal').classList.remove('hidden');
  document.getElementById('playlistModal').classList.add('flex');
}

function closePlaylistModal() {
  document.getElementById('playlistModal').classList.add('hidden');
  document.getElementById('playlistModal').classList.remove('flex');
}

function closeViewPlaylistModal() {
  closePreviewPlayer();
  document.getElementById('viewPlaylistModal').classList.add('hidden');
  document.getElementById('viewPlaylistModal').classList.remove('flex');
}

function addVideoToPlaylist(videoId) {
  const video = allVideos.find(v => v.id == videoId);
  if (video && !selectedVideos.find(v => v.id == videoId)) {
    selectedVideos.push(video);
    updateSelectedMediaDisplay();
    updateAvailableVideosDisplay();
  }
}

function removeVideoFromPlaylist(videoId) {
  selectedVideos = selectedVideos.filter(v => v.id != videoId);
  updateSelectedMediaDisplay();
  updateAvailableVideosDisplay();
}

// Toggle video via checkbox
function toggleVideoSelection(videoId) {
  if (selectedVideos.find(v => v.id == videoId)) {
    removeVideoFromPlaylist(videoId);
  } else {
    addVideoToPlaylist(videoId);
  }
}

// Toggle audio via checkbox
function toggleAudioSelection(audioId) {
  if (selectedAudios.find(a => a.id == audioId)) {
    removeAudioFromPlaylist(audioId);
  } else {
    addAudioToPlaylist(audioId);
  }
}

// Pin item to top (move to position 0)
function pinMediaItem(type, id) {
  if (type === 'video') {
    const idx = selectedVideos.findIndex(v => v.id == id);
    if (idx > 0) {
      const item = selectedVideos.splice(idx, 1)[0];
      selectedVideos.unshift(item);
    }
  } else {
    const idx = selectedAudios.findIndex(a => a.id == id);
    if (idx > 0) {
      const item = selectedAudios.splice(idx, 1)[0];
      selectedAudios.unshift(item);
    }
  }
  updateSelectedMediaDisplay();
}

// Combined selected media display (videos + audios in one list)
function updateSelectedMediaDisplay() {
  const container = document.getElementById('selectedMedia');
  const countEl = document.getElementById('selectedMediaCount');
  if (!container) return;
  
  const totalCount = selectedVideos.length + selectedAudios.length;
  if (countEl) countEl.textContent = `${totalCount} item${totalCount !== 1 ? 's' : ''}`;
  
  if (totalCount === 0) {
    container.innerHTML = '<p class="text-gray-400 text-sm text-center py-8">No media selected</p>';
    return;
  }
  
  let html = '';
  
  // Videos section
  if (selectedVideos.length > 0) {
    html += `<div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold mb-1 flex items-center gap-1"><i class="ti ti-video text-primary"></i>Videos (${selectedVideos.length})</div>`;
    html += selectedVideos.map((video, index) => `
      <div class="flex items-center gap-2 p-1.5 bg-gray-600/50 rounded" data-video-id="${video.id}">
        <div class="cursor-move flex-shrink-0">
          <i class="ti ti-grip-vertical text-gray-400 text-xs"></i>
        </div>
        <span class="text-[10px] text-gray-400 w-4 text-center flex-shrink-0">${index + 1}</span>
        <img src="${video.thumbnail_path}" alt="${escapeHtmlAttr(video.title)}" class="w-10 h-7 object-cover rounded flex-shrink-0" loading="lazy" onerror="this.src='/images/default-thumbnail.jpg'">
        <div class="flex-1 min-w-0">
          <p class="text-xs font-medium truncate">${escapeHtmlAttr(video.title)}</p>
        </div>
        <button type="button" onclick="pinMediaItem('video', '${video.id}')" class="w-5 h-5 flex items-center justify-center rounded ${index === 0 ? 'text-primary' : 'text-gray-500 hover:text-primary'}" title="Pin to top">
          <i class="ti ti-pin text-xs"></i>
        </button>
        <button type="button" onclick="removeVideoFromPlaylist('${video.id}')" class="w-5 h-5 flex items-center justify-center text-red-400 hover:text-red-300 flex-shrink-0" title="Remove">
          <i class="ti ti-x text-xs"></i>
        </button>
      </div>
    `).join('');
  }
  
  // Audios section
  if (selectedAudios.length > 0) {
    if (selectedVideos.length > 0) html += '<div class="border-t border-gray-600/30 my-2"></div>';
    html += `<div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold mb-1 flex items-center gap-1"><i class="ti ti-music text-green-400"></i>Audios (${selectedAudios.length})</div>`;
    html += selectedAudios.map((audio, index) => `
      <div class="flex items-center gap-2 p-1.5 bg-gray-600/50 rounded" data-audio-id="${audio.id}">
        <div class="cursor-move flex-shrink-0">
          <i class="ti ti-grip-vertical text-gray-400 text-xs"></i>
        </div>
        <span class="text-[10px] text-gray-400 w-4 text-center flex-shrink-0">${index + 1}</span>
        <div class="w-7 h-7 bg-dark-800 rounded flex items-center justify-center flex-shrink-0">
          <i class="ti ti-music text-green-400 text-xs"></i>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-medium truncate">${escapeHtmlAttr(audio.title)}</p>
        </div>
        <button type="button" onclick="pinMediaItem('audio', '${audio.id}')" class="w-5 h-5 flex items-center justify-center rounded ${index === 0 ? 'text-green-400' : 'text-gray-500 hover:text-green-400'}" title="Pin to top">
          <i class="ti ti-pin text-xs"></i>
        </button>
        <button type="button" onclick="removeAudioFromPlaylist('${audio.id}')" class="w-5 h-5 flex items-center justify-center text-red-400 hover:text-red-300 flex-shrink-0" title="Remove">
          <i class="ti ti-x text-xs"></i>
        </button>
      </div>
    `).join('');
  }
  
  container.innerHTML = html;
  
  // Initialize drag and drop for both sections
  setTimeout(() => {
    initializeDragAndDrop();
    initializeAudioDragAndDrop();
  }, 100);
}

// Legacy wrappers for compatibility
function updateSelectedVideosDisplay() { updateSelectedMediaDisplay(); }
function updateSelectedAudiosDisplay() { updateSelectedMediaDisplay(); }

// Helper: extract base name for grouping (same logic as Gallery)
function getVideoBaseName(title) {
  let name = title.replace(/\.(mp4|avi|mov|mkv)$/i, '');
  name = name.replace(/[-_\s]*\d+\s*$/g, '');
  name = name.replace(/\s*[\(\[\{]\d+[\)\]\}]\s*$/g, '');
  return name.trim().toLowerCase() || title.toLowerCase();
}

function getAudioBaseName(title) {
  let name = title.replace(/\.(mp3|wav|aac|m4a|flac)$/i, '');
  name = name.replace(/[-_\s]*\d+\s*$/g, '');
  name = name.replace(/\s*[\(\[\{]\d+[\)\]\}]\s*$/g, '');
  return name.trim().toLowerCase() || title.toLowerCase();
}

// Group items by folder_name (or fallback to base name extraction)
function groupByFolder(items, getBaseName) {
  const groups = {};
  items.forEach(item => {
    const explicitFolder = (item.folder_name || '').trim();
    const key = explicitFolder ? explicitFolder.toLowerCase() : getBaseName(item.title);
    if (!groups[key]) {
      groups[key] = {
        displayName: explicitFolder || item.title.replace(/[-_\s]*\d+\s*$/g, '').replace(/\s*[\(\[\{]\d+[\)\]\}]\s*$/g, '').trim(),
        items: []
      };
    }
    groups[key].items.push(item);
  });
  return groups;
}

function updateAvailableVideosDisplay() {
  const container = document.getElementById('availableVideos');
  const selectedVideoIds = selectedVideos.map(v => v.id);
  
  if (allVideos.length === 0) {
    container.innerHTML = '<div class="text-center py-5 text-gray-400"><p>No videos available</p></div>';
    return;
  }

  const groups = groupByFolder(allVideos, getVideoBaseName);
  const groupKeys = Object.keys(groups).sort((a, b) => a.localeCompare(b));
  
  let html = '';
  groupKeys.forEach((key, gIdx) => {
    const group = groups[key];
    html += `
      <div class="playlist-avail-group mb-1">
        <div class="flex items-center gap-2 px-2 py-1.5 rounded cursor-pointer hover:bg-dark-600/50 select-none" onclick="toggleAvailVideoGroup(${gIdx})">
          <i class="ti ti-chevron-down text-gray-400 text-xs transition-transform" id="availVideoGroupIcon${gIdx}"></i>
          <i class="ti ti-folder text-primary text-sm"></i>
