// Track which media is currently displayed in the View modal so preview can find filepath
let currentViewPlaylistMedia = { videos: [], audios: [] };

// Lightweight HTML escaper for titles inserted via innerHTML
function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/**
 * Single shared media element for previewing playlist items.
 * - Only one preview plays at a time (CPU-friendly).
 * - The element is created lazily on first use, then reused (no DOM churn).
 * - preload="none" so nothing is fetched until the user actually presses play.
 */
function previewMedia(kind, id) {
  const list = kind === 'video' ? currentViewPlaylistMedia.videos : currentViewPlaylistMedia.audios;
  const item = list.find(m => String(m.id) === String(id));
  if (!item || !item.filepath) {
    showToast('Media file not found', 'error');
    return;
  }

  const wrapper = document.getElementById('previewPlayerWrapper');
  const slot = document.getElementById('previewPlayerSlot');
  const titleEl = document.getElementById('previewPlayerTitle');
  const iconEl = document.getElementById('previewPlayerIcon');

  // Stop any current playback before swapping element type
  stopCurrentPreview();

  let el;
  if (kind === 'video') {
    el = document.createElement('video');
    el.controls = true;
    el.preload = 'none';
    el.playsInline = true;
    el.className = 'w-full max-h-[360px] bg-black';
    iconEl.className = 'ti ti-video text-primary flex-shrink-0';
  } else {
    el = document.createElement('audio');
    el.controls = true;
    el.preload = 'none';
    el.className = 'w-full';
    iconEl.className = 'ti ti-music text-primary flex-shrink-0';
  }
  el.src = item.filepath;

  slot.innerHTML = '';
  slot.appendChild(el);
  titleEl.textContent = item.title || (kind === 'video' ? 'Video preview' : 'Audio preview');
  wrapper.classList.remove('hidden');

  // Auto-play once user explicitly requested preview; muted-by-default not needed for audio
  el.play().catch(() => { /* ignore autoplay rejection; user can press play */ });

  // Bring preview into view
  wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function stopCurrentPreview() {
  const slot = document.getElementById('previewPlayerSlot');
  if (!slot) return;
  const media = slot.querySelector('video, audio');
  if (media) {
    try {
      media.pause();
    } catch (_) { /* noop */ }
    // Detaching the source frees the network/decoder buffers immediately
    media.removeAttribute('src');
    media.load();
  }
  slot.innerHTML = '';
}

function closePreviewPlayer() {
  stopCurrentPreview();
  const wrapper = document.getElementById('previewPlayerWrapper');
  if (wrapper) wrapper.classList.add('hidden');
}

