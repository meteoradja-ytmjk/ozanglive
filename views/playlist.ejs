          const movedVideo = selectedVideos.splice(oldIndex, 1)[0];
          selectedVideos.splice(newIndex, 0, movedVideo);
          updateSelectedVideosDisplay();
        }
      }
    });
  }
}

// Move video up in playlist
function moveVideoUp(index) {
  if (index <= 0 || index >= selectedVideos.length) return;
  const temp = selectedVideos[index];
  selectedVideos[index] = selectedVideos[index - 1];
  selectedVideos[index - 1] = temp;
  updateSelectedVideosDisplay();
}

// Move video down in playlist
function moveVideoDown(index) {
  if (index < 0 || index >= selectedVideos.length - 1) return;
  const temp = selectedVideos[index];
  selectedVideos[index] = selectedVideos[index + 1];
  selectedVideos[index + 1] = temp;
  updateSelectedVideosDisplay();
}

// Move audio up in playlist
function moveAudioUp(index) {
  if (index <= 0 || index >= selectedAudios.length) return;
  const temp = selectedAudios[index];
  selectedAudios[index] = selectedAudios[index - 1];
  selectedAudios[index - 1] = temp;
  updateSelectedAudiosDisplay();
}

// Move audio down in playlist
function moveAudioDown(index) {
  if (index < 0 || index >= selectedAudios.length - 1) return;
  const temp = selectedAudios[index];
  selectedAudios[index] = selectedAudios[index + 1];
  selectedAudios[index + 1] = temp;
  updateSelectedAudiosDisplay();
}

function filterPlaylists() {
  const searchTerm = document.getElementById('searchPlaylists').value.toLowerCase().trim();
  const sortBy = document.getElementById('sortPlaylists').value;
  const container = document.getElementById('playlistsContainer');
  const allCards = Array.from(container.querySelectorAll('.playlist-card'));

  // Hapus empty state lama (baik dari EJS maupun yang dibuat JS sebelumnya)
  container.querySelectorAll('.col-span-full').forEach(el => el.remove());

  // Tentukan kartu yang cocok
  const visibleCards = allCards.filter(card => {
    const playlistName = (card.querySelector('h3')?.textContent || '').toLowerCase();
    const playlistDescription = (card.querySelector('p')?.textContent || '').toLowerCase();
    return !searchTerm || playlistName.includes(searchTerm) || playlistDescription.includes(searchTerm);
  });

  // Sembunyikan kartu yang tidak cocok agar tidak ikut tampil
  const visibleSet = new Set(visibleCards);
  allCards.forEach(card => {
    if (!visibleSet.has(card)) {
      card.style.display = 'none';
    }
  });

  // Sort kartu yang cocok
  visibleCards.sort((a, b) => {
    const aName = a.querySelector('h3')?.textContent || '';
    const bName = b.querySelector('h3')?.textContent || '';

    switch (sortBy) {
      case 'name':
        return aName.localeCompare(bName);
      case 'oldest': {
        const aCreated = new Date(a.dataset.createdAt);
        const bCreated = new Date(b.dataset.createdAt);
        return aCreated - bCreated;
      }
      case 'newest':
      default: {
        const aUpdated = new Date(a.dataset.updatedAt);
        const bUpdated = new Date(b.dataset.updatedAt);
        return bUpdated - aUpdated;
      }
    }
  });

  visibleCards.forEach(card => container.appendChild(card));

  allPlaylistCards = visibleCards;
  currentPage = 1;
  updatePagination();

  // Tampilkan empty state hanya bila tidak ada kartu yang match
  if (visibleCards.length === 0) {
    const emptyDiv = document.createElement('div');
    emptyDiv.className = 'col-span-full text-center py-12';

    if (searchTerm) {
      emptyDiv.innerHTML = `
        <i class="ti ti-search text-6xl text-gray-600 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">No playlists found</h3>
        <p class="text-gray-400">Try adjusting your search terms</p>
      `;
    } else {
      emptyDiv.innerHTML = `
        <i class="ti ti-playlist text-6xl text-gray-600 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">No playlists yet</h3>
        <p class="text-gray-400 mb-4">Create your first playlist to get started</p>
        <button onclick="openCreatePlaylistModal()"
          class="bg-primary hover:bg-secondary text-white px-6 py-3 rounded-lg transition-colors">
          <i class="ti ti-plus mr-2"></i>
          Create Playlist
        </button>
      `;
    }

    container.appendChild(emptyDiv);
  }
}

document.getElementById('searchPlaylists').addEventListener('input', filterPlaylists);
document.getElementById('sortPlaylists').addEventListener('change', filterPlaylists);

let currentPage = 1;
const itemsPerPage = 8;
let allPlaylistCards = [];

function initializePagination() {
  allPlaylistCards = Array.from(document.querySelectorAll('.playlist-card'));
  updatePagination();
}

function updatePagination() {
  const totalItems = allPlaylistCards.length;
  const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));

  if (currentPage > totalPages) currentPage = totalPages;

  const start = totalItems === 0 ? 0 : (currentPage - 1) * itemsPerPage + 1;
  const end = Math.min(currentPage * itemsPerPage, totalItems);
  document.getElementById('paginationInfo').textContent =
    `Showing ${start}-${end} of ${totalItems} playlists`;

  // Tampilkan kartu sesuai halaman aktif
  allPlaylistCards.forEach((card, index) => {
    const shouldShow = index >= (currentPage - 1) * itemsPerPage && index < currentPage * itemsPerPage;
    card.style.display = shouldShow ? '' : 'none';
  });

  const controls = document.getElementById('paginationControls');
  if (totalItems <= itemsPerPage) {
    controls.style.display = 'none';
    return;
  }
  controls.style.display = 'flex';

  const prevBtn = document.getElementById('prevPage');
  const nextBtn = document.getElementById('nextPage');
  prevBtn.disabled = currentPage === 1;
  nextBtn.disabled = currentPage === totalPages;
  prevBtn.classList.toggle('opacity-50', currentPage === 1);
  prevBtn.classList.toggle('cursor-not-allowed', currentPage === 1);
  nextBtn.classList.toggle('opacity-50', currentPage === totalPages);
  nextBtn.classList.toggle('cursor-not-allowed', currentPage === totalPages);

  renderPageNumbers(currentPage, totalPages);
}

function renderPageNumbers(current, total) {
  const wrap = document.getElementById('pageNumbers');
  wrap.innerHTML = '';

  // Tentukan halaman yang ditampilkan: selalu 1, total, dan tetangga current
  const pages = new Set([1, total, current, current - 1, current + 1]);
  const sorted = [...pages]
    .filter(p => p >= 1 && p <= total)
    .sort((a, b) => a - b);

  let lastShown = 0;
  sorted.forEach(p => {
    if (p - lastShown > 1) {
      const ellipsis = document.createElement('span');
      ellipsis.className = 'w-9 h-9 flex items-center justify-center text-gray-500';
      ellipsis.textContent = '…';
      wrap.appendChild(ellipsis);
    }

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = p;
    btn.onclick = () => goToPage(p);
    btn.className = p === current
      ? 'w-9 h-9 flex items-center justify-center rounded-lg bg-primary text-white'
      : 'w-9 h-9 flex items-center justify-center rounded-lg bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors';
    wrap.appendChild(btn);

    lastShown = p;
  });
}

function changePage(direction) {
  const totalPages = Math.ceil(allPlaylistCards.length / itemsPerPage);
  const newPage = currentPage + direction;
  
  if (newPage >= 1 && newPage <= totalPages) {
    currentPage = newPage;
    updatePagination();
  }
}

function goToPage(page) {
  const totalPages = Math.ceil(allPlaylistCards.length / itemsPerPage);
  
  if (page >= 1 && page <= totalPages) {
    currentPage = page;
    updatePagination();
  }
}

document.addEventListener('DOMContentLoaded', function() {
  initializePagination();
});

