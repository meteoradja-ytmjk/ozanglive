      <div class="flex-shrink-0 flex items-center justify-end gap-3 p-4 sm:px-6 border-t border-gray-700">
        <button onclick="closeNewStreamModal()" class="px-5 py-2.5 text-sm font-medium text-gray-300 hover:text-white">Cancel</button>
        <button type="submit" form="newStreamForm" class="px-5 py-2.5 text-sm font-medium bg-primary hover:bg-secondary text-white rounded-lg">Create Stream</button>
