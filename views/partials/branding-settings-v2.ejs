<!-- Branding Tab - Optimized & Stylish Layout -->
<div id="branding-tab" class="settings-content hidden">
  <div class="p-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h3 class="text-lg font-semibold flex items-center">
          <i class="ti ti-palette mr-2 text-primary"></i>
          White Label Branding
        </h3>
        <p class="text-sm text-gray-400 mt-1">Customize the application with your brand identity</p>
      </div>
      <button type="button" id="reset-branding-btn"
        class="px-4 py-2 bg-gray-600 hover:bg-gray-500 text-white rounded-lg transition-colors text-sm">
        <i class="ti ti-refresh mr-1"></i>Reset to Default
      </button>
    </div>

    <form id="branding-form" class="space-y-6">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Identity & Visual Assets - 2 Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- Left Column: Identity -->
        <div class="bg-dark-700 rounded-lg p-5">
          <h4 class="text-md font-medium mb-4 flex items-center">
            <i class="ti ti-id mr-2 text-blue-400"></i>
            Application Identity
          </h4>

          <div class="space-y-4">
            <div>
              <label for="app-name" class="block text-sm font-medium text-gray-300 mb-2">
                Application Name
              </label>
              <input type="text" id="app-name" name="app_name" value="<%= branding.app_name %>"
                class="w-full bg-dark-900 text-white px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="OzangLive">
              <p class="text-xs text-gray-500 mt-1.5">Displayed in browser title and header</p>
            </div>

            <div>
              <label for="company-name" class="block text-sm font-medium text-gray-300 mb-2">
                Company Name
              </label>
              <input type="text" id="company-name" name="company_name" value="<%= branding.company_name %>"
                class="w-full bg-dark-900 text-white px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="OzangLive Team">
              <p class="text-xs text-gray-500 mt-1.5">Used in footer and legal text</p>
            </div>
          </div>
        </div>

        <!-- Right Column: Logo & Favicon -->
        <div class="bg-dark-700 rounded-lg p-5">
          <h4 class="text-md font-medium mb-4 flex items-center">
            <i class="ti ti-photo mr-2 text-green-400"></i>
            Logo & Favicon
          </h4>

          <div class="space-y-4">
            <!-- Logo Upload -->
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Application Logo</label>
              <div class="flex items-start gap-4">
                <div class="w-24 h-24 bg-dark-900 rounded-lg flex items-center justify-center overflow-hidden flex-shrink-0 border border-gray-600">
                  <img id="logo-preview" src="<%= branding.logo_path %>" alt="Logo" class="max-w-full max-h-full object-contain">
                </div>
                <div class="flex-1">
                  <input type="file" id="logo-upload" accept="image/png,image/svg+xml,image/jpeg" class="hidden">
                  <button type="button" onclick="document.getElementById('logo-upload').click()"
                    class="w-full px-4 py-2.5 bg-primary hover:bg-secondary text-white rounded-lg transition-colors mb-2 flex items-center justify-center gap-2">
                    <i class="ti ti-upload"></i>
                    <span>Upload Logo</span>
                  </button>
                  <p class="text-xs text-gray-500">PNG, SVG, or JPG • Max 2MB</p>
                  <p class="text-xs text-gray-500">Recommended: 200x60px</p>
                </div>
              </div>
            </div>

            <!-- Favicon Upload -->
            <div class="pt-4 border-t border-gray-600">
              <label class="block text-sm font-medium text-gray-300 mb-2">Favicon</label>
              <div class="flex items-start gap-4">
                <div class="w-16 h-16 bg-dark-900 rounded-lg flex items-center justify-center overflow-hidden flex-shrink-0 border border-gray-600">
                  <img id="favicon-preview" src="<%= branding.favicon_path %>" alt="Favicon" class="max-w-full max-h-full object-contain">
                </div>
                <div class="flex-1">
                  <input type="file" id="favicon-upload" accept="image/x-icon,image/png" class="hidden">
                  <button type="button" onclick="document.getElementById('favicon-upload').click()"
                    class="w-full px-4 py-2.5 bg-primary hover:bg-secondary text-white rounded-lg transition-colors mb-2 flex items-center justify-center gap-2">
                    <i class="ti ti-upload"></i>
                    <span>Upload Favicon</span>
                  </button>
                  <p class="text-xs text-gray-500">ICO or PNG • Max 500KB</p>
                  <p class="text-xs text-gray-500">Recommended: 32x32px or 64x64px</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Color Scheme -->
      <div class="bg-dark-700 rounded-lg p-5">
        <h4 class="text-md font-medium mb-4 flex items-center">
          <i class="ti ti-color-swatch mr-2 text-purple-400"></i>
          Color Scheme
        </h4>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Primary Color -->
          <div>
            <label for="primary-color" class="block text-sm font-medium text-gray-300 mb-2">Primary Color</label>
            <div class="flex items-center gap-2">
              <input type="color" id="primary-color" name="primary_color" value="<%= branding.primary_color %>"
                class="w-14 h-14 rounded-lg cursor-pointer border-2 border-gray-600">
              <input type="text" id="primary-color-text" value="<%= branding.primary_color %>"
                class="flex-1 bg-dark-900 text-white px-3 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary font-mono text-sm uppercase">
            </div>
            <p class="text-xs text-gray-500 mt-1.5">Buttons, links, highlights</p>
          </div>

          <!-- Secondary Color -->
          <div>
            <label for="secondary-color" class="block text-sm font-medium text-gray-300 mb-2">Secondary Color</label>
            <div class="flex items-center gap-2">
              <input type="color" id="secondary-color" name="secondary_color" value="<%= branding.secondary_color %>"
                class="w-14 h-14 rounded-lg cursor-pointer border-2 border-gray-600">
              <input type="text" id="secondary-color-text" value="<%= branding.secondary_color %>"
                class="flex-1 bg-dark-900 text-white px-3 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary font-mono text-sm uppercase">
            </div>
            <p class="text-xs text-gray-500 mt-1.5">Hover states, accents</p>
          </div>

          <!-- Accent Color -->
          <div>
            <label for="accent-color" class="block text-sm font-medium text-gray-300 mb-2">Accent Color</label>
            <div class="flex items-center gap-2">
              <input type="color" id="accent-color" name="accent_color" value="<%= branding.accent_color %>"
                class="w-14 h-14 rounded-lg cursor-pointer border-2 border-gray-600">
              <input type="text" id="accent-color-text" value="<%= branding.accent_color %>"
                class="flex-1 bg-dark-900 text-white px-3 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary font-mono text-sm uppercase">
            </div>
            <p class="text-xs text-gray-500 mt-1.5">Badges, notifications</p>
          </div>
        </div>

        <!-- Color Preview -->
        <div class="mt-5 p-4 bg-dark-900 rounded-lg border border-gray-600">
          <p class="text-xs text-gray-400 mb-3 font-medium">Preview:</p>
          <div class="flex flex-wrap gap-2">
            <button type="button" id="color-preview-primary" style="background-color: <%= branding.primary_color %>"
              class="px-5 py-2.5 text-white rounded-lg font-medium shadow-lg">Primary Button</button>
            <button type="button" id="color-preview-secondary" style="background-color: <%= branding.secondary_color %>"
              class="px-5 py-2.5 text-white rounded-lg font-medium shadow-lg">Secondary Button</button>
            <span id="color-preview-accent" style="background-color: <%= branding.accent_color %>"
              class="px-4 py-2 text-white rounded-full text-sm font-medium shadow-lg">Accent Badge</span>
          </div>
        </div>
      </div>

      <!-- Footer & Contact - 2 Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- Left: Footer & Contact -->
        <div class="bg-dark-700 rounded-lg p-5">
          <h4 class="text-md font-medium mb-4 flex items-center">
            <i class="ti ti-mail mr-2 text-yellow-400"></i>
            Footer & Contact
          </h4>

          <div class="space-y-4">
            <div>
              <label for="footer-text" class="block text-sm font-medium text-gray-300 mb-2">Footer Text</label>
              <input type="text" id="footer-text" name="footer_text" value="<%= branding.footer_text %>"
                class="w-full bg-dark-900 text-white px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="© 2024 Your Company. All rights reserved.">
              <p class="text-xs text-gray-500 mt-1.5">Displayed at bottom of pages</p>
            </div>

            <div>
              <label for="support-email" class="block text-sm font-medium text-gray-300 mb-2">Support Email</label>
              <input type="email" id="support-email" name="support_email" value="<%= branding.support_email %>"
                class="w-full bg-dark-900 text-white px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="support@yourcompany.com">
              <p class="text-xs text-gray-500 mt-1.5">Contact email for support</p>
            </div>

            <div>
              <label for="support-url" class="block text-sm font-medium text-gray-300 mb-2">Support URL <span class="text-gray-500">(Optional)</span></label>
              <input type="url" id="support-url" name="support_url" value="<%= branding.support_url || '' %>"
                class="w-full bg-dark-900 text-white px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="https://support.yourcompany.com">
              <p class="text-xs text-gray-500 mt-1.5">Link to help center</p>
            </div>
          </div>
        </div>

        <!-- Right: Attribution -->
        <div class="bg-dark-700 rounded-lg p-5">
          <h4 class="text-md font-medium mb-4 flex items-center">
            <i class="ti ti-info-circle mr-2 text-cyan-400"></i>
            Attribution
          </h4>

          <div class="space-y-4">
            <div class="flex items-start justify-between py-3 px-4 bg-dark-900 rounded-lg border border-gray-600">
              <div class="flex-1">
                <label class="text-sm font-medium text-gray-300 block mb-1">Show "Powered by OzangLive"</label>
                <p class="text-xs text-gray-500">Display attribution in footer</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer ml-4">
                <input type="checkbox" id="show-powered-by" name="show_powered_by" <%= branding.show_powered_by ? 'checked' : '' %> class="sr-only peer">
                <div
                  class="w-11 h-6 bg-gray-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary">
                </div>
              </label>
            </div>

            <div class="p-4 bg-blue-500/10 border border-blue-500/30 rounded-lg">
              <div class="flex items-start gap-3">
                <i class="ti ti-info-circle text-blue-400 text-xl flex-shrink-0 mt-0.5"></i>
                <div>
                  <p class="text-sm text-blue-300 font-medium mb-1">White Label Feature</p>
                  <p class="text-xs text-gray-400 leading-relaxed">
                    Customize the application with your brand identity. Perfect for resellers, agencies, and enterprises.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Save Button -->
      <div class="flex justify-end gap-3 pt-2">
        <button type="submit" id="save-branding-btn"
          class="px-8 py-3 bg-primary hover:bg-secondary text-white rounded-lg transition-colors font-medium shadow-lg">
          <i class="ti ti-device-floppy mr-2"></i>Save Branding
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// Branding Settings JavaScript
(function() {
  // Color picker sync
  const colorInputs = [
    { picker: 'primary-color', text: 'primary-color-text', preview: 'color-preview-primary' },
    { picker: 'secondary-color', text: 'secondary-color-text', preview: 'color-preview-secondary' },
    { picker: 'accent-color', text: 'accent-color-text', preview: 'color-preview-accent' }
  ];

  colorInputs.forEach(({ picker, text, preview }) => {
    const pickerEl = document.getElementById(picker);
    const textEl = document.getElementById(text);
    const previewEl = document.getElementById(preview);

    if (pickerEl && textEl && previewEl) {
      pickerEl.addEventListener('input', (e) => {
        textEl.value = e.target.value.toUpperCase();
        previewEl.style.backgroundColor = e.target.value;
      });

      textEl.addEventListener('input', (e) => {
        const value = e.target.value.toUpperCase();
        textEl.value = value;
        if (/^#[0-9A-F]{6}$/i.test(value)) {
          pickerEl.value = value;
          previewEl.style.backgroundColor = value;
        }
      });
    }
  });

  // Logo upload with API
  const logoUpload = document.getElementById('logo-upload');
  const logoPreview = document.getElementById('logo-preview');
  if (logoUpload && logoPreview) {
    logoUpload.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      // Validate file size
      if (file.size > 2 * 1024 * 1024) {
        showNotification('Logo file size must be less than 2MB', 'error');
        logoUpload.value = '';
        return;
      }

      // Preview
      const reader = new FileReader();
      reader.onload = (e) => {
        logoPreview.src = e.target.result;
      };
      reader.readAsDataURL(file);

      // Upload
      const formData = new FormData();
      formData.append('logo', file);

      try {
        const response = await fetch('/api/branding/logo', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();

        if (result.success) {
          showNotification('Logo uploaded successfully!', 'success');
        } else {
          throw new Error(result.error || 'Failed to upload logo');
        }
      } catch (error) {
        console.error('Error uploading logo:', error);
        showNotification(error.message || 'Failed to upload logo', 'error');
        // Revert preview
        logoPreview.src = '<%= branding.logo_path %>';
      }
    });
  }

  // Favicon upload with API
  const faviconUpload = document.getElementById('favicon-upload');
  const faviconPreview = document.getElementById('favicon-preview');
  if (faviconUpload && faviconPreview) {
    faviconUpload.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      // Validate file size
      if (file.size > 500 * 1024) {
        showNotification('Favicon file size must be less than 500KB', 'error');
        faviconUpload.value = '';
        return;
      }

      // Preview
      const reader = new FileReader();
      reader.onload = (e) => {
        faviconPreview.src = e.target.result;
      };
      reader.readAsDataURL(file);

      // Upload
      const formData = new FormData();
      formData.append('favicon', file);

      try {
        const response = await fetch('/api/branding/favicon', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();

        if (result.success) {
          showNotification('Favicon uploaded successfully!', 'success');
          // Update favicon in browser
          const link = document.querySelector("link[rel*='icon']") || document.createElement('link');
          link.type = 'image/x-icon';
          link.rel = 'shortcut icon';
          link.href = result.favicon_path + '?v=' + Date.now();
          document.getElementsByTagName('head')[0].appendChild(link);
        } else {
          throw new Error(result.error || 'Failed to upload favicon');
        }
      } catch (error) {
        console.error('Error uploading favicon:', error);
        showNotification(error.message || 'Failed to upload favicon', 'error');
        // Revert preview
        faviconPreview.src = '<%= branding.favicon_path %>';
      }
    });
  }

  // Save branding (text fields only)
  const brandingForm = document.getElementById('branding-form');
  if (brandingForm) {
    brandingForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const saveBtn = document.getElementById('save-branding-btn');
      const originalText = saveBtn.innerHTML;
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<i class="ti ti-loader animate-spin mr-2"></i>Saving...';

      try {
        const formData = new FormData(brandingForm);
        const data = {
          _csrf: formData.get('_csrf'),
          app_name: formData.get('app_name'),
          company_name: formData.get('company_name'),
          primary_color: formData.get('primary_color'),
          secondary_color: formData.get('secondary_color'),
          accent_color: formData.get('accent_color'),
          footer_text: formData.get('footer_text'),
          support_email: formData.get('support_email'),
          support_url: formData.get('support_url'),
          show_powered_by: formData.get('show_powered_by') === 'on' ? 1 : 0
        };
        
        const response = await fetch('/api/branding', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
          showNotification('Branding updated successfully! Reloading...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          throw new Error(result.error || 'Failed to update branding');
        }
      } catch (error) {
        console.error('Error saving branding:', error);
        showNotification(error.message || 'Failed to save branding settings', 'error');
        saveBtn.disabled = false;
        saveBtn.innerHTML = originalText;
      }
    });
  }

  // Reset branding
  const resetBtn = document.getElementById('reset-branding-btn');
  if (resetBtn) {
    resetBtn.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to reset all branding to default? This cannot be undone.')) {
        return;
      }

      try {
        const response = await fetch('/api/branding/reset', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            _csrf: document.querySelector('input[name="_csrf"]').value
          })
        });

        const result = await response.json();

        if (result.success) {
          showNotification('Branding reset to default! Reloading...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          throw new Error(result.error || 'Failed to reset branding');
        }
      } catch (error) {
        console.error('Error resetting branding:', error);
        showNotification(error.message || 'Failed to reset branding', 'error');
      }
    });
  }

  // Notification helper
  function showNotification(message, type = 'info') {
    // Reuse existing notification system if available
    if (typeof window.showNotification === 'function') {
      window.showNotification(message, type);
    } else {
      alert(message);
    }
  }
})();
</script>
