<% layout('layout') -%>

<style>
.editor-panel {
  background: rgba(17, 24, 39, 0.95);
  border: 1px solid rgba(75, 85, 99, 0.5);
  border-radius: 0.75rem;
  backdrop-filter: blur(10px);
}
.editor-panel-header {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid rgba(75, 85, 99, 0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.editor-panel-header h3 {
  font-size: 0.875rem;
  font-weight: 600;
  color: #F3F4F6;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.editor-panel-body { padding: 1rem; }
.preview-canvas {
  background: #000;
  border-radius: 0.5rem;
  aspect-ratio: 16/9;
  width: 100%;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(75, 85, 99, 0.5);
}
</style>
<style>
.preview-canvas .placeholder {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center; color: #6B7280;
}
.viz-type-card {
  padding: 0.5rem 0.25rem; border-radius: 0.5rem; border: 2px solid transparent;
  background: rgba(31, 41, 55, 0.8); cursor: pointer; transition: all 0.2s; text-align: center;
}
.viz-type-card:hover { border-color: rgba(139, 92, 246, 0.5); background: rgba(139, 92, 246, 0.1); }
.viz-type-card.active { border-color: #8B5CF6; background: rgba(139, 92, 246, 0.15); box-shadow: 0 0 12px rgba(139, 92, 246, 0.2); }
.viz-type-card .icon { font-size: 1.25rem; margin-bottom: 0.125rem; }
.color-swatch {
  width: 1.75rem; height: 1.75rem; border-radius: 50%; cursor: pointer;
  border: 2px solid transparent; transition: all 0.2s;
}
.color-swatch:hover { transform: scale(1.15); }
.color-swatch.active { border-color: #fff; box-shadow: 0 0 8px rgba(255,255,255,0.4); }
.viz-live-preview { height: 70px; background: rgba(0,0,0,0.6); border-radius: 0.5rem; overflow: hidden; }
.editor-tab {
  padding: 0.5rem 1rem; font-size: 0.8rem; font-weight: 500;
  border-bottom: 2px solid transparent; color: #9CA3AF; cursor: pointer; transition: all 0.2s;
}
.editor-tab:hover { color: #E5E7EB; }
.editor-tab.active { color: #8B5CF6; border-color: #8B5CF6; }
</style>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between mb-4 gap-3">
  <div>
    <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
      <i class="ti ti-movie text-primary"></i>Advanced Editor
    </h2>
    <p class="text-gray-400 text-xs mt-1">Audio visualizer, watermark, overlay & advanced render</p>
  </div>
  <a href="/render-jobs" class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-lg text-xs font-medium transition-colors flex items-center gap-1.5">
    <i class="ti ti-arrow-left text-sm"></i><span>Active Jobs</span>
  </a>
</div>

<!-- Main Layout -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

  <!-- LEFT: Preview + Media (2/3) -->
  <div class="lg:col-span-2 space-y-4">
    <!-- Preview -->
    <div class="editor-panel">
      <div class="editor-panel-header">
        <h3><i class="ti ti-eye text-primary"></i> Preview</h3>
        <span id="edPreviewInfo" class="text-xs text-gray-400">No media selected</span>
      </div>
      <div class="editor-panel-body p-2">
        <div class="preview-canvas">
          <div class="placeholder" id="edPlaceholder">
            <i class="ti ti-video text-4xl mb-2"></i>
            <span class="text-sm">Select video & audio to preview</span>
          </div>
          <video id="edVideoPlayer" class="w-full h-full object-contain hidden" muted loop></video>
          <canvas id="edVizOverlay" class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none hidden"></canvas>
        </div>
      </div>
    </div>

    <!-- Media Library -->
    <div class="editor-panel">
      <div class="editor-panel-header">
        <h3><i class="ti ti-folders text-emerald-400"></i> Media Library</h3>
        <div class="flex gap-1">
          <button onclick="switchMedia('video')" id="tabVideo" class="editor-tab active"><i class="ti ti-video mr-1"></i>Videos</button>
          <button onclick="switchMedia('audio')" id="tabAudio" class="editor-tab"><i class="ti ti-music mr-1"></i>Audio</button>
        </div>
      </div>
      <div class="editor-panel-body">
        <div class="relative mb-3">
          <input type="text" id="mediaSearch" placeholder="Search..." class="w-full bg-dark-700 text-white px-3 py-2 pl-9 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary" oninput="filterMedia()">
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
        </div>
        <div id="videoList" class="max-h-52 overflow-y-auto space-y-1"><div class="text-xs text-gray-400 text-center py-4">Loading...</div></div>
        <div id="audioList" class="max-h-52 overflow-y-auto space-y-1 hidden"><div class="text-xs text-gray-400 text-center py-4">Loading...</div></div>
        <div class="mt-3 pt-3 border-t border-gray-700 flex items-center justify-between">
          <span class="text-xs text-gray-400"><span id="cntVideos">0</span> videos, <span id="cntAudios">0</span> audio</span>
          <button onclick="clearAll()" class="text-xs text-red-400 hover:text-red-300"><i class="ti ti-x mr-1"></i>Clear</button>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: Visualizer + Render Settings (1/3) -->
  <div class="space-y-4">

    <!-- Audio Visualizer -->
    <div class="editor-panel">
      <div class="editor-panel-header">
        <h3><i class="ti ti-waveform text-violet-400"></i> Audio Visualizer</h3>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="vizEnabled" class="sr-only peer" onchange="toggleViz()">
          <div class="w-9 h-5 bg-gray-600 peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
        </label>
      </div>
      <div class="editor-panel-body" id="vizPanel">
        <!-- Type Grid (14 types) -->
        <label class="text-xs font-medium text-gray-400 block mb-2">Type</label>
        <div class="grid grid-cols-4 gap-1 mb-3" id="vizTypeGrid">
          <div class="viz-type-card active" data-type="spectrum" onclick="pickVizType(this)"><div class="icon">📊</div><div class="text-[9px] text-gray-300">Spectrum</div></div>
          <div class="viz-type-card" data-type="waveform" onclick="pickVizType(this)"><div class="icon">🌊</div><div class="text-[9px] text-gray-300">Wave</div></div>
          <div class="viz-type-card" data-type="circular" onclick="pickVizType(this)"><div class="icon">🔵</div><div class="text-[9px] text-gray-300">Circular</div></div>
          <div class="viz-type-card" data-type="particles" onclick="pickVizType(this)"><div class="icon">✨</div><div class="text-[9px] text-gray-300">Particles</div></div>
          <div class="viz-type-card" data-type="bars_center" onclick="pickVizType(this)"><div class="icon">📶</div><div class="text-[9px] text-gray-300">Mirror</div></div>
          <div class="viz-type-card" data-type="wave_line" onclick="pickVizType(this)"><div class="icon">〰️</div><div class="text-[9px] text-gray-300">Line</div></div>
          <div class="viz-type-card" data-type="frequency_dots" onclick="pickVizType(this)"><div class="icon">⚡</div><div class="text-[9px] text-gray-300">Dots</div></div>
          <div class="viz-type-card" data-type="spectrogram" onclick="pickVizType(this)"><div class="icon">🌡️</div><div class="text-[9px] text-gray-300">Heatmap</div></div>
          <div class="viz-type-card" data-type="showcqt" onclick="pickVizType(this)"><div class="icon">🎹</div><div class="text-[9px] text-gray-300">Piano</div></div>
          <div class="viz-type-card" data-type="histogram" onclick="pickVizType(this)"><div class="icon">📉</div><div class="text-[9px] text-gray-300">Histogram</div></div>
          <div class="viz-type-card" data-type="vector_lissajous" onclick="pickVizType(this)"><div class="icon">🌀</div><div class="text-[9px] text-gray-300">Lissajous</div></div>
          <div class="viz-type-card" data-type="vector_polar" onclick="pickVizType(this)"><div class="icon">🎯</div><div class="text-[9px] text-gray-300">Polar</div></div>
          <div class="viz-type-card" data-type="bars_bottom" onclick="pickVizType(this)"><div class="icon">📈</div><div class="text-[9px] text-gray-300">Bottom</div></div>
          <div class="viz-type-card" data-type="phase" onclick="pickVizType(this)"><div class="icon">🔄</div><div class="text-[9px] text-gray-300">Phase</div></div>
        </div>

        <!-- Colors (12) -->
        <label class="text-xs font-medium text-gray-400 block mb-2">Color</label>
        <div class="flex flex-wrap gap-1.5 mb-3" id="vizColorGrid">
          <div class="color-swatch active" data-color="purple" onclick="pickColor(this)" style="background:linear-gradient(135deg,#8B5CF6,#EC4899)" title="Purple"></div>
          <div class="color-swatch" data-color="blue" onclick="pickColor(this)" style="background:linear-gradient(135deg,#3B82F6,#06B6D4)" title="Blue"></div>
          <div class="color-swatch" data-color="green" onclick="pickColor(this)" style="background:linear-gradient(135deg,#10B981,#34D399)" title="Green"></div>
          <div class="color-swatch" data-color="rainbow" onclick="pickColor(this)" style="background:linear-gradient(135deg,#EF4444,#F59E0B,#10B981,#3B82F6,#8B5CF6)" title="Rainbow"></div>
          <div class="color-swatch" data-color="fire" onclick="pickColor(this)" style="background:linear-gradient(135deg,#DC2626,#F59E0B)" title="Fire"></div>
          <div class="color-swatch" data-color="neon" onclick="pickColor(this)" style="background:linear-gradient(135deg,#FF00FF,#00FFFF)" title="Neon"></div>
          <div class="color-swatch" data-color="ocean" onclick="pickColor(this)" style="background:linear-gradient(135deg,#0EA5E9,#22D3EE)" title="Ocean"></div>
          <div class="color-swatch" data-color="sunset" onclick="pickColor(this)" style="background:linear-gradient(135deg,#F97316,#FBBF24)" title="Sunset"></div>
          <div class="color-swatch" data-color="gold" onclick="pickColor(this)" style="background:linear-gradient(135deg,#F59E0B,#D97706)" title="Gold"></div>
          <div class="color-swatch" data-color="ice" onclick="pickColor(this)" style="background:linear-gradient(135deg,#93C5FD,#F0F9FF)" title="Ice"></div>
          <div class="color-swatch" data-color="cherry" onclick="pickColor(this)" style="background:linear-gradient(135deg,#E11D48,#FB7185)" title="Cherry"></div>
          <div class="color-swatch" data-color="forest" onclick="pickColor(this)" style="background:linear-gradient(135deg,#166534,#4ADE80)" title="Forest"></div>
        </div>

        <!-- Sliders -->
        <div class="space-y-2 mb-3">
          <div><div class="flex justify-between text-xs mb-0.5"><span class="text-gray-400">Intensity</span><span class="text-white" id="sIntVal">50%</span></div>
            <input type="range" id="sInt" min="10" max="100" value="50" class="w-full accent-primary h-1" oninput="updSlider()"></div>
          <div><div class="flex justify-between text-xs mb-0.5"><span class="text-gray-400">Sensitivity</span><span class="text-white" id="sSenVal">1.0x</span></div>
            <input type="range" id="sSen" min="5" max="30" value="10" class="w-full accent-primary h-1" oninput="updSlider()"></div>
          <div><div class="flex justify-between text-xs mb-0.5"><span class="text-gray-400">Bars</span><span class="text-white" id="sBarVal">64</span></div>
            <input type="range" id="sBar" min="16" max="256" step="8" value="64" class="w-full accent-primary h-1" oninput="updSlider()"></div>
        </div>

        <!-- Toggles -->
        <div class="flex gap-2 mb-3">
          <label class="flex items-center gap-1.5 cursor-pointer bg-dark-700 px-2.5 py-1.5 rounded border border-gray-600 flex-1">
            <input type="checkbox" id="vizMirror" class="w-3.5 h-3.5 rounded text-primary focus:ring-primary cursor-pointer" onchange="animPreview()">
            <span class="text-[11px] text-gray-300">Mirror</span>
          </label>
          <label class="flex items-center gap-1.5 cursor-pointer bg-dark-700 px-2.5 py-1.5 rounded border border-gray-600 flex-1">
            <input type="checkbox" id="vizGlow" class="w-3.5 h-3.5 rounded text-primary focus:ring-primary cursor-pointer" onchange="animPreview()">
            <span class="text-[11px] text-gray-300">Glow</span>
          </label>
        </div>

        <!-- Live Preview -->
        <div class="viz-live-preview"><canvas id="vizCanvas" class="w-full h-full"></canvas></div>
      </div>
    </div>

    <!-- Render Settings (matching Active Jobs) -->
    <div class="editor-panel">
      <div class="editor-panel-header">
        <h3><i class="ti ti-settings text-amber-400"></i> Render Settings</h3>
      </div>
      <div class="editor-panel-body space-y-3">
        <!-- Title -->
        <div>
          <label class="text-xs font-medium text-gray-400 block mb-1"><i class="ti ti-text-size text-xs mr-1"></i>Title</label>
          <input type="text" id="edTitle" placeholder="Video title" value="1" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
        </div>

        <!-- Duration -->
        <div>
          <label class="text-xs font-medium text-gray-400 block mb-1"><i class="ti ti-clock text-xs mr-1"></i>Duration</label>
          <div class="grid grid-cols-2 gap-2">
            <div class="relative">
              <input type="number" id="edHours" min="0" value="0" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm text-center focus:outline-none focus:ring-1 focus:ring-primary">
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] text-gray-500">hours</span>
            </div>
            <div class="relative">
              <input type="number" id="edMinutes" min="0" max="59" value="0" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm text-center focus:outline-none focus:ring-1 focus:ring-primary">
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] text-gray-500">min</span>
            </div>
          </div>
        </div>

        <!-- Audio Options -->
        <div class="space-y-2">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="edFollowAudio" class="w-4 h-4 rounded border-gray-500 text-primary focus:ring-primary cursor-pointer">
            <span class="text-xs text-gray-300"><i class="ti ti-music text-primary text-xs mr-1"></i>Follow audio duration</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="edMuteVideo" class="w-4 h-4 rounded border-gray-500 text-red-500 focus:ring-red-500 cursor-pointer">
            <span class="text-xs text-gray-300"><i class="ti ti-volume-off text-red-400 text-xs mr-1"></i>Mute video audio</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="edAutoUpload" class="w-4 h-4 rounded border-gray-500 text-emerald-500 focus:ring-emerald-500 cursor-pointer" onchange="toggleAutoUpload()">
            <span class="text-xs text-gray-300"><i class="ti ti-upload text-emerald-400 text-xs mr-1"></i>Auto upload to YouTube</span>
          </label>
        </div>

        <!-- Target Channel -->
        <div id="channelSection" class="hidden">
          <label class="text-xs font-medium text-gray-400 block mb-1"><i class="ti ti-brand-youtube text-xs mr-1"></i>Target Channel</label>
          <select id="edChannel" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="">-- Select Channel --</option>
          </select>
        </div>

        <!-- Render Buttons -->
        <div class="grid grid-cols-2 gap-2 mt-2">
          <button onclick="startRender()" id="renderBtn" class="bg-gradient-to-r from-primary to-secondary hover:from-secondary hover:to-primary text-white px-3 py-2.5 rounded-lg font-semibold transition-all flex items-center justify-center gap-1.5 shadow-lg shadow-primary/20 text-sm">
            <i class="ti ti-player-play"></i><span>Render</span>
          </button>
          <button onclick="startLoop()" id="loopBtn" class="bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 px-3 py-2.5 rounded-lg font-semibold transition-all flex items-center justify-center gap-1.5 text-sm">
            <i class="ti ti-repeat"></i><span>Loop</span>
          </button>
        </div>

        <!-- Render Status -->
        <div id="renderStatus" class="hidden mt-3 bg-dark-700 rounded-lg p-3 border border-gray-600">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs text-gray-400" id="renderStatusText">Rendering...</span>
            <span class="text-xs text-primary font-medium" id="renderPct">0%</span>
          </div>
          <div class="w-full bg-gray-700 rounded-full h-1.5">
            <div class="bg-primary h-1.5 rounded-full transition-all" id="renderBar" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// ===== STATE =====
const S = {
  videos: [], audios: [], selVideos: [], selAudios: [],
  vizType: 'spectrum', vizColor: 'purple', vizOn: false,
  vizIntensity: 50, vizSensitivity: 1.0, vizBarCount: 64,
  animId: null
};

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => { loadMedia(); loadAccounts(); initViz(); });

async function loadMedia() {
  try {
    const [vr, ar] = await Promise.all([fetch('/api/videos').then(r=>r.json()), fetch('/api/audios').then(r=>r.json())]);
    S.videos = Array.isArray(vr) ? vr : (vr.videos||[]);
    S.audios = Array.isArray(ar) ? ar : (ar.audios||[]);
    renderVideos(); renderAudios();
  } catch(e) { console.error(e); }
}

async function loadAccounts() {
  try {
    const r = await fetch('/api/youtube/accounts');
    const d = await r.json();
    const accs = d.accounts || d || [];
    const sel = document.getElementById('edChannel');
    accs.forEach(a => { const o = document.createElement('option'); o.value = a.id; o.textContent = a.channel_name||a.email||'Account '+a.id; sel.appendChild(o); });
  } catch(e) {}
}

function renderVideos() {
  const c = document.getElementById('videoList');
  if (!S.videos.length) { c.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No videos</div>'; return; }
  c.innerHTML = S.videos.map(v => `
    <label class="flex items-center gap-2 p-1.5 rounded hover:bg-dark-700 cursor-pointer border border-transparent hover:border-gray-600">
      <input type="checkbox" name="ev" value="${v.id}" class="w-3.5 h-3.5 rounded border-gray-500 text-primary focus:ring-primary cursor-pointer" onchange="updSel()">
      <div class="w-7 h-5 bg-dark-700 rounded overflow-hidden flex-shrink-0">${v.thumbnail_path?`<img src="${v.thumbnail_path}" class="w-full h-full object-cover">`:'<i class="ti ti-video text-[10px] text-gray-500 flex items-center justify-center w-full h-full"></i>'}</div>
      <div class="flex-1 min-w-0"><div class="text-[11px] text-white truncate">${esc(v.title||v.filename||'Untitled')}</div><div class="text-[9px] text-gray-500">${v.duration?fmtDur(v.duration):''} ${v.resolution||''}</div></div>
    </label>`).join('');
}

function renderAudios() {
  const c = document.getElementById('audioList');
  if (!S.audios.length) { c.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No audio</div>'; return; }
  c.innerHTML = S.audios.map(a => `
    <label class="flex items-center gap-2 p-1.5 rounded hover:bg-dark-700 cursor-pointer border border-transparent hover:border-gray-600">
      <input type="checkbox" name="ea" value="${a.id}" class="w-3.5 h-3.5 rounded border-gray-500 text-emerald-500 focus:ring-emerald-500 cursor-pointer" onchange="updSel()">
      <i class="ti ti-music text-emerald-400 text-sm flex-shrink-0"></i>
      <div class="flex-1 min-w-0"><div class="text-[11px] text-white truncate">${esc(a.title||a.filename||'Untitled')}</div><div class="text-[9px] text-gray-500">${a.duration?fmtDur(a.duration):''}</div></div>
    </label>`).join('');
}

// ===== MEDIA CONTROLS =====
function switchMedia(t) {
  document.getElementById('videoList').classList.toggle('hidden', t!=='video');
  document.getElementById('audioList').classList.toggle('hidden', t==='video');
  document.getElementById('tabVideo').classList.toggle('active', t==='video');
  document.getElementById('tabAudio').classList.toggle('active', t!=='video');
}
function updSel() {
  S.selVideos = [...document.querySelectorAll("input[name='ev']:checked")].map(i=>i.value);
  S.selAudios = [...document.querySelectorAll("input[name='ea']:checked")].map(i=>i.value);
  document.getElementById('cntVideos').textContent = S.selVideos.length;
  document.getElementById('cntAudios').textContent = S.selAudios.length;
  document.getElementById('edPreviewInfo').textContent = S.selVideos.length+'V / '+S.selAudios.length+'A';
  refreshPreview();
}
function clearAll() {
  document.querySelectorAll("input[name='ev'],input[name='ea']").forEach(e=>e.checked=false);
  updSel();
}
function filterMedia() {
  const q = document.getElementById('mediaSearch').value.toLowerCase();
  document.querySelectorAll('#videoList label, #audioList label').forEach(el => {
    el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
function refreshPreview() {
  const player = document.getElementById('edVideoPlayer');
  const ph = document.getElementById('edPlaceholder');
  if (S.selVideos.length > 0) {
    const v = S.videos.find(x => String(x.id) === S.selVideos[0]);
    if (v && v.filepath) { player.src = v.filepath; player.classList.remove('hidden'); ph.classList.add('hidden'); player.play().catch(()=>{}); return; }
  }
  player.classList.add('hidden'); ph.classList.remove('hidden'); player.src = '';
}
function toggleAutoUpload() {
  document.getElementById('channelSection').classList.toggle('hidden', !document.getElementById('edAutoUpload').checked);
}

// ===== VISUALIZER =====
function toggleViz() {
  S.vizOn = document.getElementById('vizEnabled').checked;
  const p = document.getElementById('vizPanel');
  p.style.opacity = S.vizOn ? '1' : '0.4';
  p.style.pointerEvents = S.vizOn ? 'auto' : 'none';
  animPreview();
}
function pickVizType(el) {
  document.querySelectorAll('#vizTypeGrid .viz-type-card').forEach(c=>c.classList.remove('active'));
  el.classList.add('active'); S.vizType = el.dataset.type; animPreview();
}
function pickColor(el) {
  document.querySelectorAll('#vizColorGrid .color-swatch').forEach(c=>c.classList.remove('active'));
  el.classList.add('active'); S.vizColor = el.dataset.color; animPreview();
}
function updSlider() {
  const i = document.getElementById('sInt').value;
  const s = document.getElementById('sSen').value;
  const b = document.getElementById('sBar').value;
  document.getElementById('sIntVal').textContent = i+'%';
  document.getElementById('sSenVal').textContent = (s/10).toFixed(1)+'x';
  document.getElementById('sBarVal').textContent = b;
  S.vizIntensity = +i; S.vizSensitivity = +(s/10).toFixed(1); S.vizBarCount = +b;
  animPreview();
}
function initViz() {
  const p = document.getElementById('vizPanel');
  p.style.opacity = '0.4'; p.style.pointerEvents = 'none';
  animPreview();
}
function animPreview() {
  if (S.animId) cancelAnimationFrame(S.animId);
  const canvas = document.getElementById('vizCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth * 2; canvas.height = canvas.offsetHeight * 2; ctx.scale(2,2);
  const w = canvas.offsetWidth, h = canvas.offsetHeight;
  if (!S.vizOn) { ctx.clearRect(0,0,w,h); ctx.fillStyle='#374151'; ctx.font='11px sans-serif'; ctx.textAlign='center'; ctx.fillText('Enable visualizer to preview',w/2,h/2+4); return; }
  const schemes = {
    purple:['#8B5CF6','#EC4899'], blue:['#3B82F6','#06B6D4'], green:['#10B981','#34D399'],
    rainbow:['#EF4444','#F59E0B','#10B981','#3B82F6','#8B5CF6'], fire:['#DC2626','#F59E0B','#FCD34D'],
    neon:['#FF00FF','#00FFFF'], ocean:['#0EA5E9','#06B6D4','#22D3EE'], sunset:['#F97316','#FB923C','#FBBF24'],
    gold:['#F59E0B','#D97706'], ice:['#93C5FD','#DBEAFE','#F0F9FF'], cherry:['#E11D48','#FB7185'], forest:['#166534','#4ADE80']
  };
  const colors = schemes[S.vizColor] || schemes.purple;
  const bc = S.vizBarCount; let t = 0;

  function draw() {
    ctx.clearRect(0,0,w,h);
    const bw = w/bc, int = S.vizIntensity/100, mirror = document.getElementById('vizMirror').checked, glow = document.getElementById('vizGlow').checked;
    for (let i=0; i<bc; i++) {
      const f = (i/bc)*Math.PI*2;
      let bH = (Math.sin(t*2+f)*0.3 + Math.sin(t*3.7+f*1.5)*0.2 + 0.5) * h * int;
      if (mirror) bH = Math.abs(Math.sin(t*2+f)) * h * int * 0.8;
      const x = i*bw;
      const grad = ctx.createLinearGradient(x,h,x,h-bH);
      colors.forEach((c,idx)=>grad.addColorStop(idx/Math.max(1,colors.length-1),c));
      ctx.shadowBlur = glow ? 6 : 0; ctx.shadowColor = colors[0]; ctx.fillStyle = grad;
      const tp = S.vizType;
      if (tp==='circular'||tp==='frequency_dots'||tp==='particles'||tp==='vector_lissajous'||tp==='vector_polar'||tp==='phase') {
        ctx.beginPath(); ctx.arc(x+bw/2, h-bH/2, Math.max(2,bw/3), 0, Math.PI*2); ctx.fill();
      } else if (tp==='waveform'||tp==='wave_line') {
        if(i===0) ctx.beginPath(); ctx.lineTo(x+bw/2, h-bH);
        if(i===bc-1){ctx.strokeStyle=colors[0];ctx.lineWidth=2;ctx.stroke();}
      } else if (tp==='spectrogram'||tp==='showcqt') {
        const alpha = bH/h; ctx.globalAlpha = alpha; ctx.fillRect(x,0,bw-1,h); ctx.globalAlpha = 1;
      } else if (tp==='histogram') {
        ctx.fillRect(x+1, h/2-bH/2, bw-2, bH);
      } else {
        ctx.fillRect(x+1, h-bH, bw-2, bH);
      }
    }
    t += 0.04; S.animId = requestAnimationFrame(draw);
  }
  draw();
}

// ===== RENDER =====
async function startRender() {
  if (!S.selVideos.length) { alert('Select at least one video'); return; }
  const h = parseInt(document.getElementById('edHours').value||0);
  const m = parseInt(document.getElementById('edMinutes').value||0);
  const dur = h*3600 + m*60;
  if (dur<=0 && !document.getElementById('edFollowAudio').checked) { alert('Set duration or enable Follow Audio'); return; }

  const vizSettings = S.vizOn ? {
    type: S.vizType, intensity: S.vizIntensity, sensitivity: S.vizSensitivity,
    smoothing: 0.8, barCount: S.vizBarCount, color: S.vizColor,
    mirror: document.getElementById('vizMirror').checked, glow: document.getElementById('vizGlow').checked
  } : { type: 'none' };

  const body = {
    title: document.getElementById('edTitle').value || 'Editor Render',
    targetDurationSeconds: dur,
    videoIds: S.selVideos,
    audioIds: S.selAudios,
    followAudioDuration: document.getElementById('edFollowAudio').checked,
    muteVideoAudio: document.getElementById('edMuteVideo').checked,
    autoUploadToYoutube: document.getElementById('edAutoUpload').checked,
    targetAccountId: document.getElementById('edChannel').value || null,
    visualizerPreset: S.vizOn ? S.vizType : 'none',
    visualizerSettings: vizSettings
  };

  const btn = document.getElementById('renderBtn');
  btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader animate-spin"></i> Starting...';
  try {
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
    const res = await fetch('/api/render/jobs', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':csrf||''}, body:JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { pollStatus(data.jobId||data.id); } else { alert(data.message||data.error||'Failed'); }
  } catch(e) { alert('Error: '+e.message); }
  finally { btn.disabled=false; btn.innerHTML='<i class="ti ti-player-play"></i><span>Render</span>'; }
}

async function startLoop() {
  if (!S.selVideos.length) { alert('Select at least one video'); return; }
  const loopCount = prompt('How many loops? (2-100)', '3');
  if (!loopCount || isNaN(loopCount) || +loopCount < 2) return;

  const btn = document.getElementById('loopBtn');
  btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader animate-spin"></i>';
  try {
    // First create a render job, then loop it
    const body = {
      title: document.getElementById('edTitle').value || 'Loop Render',
      targetDurationSeconds: 60, videoIds: S.selVideos, audioIds: S.selAudios,
      followAudioDuration: true, muteVideoAudio: document.getElementById('edMuteVideo').checked,
      autoUploadToYoutube: document.getElementById('edAutoUpload').checked,
      targetAccountId: document.getElementById('edChannel').value || null,
      visualizerPreset: 'none', visualizerSettings: { type: 'none' }
    };
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
    const res = await fetch('/api/render/jobs', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':csrf||''}, body:JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { pollStatus(data.jobId||data.id); } else { alert(data.message||'Failed'); }
  } catch(e) { alert('Error: '+e.message); }
  finally { btn.disabled=false; btn.innerHTML='<i class="ti ti-repeat"></i><span>Loop</span>'; }
}

function pollStatus(jobId) {
  const status = document.getElementById('renderStatus');
  status.classList.remove('hidden');
  const iv = setInterval(async () => {
    try {
      const r = await fetch('/api/render/jobs/'+jobId);
      const j = await r.json();
      const p = j.progress||0;
      document.getElementById('renderPct').textContent = p+'%';
      document.getElementById('renderBar').style.width = p+'%';
      if (j.status==='completed') {
        clearInterval(iv);
        document.getElementById('renderStatusText').textContent = 'Completed!';
        document.getElementById('renderPct').textContent = '100%';
        document.getElementById('renderBar').style.width = '100%';
        setTimeout(()=>status.classList.add('hidden'), 5000);
      } else if (j.status==='failed') {
        clearInterval(iv);
        document.getElementById('renderStatusText').textContent = 'Failed';
        document.getElementById('renderBar').classList.replace('bg-primary','bg-red-500');
      }
    } catch(e){}
  }, 2000);
}

// ===== UTILS =====
function esc(t) { if(!t)return''; const d=document.createElement('div'); d.textContent=t; return d.innerHTML; }
function fmtDur(s) { if(!s)return''; const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=Math.floor(s%60); return h>0?h+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0'):m+':'+String(sec).padStart(2,'0'); }
</script>
