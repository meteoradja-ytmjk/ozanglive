    smoothingValue.textContent = parseFloat(e.target.value).toFixed(1);
    updateVisualizerPreview();
  });
}

if (visualizerBarCount) {
  visualizerBarCount.addEventListener('input', (e) => {
    barCountValue.textContent = e.target.value;
    generateVisualizerBars(parseInt(e.target.value));
    updateVisualizerPreview();
  });
}

if (visualizerColor) {
  visualizerColor.addEventListener('change', updateVisualizerPreview);
}

if (visualizerMirror) {
  visualizerMirror.addEventListener('change', updateVisualizerPreview);
}

if (visualizerGlow) {
