    if (overlayOptions) {
      overlayOptions.classList.remove('hidden');
    }
    
    // Update realtime preview
    updateRealtimePreview();
    
    showToast(`✓ Overlay video loaded: ${file.name}`);
  };
  
  reader.readAsDataURL(file);
}

function removeOverlayVideo() {
  overlayVideoData = null;
