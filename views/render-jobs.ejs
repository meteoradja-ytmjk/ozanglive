<% layout('layout') -%>

<style>
/* Mobile action buttons */
@media (max-width: 1023px) {
  .mobile-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding: 0 0 1rem 0;
    margin-bottom: 1rem;
  }
  
  .mobile-action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0.5rem;
    background: #1F2937;
    border: 1px solid #4B5563;
    border-radius: 0.75rem;
    color: #D1D5DB;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    min-height: 80px;
  }
  
  .mobile-action-btn:active {
    transform: scale(0.95);
  }
  
  .mobile-action-btn.primary {
    background: #8B5CF6;
    color: white;
    border-color: #8B5CF6;
  }
  
  .mobile-action-btn i {
    font-size: 1.5rem;
  }
}

@media (min-width: 1024px) {
  .mobile-actions {
    display: none !important;
  }
}

/* Template & Preview Modals */
.modal-backdrop {
  backdrop-filter: blur(4px);
}

/* Progress animations */
@keyframes progressPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.progress-active {
  animation: progressPulse 2s ease-in-out infinite;
}

/* Notification permission badge */
.notification-badge {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 9999;
  animation: slideInRight 0.3s ease;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* Filter chips */
.filter-chip {
  transition: all 0.2s ease;
}

.filter-chip:hover {
  transform: translateY(-1px);
}

.filter-chip.active {
  background: #8B5CF6;
  color: white;
  border-color: #8B5CF6;
}

/* Mini Live Preview */
.mini-preview {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
}

.mini-preview video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mini-preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #6B7280;
}

/* Watermark Preview */
.watermark-preview {
  position: relative;
  width: 100%;
  height: 120px;
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
  border-radius: 0.5rem;
  overflow: hidden;
  border: 1px solid #374151;
}

.watermark-overlay {
  position: absolute;
  pointer-events: none;
  max-width: 30%;
  max-height: 30%;
  opacity: 0.7;
}

.watermark-overlay.top-left { top: 10px; left: 10px; }
.watermark-overlay.top-right { top: 10px; right: 10px; }
.watermark-overlay.bottom-left { bottom: 10px; left: 10px; }
.watermark-overlay.bottom-right { bottom: 10px; right: 10px; }
.watermark-overlay.center { top: 50%; left: 50%; transform: translate(-50%, -50%); }

/* Advanced Visualizer Preview */
.visualizer-preview {
  width: 100%;
  height: 60px;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
  position: relative;
}

.visualizer-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding: 5px;
  gap: 2px;
}

.visualizer-bar {
  flex: 1;
  background: linear-gradient(to top, #8B5CF6, #EC4899);
  border-radius: 2px;
  animation: visualizerPulse 1s ease-in-out infinite;
}

@keyframes visualizerPulse {
  0%, 100% { height: 20%; }
  50% { height: 80%; }
}

.visualizer-bar:nth-child(2n) { animation-delay: 0.1s; }
.visualizer-bar:nth-child(3n) { animation-delay: 0.2s; }
.visualizer-bar:nth-child(4n) { animation-delay: 0.3s; }

/* Batch Render Queue */
.batch-queue-item {
  transition: all 0.2s ease;
}

.batch-queue-item:hover {
  background: rgba(139, 92, 246, 0.1);
  border-color: #8B5CF6;
}

.batch-queue-item.processing {
  border-color: #10B981;
  background: rgba(16, 185, 129, 0.05);
}

/* Real-time Progress Ring */
.progress-ring {
  transform: rotate(-90deg);
}

.progress-ring-circle {
  transition: stroke-dashoffset 0.3s ease;
}

/* Collapsible sections */
.collapsible-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.collapsible-content.open {
  max-height: 2000px;
}
</style>
</style>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold">Render Dashboard</h2>
    <p class="text-gray-400 text-sm mt-1">Pilih channel, jam, menit, video, dan audio untuk proses render</p>
  </div>
</div>

<!-- Tab Navigation -->
<div class="flex w-full border border-gray-600 rounded-lg mb-6 overflow-hidden bg-gray-800/50">
  <button onclick="switchRenderTab('jobs')" id="jobsTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center bg-primary/20 text-primary border-b-2 border-primary">
    <i class="ti ti-video mr-2"></i>Active Jobs
  </button>
  <div class="w-px bg-gray-600"></div>
  <button onclick="switchRenderTab('history')" id="historyTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center text-gray-400 hover:text-white hover:bg-gray-700/50">
    <i class="ti ti-history mr-2"></i>History
  </button>
</div>

<!-- Mobile Action Buttons -->
<div class="mobile-actions lg:hidden">
  <button class="mobile-action-btn primary" id="mobileCreateBtn">
    <i class="ti ti-player-play"></i>
    <span>Render</span>
  </button>
  <button class="mobile-action-btn" id="mobileTemplateBtn">
    <i class="ti ti-template"></i>
    <span>Template</span>
  </button>
  <button class="mobile-action-btn" id="mobileRefreshBtn">
    <i class="ti ti-refresh"></i>
    <span>Refresh</span>
  </button>
</div>

<!-- Jobs Container (Active Tab) -->
<div id="jobsContainer" class="tab-content">

<!-- Main Form Card -->
<div class="bg-gray-800 rounded-lg p-4 md:p-6 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
    <h3 class="text-lg font-semibold">Render Settings</h3>
    <div class="flex gap-2">
      <button onclick="openTemplateModal()" class="flex items-center gap-2 px-4 py-2 bg-primary/20 hover:bg-primary/30 text-primary rounded-lg text-sm font-medium transition-colors">
        <i class="ti ti-template"></i>
        <span>Templates</span>
      </button>
      <button onclick="openPreviewModal()" class="flex items-center gap-2 px-4 py-2 bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 rounded-lg text-sm font-medium transition-colors">
        <i class="ti ti-eye"></i>
        <span>Preview</span>
      </button>
    </div>
  </div>
  
  <div class="space-y-4">
    <!-- Row 1: Target Channel & Title -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="text-sm font-medium text-white block mb-2">Target Channel</label>
        <select id="targetAccountId" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
          <option value="">-- Pilih Channel --</option>
        </select>
      </div>
      
      <div>
        <label class="text-sm font-medium text-white block mb-2">Judul</label>
        <input type="text" id="title" value="1" placeholder="Masukkan judul" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
      </div>
    </div>
    
    <!-- Row 2: Duration & Visualizer -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-sm font-medium text-white block mb-2">Jam</label>
          <input type="number" id="durationHours" min="0" value="0" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        </div>
        <div>
          <label class="text-sm font-medium text-white block mb-2">Menit</label>
          <input type="number" id="durationMinutes" min="0" max="59" value="0" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        </div>
      </div>
      
      <div>
        <label class="text-sm font-medium text-white block mb-2">Overlay / Spectrum</label>
        <select id="visualizerPreset" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
          <option value="none">Tanpa overlay</option>
          <option value="spectrum">Spectrum</option>
          <option value="bars">Bars</option>
          <option value="wave">Wave</option>
        </select>
      </div>
    </div>
    
    <!-- Row 3: Checkboxes & Toggle in one row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="flex items-center gap-2 bg-dark-700 p-3 rounded-lg border border-gray-600">
        <input type="checkbox" id="followAudioDuration" class="w-4 h-4 rounded border-gray-500 bg-dark-700 text-primary focus:ring-primary">
        <label for="followAudioDuration" class="text-sm text-gray-300">Loop ikuti durasi audio</label>
      </div>
      
      <div class="flex items-center justify-between bg-dark-700 p-3 rounded-lg border border-gray-600">
        <div class="text-sm font-medium text-white">Upload otomatis</div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="autoUploadToYoutube" class="sr-only peer">
          <div class="w-11 h-6 bg-gray-600 rounded-full peer peer-checked:bg-primary transition-colors"></div>
          <div class="absolute left-[2px] top-[2px] w-5 h-5 bg-white rounded-full transition-all peer-checked:translate-x-5"></div>
        </label>
      </div>
    </div>
    
    <!-- Action Buttons (Desktop & Mobile) -->
    <div class="grid grid-cols-3 gap-3 pt-2">
      <button id="createBtn" class="bg-primary hover:bg-secondary text-white px-4 py-2.5 rounded-lg font-medium transition-colors flex flex-col items-center justify-center gap-1">
        <i class="ti ti-player-play text-lg"></i>
        <span class="text-sm">Render</span>
      </button>
      <button onclick="saveAsTemplate()" class="bg-yellow-500/20 hover:bg-yellow-500/30 border border-yellow-500/50 text-yellow-400 px-4 py-2.5 rounded-lg font-medium transition-colors flex flex-col items-center justify-center gap-1">
        <i class="ti ti-device-floppy text-lg"></i>
        <span class="text-sm">Template</span>
      </button>
      <button id="resetBtn" class="bg-dark-700 hover:bg-dark-600 border border-gray-600 text-gray-300 px-4 py-2.5 rounded-lg font-medium transition-colors flex flex-col items-center justify-center gap-1">
        <i class="ti ti-eraser text-lg"></i>
        <span class="text-sm">Reset</span>
      </button>
    </div>
  </div>
</div>

<!-- Advanced Features Grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
  
  <!-- Mini Live Preview -->
  <div class="bg-gray-800 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-white flex items-center gap-2">
        <i class="ti ti-eye text-primary"></i>
        Mini Live Preview
      </h3>
      <button onclick="refreshMiniPreview()" class="text-xs text-gray-400 hover:text-primary">
        <i class="ti ti-refresh"></i>
      </button>
    </div>
    <div class="mini-preview" id="miniPreview">
      <div class="mini-preview-placeholder">
        <i class="ti ti-video text-4xl mb-2"></i>
        <span class="text-xs">Select videos to preview</span>
      </div>
    </div>
    <div class="mt-2 text-xs text-gray-400 text-center" id="previewInfo">
      No preview available
    </div>
  </div>
  
  <!-- Advanced Visualizer -->
  <div class="bg-gray-800 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-white flex items-center gap-2">
        <i class="ti ti-waveform text-primary"></i>
        Advanced Visualizer
      </h3>
      <button onclick="toggleVisualizerSettings()" class="text-xs text-gray-400 hover:text-primary">
        <i class="ti ti-settings"></i>
      </button>
    </div>
    
    <div class="space-y-3">
      <!-- Preset Selection -->
      <div>
        <label class="text-xs font-medium text-gray-300 block mb-2">Visualizer Type</label>
        <select id="visualizerType" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary" onchange="updateVisualizerType()">
          <option value="none">No Visualizer</option>
          <option value="spectrum">Audio Spectrum</option>
          <option value="bars">Frequency Bars</option>
          <option value="wave">Waveform</option>
          <option value="circular">Circular Spectrum</option>
          <option value="particles">Audio Particles</option>
          <option value="custom">Custom JSON</option>
        </select>
      </div>
      
      <!-- Custom JSON Upload Section -->
      <div id="customJsonSection" class="hidden">
        <label class="text-xs font-medium text-gray-300 block mb-2">
          Custom Spectrum Files (.json)
          <span class="text-gray-500 ml-1">(Multiple files supported)</span>
        </label>
        <input type="file" id="spectrumJsonFiles" accept=".json" multiple class="hidden" onchange="handleSpectrumJsonUpload(event)">
        <button onclick="document.getElementById('spectrumJsonFiles').click()" class="w-full bg-dark-700 hover:bg-dark-600 border border-gray-600 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
          <i class="ti ti-upload"></i>
          <span>Upload JSON Spectrum Files</span>
        </button>
        
        <!-- Uploaded Files List -->
        <div id="spectrumFilesList" class="mt-2 space-y-1 max-h-32 overflow-y-auto">
          <!-- Files will be listed here -->
        </div>
        
        <!-- JSON Format Guide -->
        <div class="mt-2 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-xs text-blue-300">
          <div class="flex items-start gap-2">
            <i class="ti ti-info-circle mt-0.5"></i>
            <div>
              <strong>JSON Format:</strong>
              <pre class="mt-1 text-xs bg-black/30 p-2 rounded overflow-x-auto">{
  "name": "My Spectrum",
  "type": "bars|wave|circular",
  "bars": 64,
  "smoothing": 0.8,
  "colors": ["#8B5CF6", "#EC4899"],
  "sensitivity": 1.5,
  "mirror": true
}</pre>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Advanced Settings (Collapsible) -->
      <div id="visualizerAdvancedSettings" class="collapsible-content">
        <div class="space-y-3 pt-2 border-t border-gray-700">
          <!-- Intensity -->
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-2 flex items-center justify-between">
              <span>Intensity</span>
              <span id="intensityValue" class="text-primary">50%</span>
            </label>
            <input type="range" id="visualizerIntensity" min="0" max="100" value="50" class="w-full h-2 bg-dark-700 rounded-lg appearance-none cursor-pointer accent-primary">
          </div>
          
          <!-- Sensitivity -->
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-2 flex items-center justify-between">
              <span>Audio Sensitivity</span>
              <span id="sensitivityValue" class="text-primary">1.0x</span>
            </label>
            <input type="range" id="visualizerSensitivity" min="0.5" max="3" step="0.1" value="1.0" class="w-full h-2 bg-dark-700 rounded-lg appearance-none cursor-pointer accent-primary">
          </div>
          
          <!-- Smoothing -->
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-2 flex items-center justify-between">
              <span>Smoothing</span>
              <span id="smoothingValue" class="text-primary">0.8</span>
            </label>
            <input type="range" id="visualizerSmoothing" min="0" max="1" step="0.1" value="0.8" class="w-full h-2 bg-dark-700 rounded-lg appearance-none cursor-pointer accent-primary">
          </div>
          
          <!-- Bar Count -->
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-2 flex items-center justify-between">
              <span>Bar Count</span>
              <span id="barCountValue" class="text-primary">64</span>
            </label>
            <input type="range" id="visualizerBarCount" min="16" max="128" step="8" value="64" class="w-full h-2 bg-dark-700 rounded-lg appearance-none cursor-pointer accent-primary">
          </div>
          
          <!-- Color Scheme -->
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-2">Color Scheme</label>
            <select id="visualizerColor" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
              <option value="purple">Purple Gradient</option>
              <option value="blue">Blue Wave</option>
              <option value="green">Green Pulse</option>
              <option value="rainbow">Rainbow</option>
              <option value="fire">Fire</option>
              <option value="neon">Neon Glow</option>
              <option value="ocean">Ocean Deep</option>
              <option value="sunset">Sunset</option>
            </select>
          </div>
          
          <!-- Mirror Effect -->
          <div class="flex items-center justify-between p-2 bg-dark-700 rounded-lg border border-gray-600">
            <span class="text-xs font-medium text-gray-300">Mirror Effect</span>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="visualizerMirror" class="sr-only peer">
              <div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:bg-primary transition-colors"></div>
              <div class="absolute left-[2px] top-[2px] w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-4"></div>
            </label>
          </div>
          
          <!-- Glow Effect -->
          <div class="flex items-center justify-between p-2 bg-dark-700 rounded-lg border border-gray-600">
            <span class="text-xs font-medium text-gray-300">Glow Effect</span>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="visualizerGlow" class="sr-only peer" checked>
              <div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:bg-primary transition-colors"></div>
              <div class="absolute left-[2px] top-[2px] w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-4"></div>
            </label>
          </div>
        </div>
      </div>
      
      <!-- Live Preview -->
      <div class="visualizer-preview" id="visualizerPreviewBox">
        <div class="visualizer-bars" id="visualizerBars">
          <!-- Bars will be generated dynamically -->
        </div>
      </div>
      
      <!-- Preset Actions -->
      <div class="grid grid-cols-2 gap-2">
        <button onclick="saveVisualizerPreset()" class="bg-primary/20 hover:bg-primary/30 border border-primary/50 text-primary px-3 py-2 rounded-lg text-xs transition-colors flex items-center justify-center gap-1">
          <i class="ti ti-device-floppy"></i>
          <span>Save Preset</span>
        </button>
        <button onclick="loadVisualizerPreset()" class="bg-blue-500/20 hover:bg-blue-500/30 border border-blue-500/50 text-blue-400 px-3 py-2 rounded-lg text-xs transition-colors flex items-center justify-center gap-1">
          <i class="ti ti-folder-open"></i>
          <span>Load Preset</span>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Watermark & Batch Queue Combined -->
  <div class="bg-gray-800 rounded-lg p-4">
    <!-- Tabs -->
    <div class="flex border-b border-gray-700 mb-4">
      <button onclick="switchWatermarkBatchTab('watermark')" id="watermarkTabBtn" class="flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-primary text-primary">
        <i class="ti ti-photo mr-1"></i>Watermark
      </button>
      <button onclick="switchWatermarkBatchTab('batch')" id="batchTabBtn" class="flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-transparent text-gray-400 hover:text-white">
        <i class="ti ti-list-check mr-1"></i>Batch Queue
        <span class="ml-1 bg-primary/20 text-primary px-1.5 py-0.5 rounded-full text-xs" id="batchCountTab">0</span>
      </button>
    </div>
    
    <!-- Watermark Content -->
    <div id="watermarkContent" class="space-y-3">
      <div>
        <label class="text-xs font-medium text-gray-300 block mb-2">Watermark Image</label>
        <input type="file" id="watermarkFile" accept="image/*" class="hidden" onchange="handleWatermarkUpload(event)">
        <button onclick="document.getElementById('watermarkFile').click()" class="w-full bg-dark-700 hover:bg-dark-600 border border-gray-600 text-gray-300 px-3 py-2 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
          <i class="ti ti-upload"></i>
          <span>Upload Image</span>
        </button>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs font-medium text-gray-300 block mb-2">Position</label>
          <select id="watermarkPosition" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary" onchange="updateWatermarkPreview()">
            <option value="top-left">Top Left</option>
            <option value="top-right">Top Right</option>
            <option value="bottom-left">Bottom Left</option>
            <option value="bottom-right" selected>Bottom Right</option>
            <option value="center">Center</option>
          </select>
        </div>
        <div>
          <label class="text-xs font-medium text-gray-300 block mb-2">Opacity</label>
          <input type="range" id="watermarkOpacity" min="0" max="100" value="70" class="w-full h-2 bg-dark-700 rounded-lg appearance-none cursor-pointer accent-primary" onchange="updateWatermarkPreview()">
          <div class="text-xs text-gray-500 text-center mt-1" id="opacityValue">70%</div>
        </div>
      </div>
      <div class="watermark-preview" id="watermarkPreviewBox">
        <div class="flex items-center justify-center h-full text-gray-500 text-xs">
          <span>Watermark preview</span>
        </div>
        <img id="watermarkOverlay" class="watermark-overlay bottom-right hidden" src="" alt="Watermark">
      </div>
    </div>
    
    <!-- Batch Queue Content -->
    <div id="batchContent" class="hidden space-y-3">
      <div class="space-y-2 max-h-64 overflow-y-auto" id="batchQueueList">
        <div class="text-xs text-gray-400 text-center py-4">
          No items in queue
        </div>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <button onclick="addToBatchQueue()" class="bg-primary/20 hover:bg-primary/30 border border-primary/50 text-primary px-3 py-2 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
          <i class="ti ti-plus"></i>
          <span>Add to Queue</span>
        </button>
