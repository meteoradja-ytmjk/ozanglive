}

// FILTER/SEARCH MEDIA FUNCTION
function filterMedia(type) {
  const searchInput = type === 'video' 
    ? document.getElementById('videoSearchInput')
    : document.getElementById('audioSearchInput');
  
  const container = type === 'video'
    ? document.getElementById('videoList')
    : document.getElementById('audioList');
  
  if (!searchInput || !container) return;
  
  const searchTerm = searchInput.value.toLowerCase().trim();
  const allGroups = container.querySelectorAll('details');
  
  let visibleCount = 0;
  
  allGroups.forEach(group => {
    // Get folder/group name
    const groupNameElement = group.querySelector('summary .text-sm.font-medium');
    const groupName = groupNameElement ? groupNameElement.textContent.toLowerCase() : '';
    
    // Check if search term matches folder name
    const folderMatches = searchTerm === '' || groupName.includes(searchTerm);
    
    const items = group.querySelectorAll('.media-item');
    let groupHasVisibleItems = false;
    
    items.forEach(item => {
      const titleElement = item.querySelector('.text-sm.text-white');
      const title = titleElement ? titleElement.textContent.toLowerCase() : '';
      
      // Show item if: no search term, OR folder matches, OR file name matches
      if (searchTerm === '' || folderMatches || title.includes(searchTerm)) {
        item.style.display = '';
        groupHasVisibleItems = true;
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });
    
    // Show group if folder name matches OR has visible items
    if (folderMatches || groupHasVisibleItems) {
      group.style.display = '';
      // Auto-open group if folder name matches
      if (folderMatches && searchTerm !== '') {
        group.setAttribute('open', '');
      }
    } else {
      group.style.display = 'none';
    }
  });
  
  // Show message if no results
  const existingNoResults = container.querySelector('.no-results-message');
  if (existingNoResults) {
    existingNoResults.remove();
  }
  
  if (visibleCount === 0 && searchTerm !== '') {
    const noResultsMsg = document.createElement('div');
    noResultsMsg.className = 'no-results-message text-xs text-gray-400 text-center py-4';
    noResultsMsg.innerHTML = `<i class="ti ti-search-off text-2xl mb-2 block"></i>No ${type}s found for "${searchTerm}"`;
    container.appendChild(noResultsMsg);
  }
}

function updateMediaSelectionCount() {
