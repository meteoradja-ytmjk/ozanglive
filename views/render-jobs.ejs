}

// FEATURE 3: WATERMARK
let watermarkImageData = null;
let uploadedWatermarks = [];
let activeWatermarkIndex = null;

// Switch between Watermark and Batch tabs
function switchWatermarkBatchTab(tab) {
  const watermarkBtn = document.getElementById('watermarkTabBtn');
  const batchBtn = document.getElementById('batchTabBtn');
  const watermarkContent = document.getElementById('watermarkContent');
  const batchContent = document.getElementById('batchContent');
  
  if (tab === 'watermark') {
    watermarkBtn.className = 'flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-primary text-primary';
    batchBtn.className = 'flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-transparent text-gray-400 hover:text-white';
    watermarkContent.classList.remove('hidden');
    batchContent.classList.add('hidden');
  } else {
    batchBtn.className = 'flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-primary text-primary';
    watermarkBtn.className = 'flex-1 px-4 py-2 text-sm font-medium transition-colors border-b-2 border-transparent text-gray-400 hover:text-white';
    batchContent.classList.remove('hidden');
    watermarkContent.classList.add('hidden');
  }
}

function handleWatermarkUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  
  // Validate file type
  const validTypes = ['image/png', 'image/jpeg', 'image/jpg'];
  if (!validTypes.includes(file.type)) {
    alert('Please upload PNG or JPG image only');
    return;
  }
  
  // Validate file size (max 5MB)
  const maxSize = 5 * 1024 * 1024; // 5MB
  if (file.size > maxSize) {
    alert('File size too large. Maximum 5MB');
    return;
  }
  
  const reader = new FileReader();
  reader.onload = (e) => {
    const imageData = e.target.result;
    
    // Add to uploaded watermarks list
    uploadedWatermarks.push({
      name: file.name,
      data: imageData,
      type: file.type,
      size: file.size,
      uploadedAt: new Date().toISOString()
    });
    
    // Set as active watermark
    activeWatermarkIndex = uploadedWatermarks.length - 1;
    watermarkImageData = imageData;
    
    // Update UI
    updateWatermarkFilesList();
    
    const overlay = document.getElementById('watermarkOverlay');
    overlay.src = watermarkImageData;
    overlay.classList.remove('hidden');
    updateWatermarkPreview();
    
    showToast(`✓ Watermark added: ${file.name}`);
    
    // Reset file input
    event.target.value = '';
  };
  reader.readAsDataURL(file);
}

function updateWatermarkFilesList() {
  const list = document.getElementById('watermarkFilesList');
  const counter = document.getElementById('watermarkCount');
  const bulkActions = document.getElementById('watermarkBulkActions');
  
  // Update counter
  if (counter) {
    counter.textContent = `${uploadedWatermarks.length} file${uploadedWatermarks.length !== 1 ? 's' : ''}`;
  }
  
  // Show/hide bulk actions
  if (bulkActions) {
    if (uploadedWatermarks.length > 0) {
      bulkActions.classList.remove('hidden');
    } else {
      bulkActions.classList.add('hidden');
    }
  }
  
  if (uploadedWatermarks.length === 0) {
    list.innerHTML = `
      <div class="text-xs text-gray-400 text-center py-4">
        <i class="ti ti-photo-off text-2xl mb-2 block"></i>
        No watermarks uploaded yet
      </div>
    `;
    return;
  }
  
  list.innerHTML = uploadedWatermarks.map((file, idx) => `
    <div class="flex items-center justify-between p-2 bg-dark-700 rounded border ${idx === activeWatermarkIndex ? 'border-primary' : 'border-gray-600'} hover:border-primary/50 transition-colors">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <div class="w-10 h-10 rounded bg-gray-900 flex-shrink-0 overflow-hidden border border-gray-600">
          <img src="${file.data}" class="w-full h-full object-contain" alt="${file.name}">
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-xs font-medium text-white truncate" title="${file.name}">${file.name}</div>
          <div class="text-xs text-gray-400">
            ${(file.size / 1024).toFixed(1)} KB • ${file.type.split('/')[1].toUpperCase()}
          </div>
        </div>
      </div>
      <div class="flex items-center gap-1">
        ${idx === activeWatermarkIndex 
          ? '<span class="text-xs text-primary px-2 py-1 bg-primary/20 rounded font-medium flex items-center gap-1"><i class="ti ti-check text-sm"></i>Active</span>'
          : `<button onclick="selectWatermark(${idx})" class="text-primary hover:text-primary/80 hover:bg-primary/10 px-2 py-1 rounded text-xs transition-colors" title="Use this watermark">
              <i class="ti ti-check"></i>
            </button>`
        }
        <button onclick="removeWatermark(${idx})" class="text-red-400 hover:text-red-300 hover:bg-red-500/10 p-1 rounded transition-colors" title="Delete watermark">
          <i class="ti ti-trash text-sm"></i>
        </button>
      </div>
    </div>
  `).join('');
}

function selectWatermark(index) {
  if (index < 0 || index >= uploadedWatermarks.length) return;
  
  activeWatermarkIndex = index;
  watermarkImageData = uploadedWatermarks[index].data;
  
  const overlay = document.getElementById('watermarkOverlay');
  overlay.src = watermarkImageData;
  overlay.classList.remove('hidden');
  
  updateWatermarkFilesList();
  updateWatermarkPreview();
  updateRealtimePreview();
  
  showToast(`✓ Using: ${uploadedWatermarks[index].name}`);
}

function removeWatermark(index) {
  if (!confirm('Delete this watermark?')) return;
  
  const removedName = uploadedWatermarks[index].name;
  uploadedWatermarks.splice(index, 1);
  
  // Update active index
  if (activeWatermarkIndex === index) {
    // If active watermark was deleted
    if (uploadedWatermarks.length > 0) {
      // Select the first available watermark
      activeWatermarkIndex = 0;
      watermarkImageData = uploadedWatermarks[0].data;
      
      const overlay = document.getElementById('watermarkOverlay');
      overlay.src = watermarkImageData;
      overlay.classList.remove('hidden');
    } else {
      // No watermarks left
      activeWatermarkIndex = null;
      watermarkImageData = null;
      
      const overlay = document.getElementById('watermarkOverlay');
      overlay.classList.add('hidden');
    }
  } else if (activeWatermarkIndex > index) {
    // Adjust active index if needed
    activeWatermarkIndex--;
  }
  
  updateWatermarkFilesList();
  updateWatermarkPreview();
  
  showToast(`✗ Deleted: ${removedName}`);
}

function clearAllWatermarks() {
  if (uploadedWatermarks.length === 0) return;
  
  if (!confirm(`Delete all ${uploadedWatermarks.length} watermark(s)?`)) return;
  
  const count = uploadedWatermarks.length;
  
  // Clear all watermarks
  uploadedWatermarks = [];
  activeWatermarkIndex = null;
  watermarkImageData = null;
  
  // Hide overlay
  const overlay = document.getElementById('watermarkOverlay');
  overlay.classList.add('hidden');
  
  // Update UI
  updateWatermarkFilesList();
  updateWatermarkPreview();
  
  showToast(`✗ Cleared ${count} watermark(s)`);
}

function updateWatermarkPreview() {
  const position = document.getElementById('watermarkPosition')?.value || 'bottom-right';
  const opacity = document.getElementById('watermarkOpacity')?.value || 70;
  const overlay = document.getElementById('watermarkOverlay');
  const opacityValue = document.getElementById('opacityValue');
  
  if (opacityValue) opacityValue.textContent = opacity + '%';
  
  if (overlay && !overlay.classList.contains('hidden')) {
    // Remove all position classes
    overlay.className = 'watermark-overlay';
    // Add new position class
    overlay.classList.add(position);
    overlay.style.opacity = opacity / 100;
  }
  
  // Update realtime preview
  updateRealtimePreview();
}

// FEATURE 4: BATCH RENDER QUEUE
let batchQueue = [];

function addToBatchQueue() {
  const titleV = el.title.value;
  const h = parseInt(el.durationHours.value || 0, 10);
  const m = parseInt(el.durationMinutes.value || 0, 10);
  const videoIds = [...document.querySelectorAll("input[name='video']:checked")].map(i=>i.value);
  const audioIds = [...document.querySelectorAll("input[name='audio']:checked")].map(i=>i.value);
  
  if (videoIds.length === 0) {
    alert('Please select at least one video');
    return;
  }
  
  // Get visualizer settings
  const visualizerSettings = {
    type: visualizerType?.value || 'none',
    intensity: visualizerIntensity?.value || 50,
    sensitivity: visualizerSensitivity?.value || 1.0,
    smoothing: visualizerSmoothing?.value || 0.8,
    barCount: visualizerBarCount?.value || 64,
    color: visualizerColor?.value || 'purple',
    mirror: visualizerMirror?.checked || false,
    glow: visualizerGlow?.checked || false,
    customConfig: currentVisualizerConfig || null
  };
  
  // Get watermark settings
  const watermarkSettings = (activeWatermarkIndex !== null && uploadedWatermarks[activeWatermarkIndex]) ? {
    image: uploadedWatermarks[activeWatermarkIndex].data,
    fileName: uploadedWatermarks[activeWatermarkIndex].name,
    position: document.getElementById('watermarkPosition')?.value || 'bottom-right',
    opacity: document.getElementById('watermarkOpacity')?.value || 70
  } : null;
  
  const queueItem = {
    id: Date.now(),
    title: titleV || `Render ${batchQueue.length + 1}`,
    durationHours: h,
    durationMinutes: m,
    targetDurationSeconds: (h * 3600) + (m * 60),
    targetAccountId: el.targetAccountId.value,
    autoUploadToYoutube: false,
    followAudioDuration: el.followAudioDuration.checked,
    muteVideoAudio: el.muteVideoAudio.checked,
    videoIds: videoIds,
    audioIds: audioIds,
    visualizerSettings: visualizerSettings,
    watermark: watermarkSettings,
    overlayVideo: overlayVideoData ? {
      data: overlayVideoData,
      fileName: overlayVideoFile?.name || 'overlay.mp4',
      blendMode: document.getElementById('overlayBlendMode')?.value || 'normal',
      opacity: document.getElementById('overlayOpacity')?.value || 100
    } : null,
    status: 'pending'
  };
  
  batchQueue.push(queueItem);
  updateBatchQueueUI();
  showToast(`✓ Added "${queueItem.title}" to queue`);
}

function updateBatchQueueUI() {
  const batchCountTab = document.getElementById('batchCountTab');
  const batchQueueList = document.getElementById('batchQueueList');
  
  if (batchCountTab) batchCountTab.textContent = batchQueue.length;
  
  if (batchQueue.length === 0) {
    batchQueueList.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No items in queue</div>';
    return;
  }
  
  batchQueueList.innerHTML = batchQueue.map((item, idx) => {
    const hasWatermark = item.watermark ? '💧' : '';
    const hasOverlay = item.overlayVideo ? '🎬' : '';
    const hasVisualizer = item.visualizerSettings?.type !== 'none' ? '🎵' : '';
    const hasAdvancedAudio = item.advancedAudio?.normalize || item.advancedAudio?.dualLayer?.enabled ? '🎚️' : '';
    const features = [hasWatermark, hasOverlay, hasVisualizer, hasAdvancedAudio].filter(f => f).join(' ');
    
    return `
    <div class="batch-queue-item bg-dark-700 p-3 rounded-lg border border-gray-600 ${item.status === 'processing' ? 'processing' : ''}">
      <div class="flex items-start justify-between mb-2">
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-white truncate">${item.title}</div>
          <div class="text-xs text-gray-400 mt-1">
            ${item.videoIds.length} video${item.videoIds.length > 1 ? 's' : ''} • 
            ${item.audioIds?.length || 0} audio${(item.audioIds?.length || 0) !== 1 ? 's' : ''} • 
            ${item.durationHours}h ${item.durationMinutes}m
          </div>
          ${features ? `<div class="text-xs text-primary mt-1">Features: ${features}</div>` : ''}
        </div>
        <div class="flex items-center gap-1">
          ${item.status === 'processing' ? '<i class="ti ti-loader animate-spin text-green-400"></i>' : ''}
          <button onclick="removeBatchItem(${idx})" class="text-red-400 hover:text-red-300 p-1 rounded hover:bg-red-500/10 transition-colors" title="Remove from queue">
            <i class="ti ti-x text-sm"></i>
          </button>
        </div>
      </div>
      
      <!-- Feature Details -->
      ${item.watermark || item.overlayVideo || item.visualizerSettings?.type !== 'none' || item.advancedAudio ? `
        <div class="mt-2 pt-2 border-t border-gray-600 space-y-1">
          ${item.watermark ? `<div class="text-xs text-gray-400"><i class="ti ti-droplet text-blue-400"></i> Watermark: ${item.watermark.position}</div>` : ''}
          ${item.overlayVideo ? `<div class="text-xs text-gray-400"><i class="ti ti-layers-intersect text-purple-400"></i> Overlay: ${item.overlayVideo.fileName}</div>` : ''}
          ${item.visualizerSettings?.type !== 'none' ? `<div class="text-xs text-gray-400"><i class="ti ti-waveform text-primary"></i> Visualizer: ${item.visualizerSettings.type}</div>` : ''}
          ${item.advancedAudio?.normalize ? `<div class="text-xs text-gray-400"><i class="ti ti-adjustments text-green-400"></i> Audio: Normalized</div>` : ''}
          ${item.advancedAudio?.dualLayer?.enabled ? `<div class="text-xs text-gray-400"><i class="ti ti-layers-linked text-yellow-400"></i> Dual Audio Layer</div>` : ''}
        </div>
      ` : ''}
    </div>
  `;
  }).join('');
}

function removeBatchItem(index) {
  batchQueue.splice(index, 1);
  updateBatchQueueUI();
}

function clearBatchQueue() {
  if (!confirm('Clear all items from queue?')) return;
  batchQueue = [];
  updateBatchQueueUI();
}

async function processBatchQueue() {
  if (batchQueue.length === 0) {
    alert('Queue is empty');
    return;
  }
  
  if (!confirm(`Process ${batchQueue.length} render job(s)?`)) return;
  
  showToast(`🚀 Processing ${batchQueue.length} jobs...`);
  
  let successCount = 0;
  let failCount = 0;
  
  for (let i = 0; i < batchQueue.length; i++) {
    const item = batchQueue[i];
    item.status = 'processing';
    updateBatchQueueUI();
    
    try {
      const resp = await fetch('/api/render/jobs', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(item)
      });
      
      const data = await resp.json();
      
      if (resp.ok && data.success) {
        successCount++;
        showToast(`✓ ${item.title} queued (${i + 1}/${batchQueue.length})`);
      } else {
        failCount++;
        showToast(`✗ ${item.title} failed: ${data.message}`);
      }
    } catch (err) {
      console.error('Batch render error:', err);
      failCount++;
      showToast(`✗ ${item.title} error`);
    }
    
    // Small delay between jobs
    await new Promise(resolve => setTimeout(resolve, 500));
  }
  
  // Clear queue after processing
  batchQueue = [];
  updateBatchQueueUI();
  loadJobs();
  startSmartRefresh(); // Start auto-refresh for batch jobs
  
  // Show summary notification
  const summary = `Batch Complete: ${successCount} success, ${failCount} failed`;
  showNotification('Batch Processing Complete', summary);
  showToast(`🎉 ${summary}`);
}

// FEATURE 5: ENHANCED REAL-TIME PROGRESS (already implemented, adding circular progress)
function createProgressRing(progress) {
  const radius = 18;
  const circumference = 2 * Math.PI * radius;
  const offset = circumference - (progress / 100) * circumference;
  
  return `
    <svg class="progress-ring" width="40" height="40">
      <circle class="text-gray-600" stroke-width="3" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
      <circle class="progress-ring-circle text-primary" stroke-width="3" stroke-dasharray="${circumference}" stroke-dashoffset="${offset}" stroke-linecap="round" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
    </svg>
  `;
}

// Initialize
Promise.resolve()
  .then(loadAccounts)
  .then(loadMedia)
  .then(loadJobs)
  .then(requestNotificationPermission)
  .catch((err) => console.error('Render dashboard init error:', err));

// Smart auto-refresh: only refresh when there are active jobs AND no video is playing
let refreshInterval = null;

function isAnyVideoPlaying() {
  const videos = document.querySelectorAll('video[data-video-id]');
  for (const video of videos) {
    if (!video.paused) {
      return true;
    }
  }
  return false;
}

function startSmartRefresh() {
  // Clear existing interval
  if (refreshInterval) {
    clearInterval(refreshInterval);
    refreshInterval = null;
  }
  
  // Only start interval if there are active jobs
  refreshInterval = setInterval(async () => {
    try {
      // CRITICAL: Don't refresh if any video is playing
      if (isAnyVideoPlaying()) {
        console.log('[Auto-Refresh] Skipped - video is playing');
        return;
      }
      
      const r = await fetch('/api/render/jobs');
      const d = await r.json();
      const jobs = toArray(d, 'jobs');
      
      // Check if there are any active jobs
      const hasActiveJobs = jobs.some(j => j.status === 'processing' || j.status === 'queued' || j.status === 'pending');
      
      if (hasActiveJobs) {
        // Only update jobs list, don't reload everything
        await loadJobs();
        await checkJobCompletion();
      } else {
        // No active jobs, stop auto-refresh
        clearInterval(refreshInterval);
        refreshInterval = null;
      }
    } catch (err) {
      console.error('Smart refresh error:', err);
    }
  }, 3000); // Poll every 3 seconds for responsive progress
}

// Start smart refresh
startSmartRefresh();

