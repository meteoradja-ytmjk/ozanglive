function shuffleMedia() {
  const container = currentMediaTab === 'video' 
    ? document.getElementById('videoList')
    : document.getElementById('audioList');
  
  if (!container) return;
  
  // Get all details (groups)
  const allDetails = Array.from(container.querySelectorAll('details'));
  
  allDetails.forEach(detail => {
    const itemsContainer = detail.querySelector('div.border-t');
    if (!itemsContainer) return;
    
    // Get all items in this group
    const allItems = Array.from(itemsContainer.querySelectorAll('.media-item'));
    
    if (allItems.length === 0) return;
    
    // Separate pinned and unpinned
    const pinnedItems = allItems.filter(item => item.dataset.pinned === 'true');
    const unpinnedItems = allItems.filter(item => item.dataset.pinned === 'false');
    
    // Shuffle unpinned items using Fisher-Yates
    for (let i = unpinnedItems.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [unpinnedItems[i], unpinnedItems[j]] = [unpinnedItems[j], unpinnedItems[i]];
    }
    
    // Clear container
    itemsContainer.innerHTML = '';
    
    // Append pinned first, then shuffled unpinned
    [...pinnedItems, ...unpinnedItems].forEach(item => {
      itemsContainer.appendChild(item);
    });
  });
  
  const pinnedCount = container.querySelectorAll('.media-item[data-pinned="true"]').length;
  const totalCount = container.querySelectorAll('.media-item').length;
  
  showToast(`🔀 Shuffled! ${pinnedCount} pinned items stayed on top`);
}

function togglePin(event, id, type) {
  event.preventDefault();
  event.stopPropagation();
  
  const item = event.target.closest('.media-item');
  if (!item) return;
  
  const isPinned = item.dataset.pinned === 'true';
  const newPinnedState = !isPinned;
  
  item.dataset.pinned = newPinnedState;
  
  const pinBtn = item.querySelector('.pin-btn');
  if (pinBtn) {
    if (newPinnedState) {
      pinBtn.textContent = '📌';
      pinBtn.style.background = 'rgba(234, 179, 8, 0.2)';
      item.style.background = 'rgba(234, 179, 8, 0.1)';
    } else {
      pinBtn.textContent = '📍';
      pinBtn.style.background = '';
      item.style.background = '';
    }
  }
  
  // Move pinned items to top
  const container = type === 'video' 
    ? document.getElementById('videoList')
    : document.getElementById('audioList');
  
  if (!container) return;
  
  const detail = item.closest('details');
  if (!detail) return;
  
  const itemsContainer = detail.querySelector('div.border-t');
  if (!itemsContainer) return;
  
  const allItems = Array.from(itemsContainer.querySelectorAll('.media-item'));
  const pinnedItems = allItems.filter(i => i.dataset.pinned === 'true');
  const unpinnedItems = allItems.filter(i => i.dataset.pinned === 'false');
  
  // Rebuild: pinned first, then unpinned
  itemsContainer.innerHTML = '';
  [...pinnedItems, ...unpinnedItems].forEach(i => itemsContainer.appendChild(i));
  
  showToast(newPinnedState ? '📌 Pinned to top' : '📍 Unpinned');
}

