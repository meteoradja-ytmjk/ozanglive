<% layout('layout') -%>

<style>
/* Step-by-Step Flow Styling - ULTRA CLEAN */
.step-section {
  padding: 0.75rem 0;
  margin-bottom: 0.5rem;
  transition: all 0.2s ease;
}

.step-section:hover {
  background: rgba(139, 92, 246, 0.03);
}

.step-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

.step-number {
  width: 1.75rem;
  height: 1.75rem;
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  border-radius: 0.375rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.step-title h4 {
  font-size: 0.875rem;
  font-weight: 600;
  color: white;
  margin: 0;
  line-height: 1.2;
}

.step-title p {
  font-size: 0.7rem;
  color: #9CA3AF;
  margin: 0.125rem 0 0 0;
  line-height: 1.2;
}

.step-content {
  padding-left: 2.5rem;
}

@media (max-width: 768px) {
  .step-section {
    padding: 0.5rem 0;
    margin-bottom: 0.5rem;
  }
  
  .step-header {
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  
  .step-number {
    width: 1.5rem;
    height: 1.5rem;
    font-size: 0.75rem;
  }
  
  .step-title h4 {
    font-size: 0.8rem;
  }
  
  .step-title p {
    font-size: 0.65rem;
  }
  
  .step-content {
    padding-left: 0;
    margin-top: 0.5rem;
  }
}

/* Progress animations */
.modal-backdrop {
  backdrop-filter: blur(4px);
}

/* Progress animations */
@keyframes progressPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.progress-active {
  animation: progressPulse 2s ease-in-out infinite;
}

/* Duration Settings - Enhanced Styling */
.step-content input[type="number"]::-webkit-inner-spin-button,
.step-content input[type="number"]::-webkit-outer-spin-button {
  opacity: 1;
  height: 30px;
}

.step-content input[type="number"]:hover::-webkit-inner-spin-button,
.step-content input[type="number"]:hover::-webkit-outer-spin-button {
  opacity: 1;
}

/* Audio Options Card Hover Effect */
.step-content .bg-dark-800.rounded-lg.p-3 {
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.step-content .bg-dark-800.rounded-lg.p-3::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.1), transparent);
  transition: left 0.5s ease;
}

.step-content .bg-dark-800.rounded-lg.p-3:hover::before {
  left: 100%;
}

.step-content .bg-dark-800.rounded-lg.p-3:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(139, 92, 246, 0.2);
}

/* Checkbox Animation */
.step-content input[type="checkbox"] {
  transition: all 0.2s ease;
}

.step-content input[type="checkbox"]:checked {
  transform: scale(1.1);
}

/* Info Message Animation */
@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

#durationInfo:not(.hidden),
#muteVideoInfo:not(.hidden) {
  animation: slideDown 0.3s ease-out;
}

/* Duration Input Focus Effect */
.step-content input[type="number"]:focus {
  transform: scale(1.02);
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

/* Notification permission badge */
.notification-badge {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 9999;
  animation: slideInRight 0.3s ease;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* Filter chips */
.filter-chip {
  transition: all 0.2s ease;
}

.filter-chip:hover {
  transform: translateY(-1px);
}

.filter-chip.active {
  background: #8B5CF6;
  color: white;
  border-color: #8B5CF6;
}

/* Mini Live Preview */
.mini-preview {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
}

.mini-preview video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mini-preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #6B7280;
}

/* Watermark Preview */
.watermark-preview {
  position: relative;
  width: 100%;
  height: 120px;
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
  border-radius: 0.5rem;
  overflow: hidden;
  border: 1px solid #374151;
}

.watermark-overlay {
  position: absolute;
  pointer-events: none;
  max-width: 30%;
  max-height: 30%;
  opacity: 0.7;
}

.watermark-overlay.top-left { top: 10px; left: 10px; }
.watermark-overlay.top-right { top: 10px; right: 10px; }
.watermark-overlay.bottom-left { bottom: 10px; left: 10px; }
.watermark-overlay.bottom-right { bottom: 10px; right: 10px; }
.watermark-overlay.center { top: 50%; left: 50%; transform: translate(-50%, -50%); }

/* Advanced Visualizer Preview */
.visualizer-preview {
  width: 100%;
  height: 60px;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
  position: relative;
}

.visualizer-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding: 5px;
  gap: 2px;
}

.visualizer-bar {
  flex: 1;
  background: linear-gradient(to top, #8B5CF6, #EC4899);
  border-radius: 2px;
  animation: visualizerPulse 1s ease-in-out infinite;
}

@keyframes visualizerPulse {
  0%, 100% { height: 20%; }
  50% { height: 80%; }
}

.visualizer-bar:nth-child(2n) { animation-delay: 0.1s; }
.visualizer-bar:nth-child(3n) { animation-delay: 0.2s; }
.visualizer-bar:nth-child(4n) { animation-delay: 0.3s; }

/* Batch Render Queue */
.batch-queue-item {
  transition: all 0.2s ease;
}

.batch-queue-item:hover {
  background: rgba(139, 92, 246, 0.1);
  border-color: #8B5CF6;
}

/* Floating Preview */
#vizLivePreview.floating-preview {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 360px;
  height: 203px;
  z-index: 9999;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(139,92,246,0.3);
  aspect-ratio: auto;
  transition: all 0.3s ease;
}

#vizLivePreview.floating-preview:hover {
  box-shadow: 0 10px 40px rgba(0,0,0,0.8), 0 0 0 1px rgba(139,92,246,0.5);
  transform: scale(1.02);
}

#vizLivePreview.floating-preview #vizAudioControls {
  opacity: 0;
  transition: opacity 0.2s ease;
}

#vizLivePreview.floating-preview:hover #vizAudioControls {
  opacity: 1;
}

@media (max-width: 640px) {
  #vizLivePreview.floating-preview {
    width: 90%;
    height: auto;
    aspect-ratio: 16/9;
    bottom: auto;
    top: 10px;
    right: 5%;
    left: 5%;
  }
}

.batch-queue-item.processing {
  border-color: #10B981;
  background: rgba(16, 185, 129, 0.05);
}

/* Real-time Progress Ring */
.progress-ring {
  transform: rotate(-90deg);
}

.progress-ring-circle {
  transition: stroke-dashoffset 0.3s ease;
}

/* Collapsible sections */
.collapsible-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.collapsible-content.open {
  max-height: 2000px;
}

/* Upload Widget Animations */
@keyframes slideInUp {
  from {
    transform: translateY(100px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.3;
  }
  100% {
    transform: scale(1.2);
    opacity: 0;
  }
}

#uploadWidget {
  animation: slideInUp 0.3s ease-out;
}

#uploadWidgetMinimized .animate-ping {
  animation: pulse-ring 2s cubic-bezier(0, 0, 0.2, 1) infinite;
}

#uploadWidgetExpanded {
  animation: slideInUp 0.2s ease-out;
}

/* Search Box Styling */
#videoSearchInput:focus,
#audioSearchInput:focus {
  border-color: #8B5CF6;
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

.no-results-message {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Visualizer Type Buttons */
.viz-type-btn {
  padding: 0.5rem 0.25rem;
  border-radius: 0.5rem;
  border: 2px solid transparent;
  background: rgba(31, 41, 55, 0.8);
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
  font-size: 1rem;
  line-height: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 3rem;
}
.viz-type-btn:hover {
  border-color: rgba(139, 92, 246, 0.5);
  transform: translateY(-1px);
  background: rgba(139, 92, 246, 0.08);
}
.viz-type-btn.active {
  border-color: #8B5CF6;
  background: rgba(139, 92, 246, 0.15);
  box-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
}

/* Visualizer Color Buttons */
.viz-color-btn {
  width: 1.5rem;
  height: 1.5rem;
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.2s;
}
.viz-color-btn:hover {
  transform: scale(1.2);
}
.viz-color-btn.active {
  border-color: #fff;
  box-shadow: 0 0 8px rgba(255,255,255,0.4);
  transform: scale(1.15);
}

/* Visualizer Position Buttons */
.viz-pos-btn.active {
  border-color: #8B5CF6 !important;
  background: rgba(139, 92, 246, 0.1) !important;
  color: #8B5CF6 !important;
}

/* Enhanced Render Progress */
.render-progress-card {
  background: linear-gradient(135deg, rgba(17, 24, 39, 0.95), rgba(31, 41, 55, 0.9));
  border: 1px solid rgba(75, 85, 99, 0.5);
  border-radius: 0.75rem;
  padding: 1rem;
  transition: all 0.3s;
}
.render-progress-card.active {
  border-color: rgba(139, 92, 246, 0.4);
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.1);
}

@keyframes renderPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4); }
  50% { box-shadow: 0 0 0 6px rgba(139, 92, 246, 0); }
}
.render-active-dot {
  animation: renderPulse 2s ease-in-out infinite;
}
</style>
</style>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold">Render Dashboard</h2>
    <p class="text-gray-400 text-sm mt-1">Pilih channel, jam, menit, video, dan audio untuk proses render</p>
  </div>
</div>

<!-- Tab Navigation -->
<div class="flex w-full border border-gray-600 rounded-lg mb-6 overflow-hidden bg-gray-800/50">
  <button onclick="switchRenderTab('jobs')" id="jobsTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center bg-primary/20 text-primary border-b-2 border-primary">
    <i class="ti ti-player-play mr-2"></i>Active Jobs
  </button>
  <div class="w-px bg-gray-600"></div>
  <button onclick="switchRenderTab('lyrics')" id="lyricsTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center text-gray-400 hover:text-white hover:bg-gray-700/50 flex items-center justify-center">
    <i class="ti ti-music mr-2"></i>Lyrics / Karaoke
  </button>
</div>

<!-- Lyrics/Karaoke Tab Content -->
<div id="lyricsContainer" class="tab-content hidden">
  <div class="bg-gray-800 rounded-xl p-6 md:p-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/20 mb-4">
        <i class="ti ti-microphone-2 text-4xl text-primary"></i>
      </div>
      <h3 class="text-2xl font-bold text-white mb-2">Lyrics / Karaoke</h3>
      <p class="text-gray-400 max-w-md mx-auto">Tambahkan lirik sinkron ke video render kamu untuk membuat konten karaoke yang menarik</p>
    </div>

    <!-- Feature Preview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="bg-gray-700/50 rounded-xl p-5 border border-gray-600/50">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center">
            <i class="ti ti-file-text text-xl text-blue-400"></i>
          </div>
          <h4 class="font-semibold text-white">Import Lirik</h4>
        </div>
        <p class="text-sm text-gray-400">Upload file .lrc, .srt, atau ketik manual lirik dengan timestamp</p>
      </div>

      <div class="bg-gray-700/50 rounded-xl p-5 border border-gray-600/50">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center">
            <i class="ti ti-palette text-xl text-purple-400"></i>
          </div>
          <h4 class="font-semibold text-white">Style Karaoke</h4>
        </div>
        <p class="text-sm text-gray-400">Pilih font, warna, animasi highlight, dan posisi teks di video</p>
      </div>

      <div class="bg-gray-700/50 rounded-xl p-5 border border-gray-600/50">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-lg bg-green-500/20 flex items-center justify-center">
            <i class="ti ti-player-play text-xl text-green-400"></i>
          </div>
          <h4 class="font-semibold text-white">Preview & Render</h4>
        </div>
        <p class="text-sm text-gray-400">Preview real-time sinkronisasi lirik sebelum render final</p>
      </div>
    </div>

    <!-- Coming Soon Badge -->
    <div class="text-center">
      <div class="inline-flex items-center gap-2 px-5 py-3 bg-yellow-500/10 border border-yellow-500/30 rounded-full">
        <i class="ti ti-clock text-yellow-400"></i>
        <span class="text-yellow-300 font-medium text-sm">Fitur ini sedang dalam pengembangan — Coming Soon</span>
      </div>
      <p class="text-gray-500 text-xs mt-3">Akan tersedia di update berikutnya</p>
    </div>
  </div>
</div>

<!-- Jobs Container (Active Tab) -->
<div id="jobsContainer" class="tab-content">

<!-- Main Form Card with Step-by-Step Flow -->
<div class="bg-gray-800 rounded-lg p-3 md:p-4 mb-4">
  <div class="flex items-center justify-between mb-3">
    <div>
      <h3 class="text-base md:text-lg font-bold text-white">Create Render Job</h3>
      <p class="text-xs text-gray-400 mt-0.5 hidden md:block">Follow the steps below</p>
    </div>
    <div class="hidden md:flex gap-2">
      <button onclick="openPreviewModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 rounded-lg text-xs font-medium transition-colors">
        <i class="ti ti-eye text-sm"></i>
        <span>Preview</span>
      </button>
    </div>
  </div>
  
  <div class="space-y-2 md:space-y-3">
    
    <!-- STEP 1: Basic Information -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">1</div>
        <div class="step-title">
          <h4>Basic Information</h4>
          <p>Title and target channel</p>
        </div>
      </div>
      <div class="step-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-text-size text-xs mr-1"></i>Video Title
            </label>
            <input type="text" id="title" value="1" placeholder="Enter video title" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
          </div>
          
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-brand-youtube text-xs mr-1"></i>Target Channel (Optional)
            </label>
            <select id="targetAccountId" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
              <option value="">-- Select Channel --</option>
            </select>
          </div>
        </div>
      </div>
    </div>
    
    <!-- STEP 2: Duration Settings -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">2</div>
        <div class="step-title">
          <h4>Duration Settings</h4>
          <p>Set video length and audio options</p>
        </div>
      </div>
      <div class="step-content">
        <!-- Grid 2 Columns Layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          <!-- Left Column: Duration Inputs -->
          <div class="space-y-3">
            <div class="flex items-center gap-2 mb-2">
              <i class="ti ti-clock text-primary"></i>
              <span class="text-sm font-semibold text-white">Video Duration</span>
            </div>
            
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-xs font-medium text-gray-400 block mb-2">
                  <i class="ti ti-clock-hour-4 text-xs mr-1"></i>Hours
                </label>
                <input type="number" id="durationHours" min="0" value="0" 
                  class="w-full bg-dark-700 text-white px-3 py-2.5 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary text-center font-bold border border-gray-600">
              </div>
              <div>
                <label class="text-xs font-medium text-gray-400 block mb-2">
                  <i class="ti ti-clock text-xs mr-1"></i>Minutes
                </label>
                <input type="number" id="durationMinutes" min="0" max="59" value="0" 
                  class="w-full bg-dark-700 text-white px-3 py-2.5 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary text-center font-bold border border-gray-600">
              </div>
            </div>
          </div>
          
          <!-- Right Column: Audio Options -->
          <div class="space-y-3">
            <div class="flex items-center gap-2 mb-2">
              <i class="ti ti-settings text-primary"></i>
              <span class="text-sm font-semibold text-white">Audio Options</span>
            </div>
            
            <div class="space-y-2">
              <!-- Follow Audio Duration -->
              <div class="bg-dark-700 rounded-lg p-3 border border-gray-600">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" id="followAudioDuration" 
                    class="w-5 h-5 rounded border-gray-500 text-primary focus:ring-2 focus:ring-primary cursor-pointer flex-shrink-0">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <i class="ti ti-music text-primary text-sm"></i>
                      <span class="text-sm font-medium text-white">Follow Audio Duration</span>
                    </div>
                    <p class="text-xs text-gray-400 mt-0.5">Auto-match total audio length</p>
                  </div>
                </label>
              </div>
              
              <!-- Mute Video Audio -->
              <div class="bg-dark-700 rounded-lg p-3 border border-gray-600">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" id="muteVideoAudio" 
                    class="w-5 h-5 rounded border-gray-500 text-red-500 focus:ring-2 focus:ring-red-500 cursor-pointer flex-shrink-0">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <i class="ti ti-volume-off text-red-400 text-sm"></i>
                      <span class="text-sm font-medium text-white">Mute Video Audio</span>
                    </div>
                    <p class="text-xs text-gray-400 mt-0.5">Remove original video audio</p>
                  </div>
                </label>
              </div>
            </div>
          </div>
          
        </div>
        
        <!-- Info Messages -->
        <div class="mt-3 space-y-2">
          <!-- Duration Info -->
          <div id="durationInfo" class="bg-primary/10 border border-primary/30 rounded-lg p-2.5 text-xs hidden">
            <div class="flex items-center gap-2 text-primary">
              <i class="ti ti-info-circle"></i>
              <span><strong>Follow Audio:</strong> Duration will match total audio length</span>
            </div>
          </div>
          
          <!-- Mute Video Info -->
          <div id="muteVideoInfo" class="bg-red-500/10 border border-red-500/30 rounded-lg p-2.5 text-xs hidden">
            <div class="flex items-center gap-2 text-red-400">
              <i class="ti ti-volume-off"></i>
              <span><strong>Mute Mode:</strong> Original video audio will be removed</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    
    <!-- STEP 3: Select Videos & Audio -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">3</div>
        <div class="step-title">
          <h4 class="text-base font-semibold text-white">Select Videos & Audio</h4>
          <p class="text-xs text-gray-400">Choose media files for your render</p>
        </div>
      </div>
      <div class="step-content">
        <!-- Video & Audio Selection Combined -->
        <div class="p-0">
          <!-- Tabs -->
          <div class="flex items-center justify-between mb-3">
            <div class="flex gap-1">
              <button onclick="switchMediaTab('video')" id="videoMediaTab" class="px-3 py-1.5 text-xs font-medium transition-colors rounded bg-primary/20 text-primary">
                <i class="ti ti-video text-sm mr-1"></i>Videos
                <span class="ml-1" id="videoSelectedCount">(0)</span>
              </button>
              <button onclick="switchMediaTab('audio')" id="audioMediaTab" class="px-3 py-1.5 text-xs font-medium transition-colors rounded text-gray-400 hover:text-white hover:bg-gray-700/50">
                <i class="ti ti-music text-sm mr-1"></i>Audio
