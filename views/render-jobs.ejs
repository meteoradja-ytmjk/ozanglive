function handleOverlayVideoUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  
  // Validate file type
  if (!file.type.includes('video/mp4')) {
    alert('Please upload MP4 video only');
    return;
  }
  
  // Validate file size (max 100MB)
  const maxSize = 100 * 1024 * 1024; // 100MB
  if (file.size > maxSize) {
    alert('File size too large. Maximum 100MB');
    return;
  }
  
  overlayVideoFile = file;
  
  // Read file as data URL for preview
  const reader = new FileReader();
  reader.onload = (e) => {
    overlayVideoData = e.target.result;
    
    // Update UI
    const fileName = document.getElementById('overlayFileName');
    const overlayOptions = document.getElementById('overlayOptions');
    
    if (fileName) {
      fileName.innerHTML = `<i class="ti ti-video mr-1"></i>${file.name}`;
