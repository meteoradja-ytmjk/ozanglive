<% layout('layout') -%>

<style>
/* Step-by-Step Flow Styling - ULTRA CLEAN */
.step-section {
  padding: 0.75rem 0;
  margin-bottom: 0.5rem;
  transition: all 0.2s ease;
}

.step-section:hover {
  background: rgba(139, 92, 246, 0.03);
}

.step-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

.step-number {
  width: 1.75rem;
  height: 1.75rem;
  background: linear-gradient(135deg, #8B5CF6, #EC4899);
  border-radius: 0.375rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.step-title h4 {
  font-size: 0.875rem;
  font-weight: 600;
  color: white;
  margin: 0;
  line-height: 1.2;
}

.step-title p {
  font-size: 0.7rem;
  color: #9CA3AF;
  margin: 0.125rem 0 0 0;
  line-height: 1.2;
}

.step-content {
  padding-left: 2.5rem;
}

@media (max-width: 768px) {
  .step-section {
    padding: 0.5rem 0;
    margin-bottom: 0.5rem;
  }
  
  .step-header {
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  
  .step-number {
    width: 1.5rem;
    height: 1.5rem;
    font-size: 0.75rem;
  }
  
  .step-title h4 {
    font-size: 0.8rem;
  }
  
  .step-title p {
    font-size: 0.65rem;
  }
  
  .step-content {
    padding-left: 0;
    margin-top: 0.5rem;
  }
}

/* Progress animations */
.modal-backdrop {
  backdrop-filter: blur(4px);
}

/* Progress animations */
@keyframes progressPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.progress-active {
  animation: progressPulse 2s ease-in-out infinite;
}

/* Notification permission badge */
.notification-badge {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 9999;
  animation: slideInRight 0.3s ease;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* Filter chips */
.filter-chip {
  transition: all 0.2s ease;
}

.filter-chip:hover {
  transform: translateY(-1px);
}

.filter-chip.active {
  background: #8B5CF6;
  color: white;
  border-color: #8B5CF6;
}

/* Mini Live Preview */
.mini-preview {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
}

.mini-preview video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mini-preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #6B7280;
}

/* Watermark Preview */
.watermark-preview {
  position: relative;
  width: 100%;
  height: 120px;
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
  border-radius: 0.5rem;
  overflow: hidden;
  border: 1px solid #374151;
}

.watermark-overlay {
  position: absolute;
  pointer-events: none;
  max-width: 30%;
  max-height: 30%;
  opacity: 0.7;
}

.watermark-overlay.top-left { top: 10px; left: 10px; }
.watermark-overlay.top-right { top: 10px; right: 10px; }
.watermark-overlay.bottom-left { bottom: 10px; left: 10px; }
.watermark-overlay.bottom-right { bottom: 10px; right: 10px; }
.watermark-overlay.center { top: 50%; left: 50%; transform: translate(-50%, -50%); }

/* Advanced Visualizer Preview */
.visualizer-preview {
  width: 100%;
  height: 60px;
  background: #000;
  border-radius: 0.5rem;
  overflow: hidden;
  position: relative;
}

.visualizer-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding: 5px;
  gap: 2px;
}

.visualizer-bar {
  flex: 1;
  background: linear-gradient(to top, #8B5CF6, #EC4899);
  border-radius: 2px;
  animation: visualizerPulse 1s ease-in-out infinite;
}

@keyframes visualizerPulse {
  0%, 100% { height: 20%; }
  50% { height: 80%; }
}

.visualizer-bar:nth-child(2n) { animation-delay: 0.1s; }
.visualizer-bar:nth-child(3n) { animation-delay: 0.2s; }
.visualizer-bar:nth-child(4n) { animation-delay: 0.3s; }

/* Batch Render Queue */
.batch-queue-item {
  transition: all 0.2s ease;
}

.batch-queue-item:hover {
  background: rgba(139, 92, 246, 0.1);
  border-color: #8B5CF6;
}

.batch-queue-item.processing {
  border-color: #10B981;
  background: rgba(16, 185, 129, 0.05);
}

/* Real-time Progress Ring */
.progress-ring {
  transform: rotate(-90deg);
}

.progress-ring-circle {
  transition: stroke-dashoffset 0.3s ease;
}

/* Collapsible sections */
.collapsible-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.collapsible-content.open {
  max-height: 2000px;
}
</style>
</style>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold">Render Dashboard</h2>
    <p class="text-gray-400 text-sm mt-1">Pilih channel, jam, menit, video, dan audio untuk proses render</p>
  </div>
</div>

<!-- Tab Navigation -->
<div class="flex w-full border border-gray-600 rounded-lg mb-6 overflow-hidden bg-gray-800/50">
  <button onclick="switchRenderTab('jobs')" id="jobsTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center bg-primary/20 text-primary border-b-2 border-primary">
    <i class="ti ti-video mr-2"></i>Active Jobs
  </button>
  <div class="w-px bg-gray-600"></div>
  <button onclick="switchRenderTab('history')" id="historyTab"
    class="flex-1 px-4 md:px-6 py-3 font-medium transition-colors text-center text-gray-400 hover:text-white hover:bg-gray-700/50">
    <i class="ti ti-history mr-2"></i>History
  </button>
</div>

<!-- Jobs Container (Active Tab) -->
<div id="jobsContainer" class="tab-content">

<!-- Main Form Card with Step-by-Step Flow -->
<div class="bg-gray-800 rounded-lg p-3 md:p-4 mb-4">
  <div class="flex items-center justify-between mb-3">
    <div>
      <h3 class="text-base md:text-lg font-bold text-white">Create Render Job</h3>
      <p class="text-xs text-gray-400 mt-0.5 hidden md:block">Follow the steps below</p>
    </div>
    <div class="hidden md:flex gap-2">
      <button onclick="openTemplateModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary/20 hover:bg-primary/30 text-primary rounded-lg text-xs font-medium transition-colors">
        <i class="ti ti-template text-sm"></i>
        <span>Templates</span>
      </button>
      <button onclick="openPreviewModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 rounded-lg text-xs font-medium transition-colors">
        <i class="ti ti-eye text-sm"></i>
        <span>Preview</span>
      </button>
    </div>
  </div>
  
  <div class="space-y-2 md:space-y-3">
    
    <!-- STEP 1: Basic Information -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">1</div>
        <div class="step-title">
          <h4>Basic Information</h4>
          <p>Title and target channel</p>
        </div>
      </div>
      <div class="step-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-text-size text-xs mr-1"></i>Video Title
            </label>
            <input type="text" id="title" value="1" placeholder="Enter video title" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
          </div>
          
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-brand-youtube text-xs mr-1"></i>Target Channel (Optional)
            </label>
            <select id="targetAccountId" class="w-full bg-dark-700 text-white px-3 py-2 border border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary">
              <option value="">-- Select Channel --</option>
            </select>
          </div>
        </div>
      </div>
    </div>
    
    <!-- STEP 2: Duration Settings -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">2</div>
        <div class="step-title">
          <h4>Duration Settings</h4>
          <p>Set video length</p>
        </div>
      </div>
      <div class="step-content">
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-clock-hour-4 text-xs mr-1"></i>Hours
            </label>
            <input type="number" id="durationHours" min="0" value="0" class="w-full bg-dark-700 text-white px-2 py-2 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary text-center font-semibold">
          </div>
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">
              <i class="ti ti-clock text-xs mr-1"></i>Minutes
            </label>
            <input type="number" id="durationMinutes" min="0" max="59" value="0" class="w-full bg-dark-700 text-white px-2 py-2 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary text-center font-semibold">
          </div>
          <div>
            <label class="text-xs font-medium text-gray-300 block mb-1.5">Follow</label>
            <div class="flex items-center justify-center bg-dark-700 px-2 py-2 rounded-lg h-[38px]">
              <input type="checkbox" id="followAudioDuration" class="w-4 h-4 rounded border-gray-500 bg-dark-700 text-primary focus:ring-primary">
              <label for="followAudioDuration" class="text-xs text-gray-300 cursor-pointer ml-1.5 hidden md:inline">Audio</label>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    
    <!-- STEP 3: Select Videos & Audio -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">3</div>
        <div class="step-title">
          <h4 class="text-base font-semibold text-white">Select Videos & Audio</h4>
          <p class="text-xs text-gray-400">Choose media files for your render</p>
        </div>
      </div>
      <div class="step-content">
        <!-- Video & Audio Selection Combined -->
        <div class="p-0">
          <!-- Tabs -->
          <div class="flex items-center justify-between mb-3">
            <div class="flex gap-1">
              <button onclick="switchMediaTab('video')" id="videoMediaTab" class="px-3 py-1.5 text-xs font-medium transition-colors rounded bg-primary/20 text-primary">
                <i class="ti ti-video text-sm mr-1"></i>Videos
                <span class="ml-1" id="videoSelectedCount">(0)</span>
              </button>
              <button onclick="switchMediaTab('audio')" id="audioMediaTab" class="px-3 py-1.5 text-xs font-medium transition-colors rounded text-gray-400 hover:text-white hover:bg-gray-700/50">
                <i class="ti ti-music text-sm mr-1"></i>Audio
                <span class="ml-1" id="audioSelectedCount">(0)</span>
              </button>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex gap-1">
              <button onclick="selectAllMedia()" class="text-xs px-2 py-1 bg-primary/20 hover:bg-primary/30 text-primary rounded transition-colors" title="Select All">
                <i class="ti ti-checkbox text-sm"></i>
              </button>
              <button onclick="deselectAllMedia()" class="text-xs px-2 py-1 bg-gray-700 hover:bg-gray-600 text-gray-300 rounded transition-colors" title="Deselect All">
                <i class="ti ti-square text-sm"></i>
              </button>
              <button onclick="shuffleMedia()" class="text-xs px-2 py-1 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded transition-colors" title="Shuffle">
                <i class="ti ti-arrows-shuffle text-sm"></i>
              </button>
            </div>
          </div>
          
          <!-- Video Content -->
          <div id="videoMediaContent">
            <div id="videoList" class="max-h-64 overflow-y-auto bg-gray-700/30 rounded-lg p-2">
              <div class="text-xs text-gray-400 text-center py-3">Loading...</div>
            </div>
          </div>
          
          <!-- Audio Content -->
          <div id="audioMediaContent" class="hidden">
            <div id="audioList" class="max-h-64 overflow-y-auto bg-gray-700/30 rounded-lg p-2">
              <div class="text-xs text-gray-400 text-center py-3">Loading...</div>
            </div>
            
            <!-- Advanced Audio Settings -->
            <div id="advancedAudioSettings" class="hidden mt-3 p-3 bg-violet-500/10 rounded-lg space-y-3">
              <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-violet-400">
                  <i class="ti ti-adjustments-horizontal mr-2"></i>Advanced Audio Settings
                </h4>
                <button type="button" onclick="resetAudioSettings()" class="text-xs text-gray-400 hover:text-white transition-colors">
                  <i class="ti ti-refresh text-xs"></i> Reset
                </button>
              </div>
              
              <!-- Fade In/Out -->
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-gray-400 mb-2">
                    <i class="ti ti-volume-3 text-xs"></i> Fade In (seconds)
                  </label>
                  <input type="number" id="audioFadeIn" min="0" max="10" step="0.5" value="0" 
                    class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:border-violet-500">
                </div>
                <div>
                  <label class="block text-xs text-gray-400 mb-2">
                    <i class="ti ti-volume text-xs"></i> Fade Out (seconds)
                  </label>
                  <input type="number" id="audioFadeOut" min="0" max="10" step="0.5" value="0" 
                    class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:border-violet-500">
                </div>
              </div>
              
              <!-- Volume Control -->
              <div>
                <label class="block text-xs text-gray-400 mb-2">
                  <i class="ti ti-volume-2 text-xs"></i> Volume: <span id="volumeValue" class="text-violet-400 font-semibold">100%</span>
                </label>
                <input type="range" id="audioVolume" min="0" max="200" value="100" 
                  class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-violet-500">
                <div class="flex justify-between text-xs text-gray-500 mt-1">
                  <span>0%</span>
                  <span>100%</span>
                  <span>200%</span>
                </div>
              </div>
              
              <!-- Crossfade -->
              <div>
                <label class="block text-xs text-gray-400 mb-2">
                  <i class="ti ti-arrows-shuffle text-xs"></i> Crossfade Between Tracks (seconds)
                </label>
                <input type="number" id="audioCrossfade" min="0" max="5" step="0.5" value="0" 
                  class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:border-violet-500">
                <p class="text-xs text-gray-500 mt-1">Smooth transition between audio tracks</p>
              </div>
              
              <!-- Normalization -->
              <div class="flex items-center justify-between p-3 bg-gray-700/50 rounded-lg">
                <div>
                  <label class="text-xs text-gray-300 font-medium">
                    <i class="ti ti-waveform text-xs"></i> Audio Normalization
                  </label>
                  <p class="text-xs text-gray-500 mt-1">Balance volume across all tracks</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="audioNormalize" class="sr-only peer">
                  <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-violet-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-violet-600"></div>
                </label>
              </div>
              
              <!-- Dual Layer Audio -->
              <div class="border-t border-gray-700 pt-4">
                <div class="flex items-center justify-between mb-3">
                  <label class="text-xs text-gray-300 font-medium">
                    <i class="ti ti-layers-linked text-xs"></i> Dual Audio Layer
                  </label>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="enableDualAudio" class="sr-only peer">
                    <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-violet-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-violet-600"></div>
                  </label>
                </div>
                
                <div id="dualAudioControls" class="hidden space-y-3">
                  <p class="text-xs text-gray-500">Mix background music with voiceover/narration</p>
                  
                  <div>
                    <label class="block text-xs text-gray-400 mb-2">Background Music Volume: <span id="bgVolumeValue" class="text-violet-400">30%</span></label>
                    <input type="range" id="bgMusicVolume" min="0" max="100" value="30" 
                      class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-violet-500">
                  </div>
                  
                  <div>
                    <label class="block text-xs text-gray-400 mb-2">Voiceover Volume: <span id="voiceVolumeValue" class="text-violet-400">100%</span></label>
                    <input type="range" id="voiceoverVolume" min="0" max="100" value="100" 
                      class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-violet-500">
                  </div>
                  
                  <div class="bg-gray-700/50 rounded-lg p-3">
                    <p class="text-xs text-gray-400 mb-2">
                      <i class="ti ti-info-circle text-xs"></i> How it works:
                    </p>
                    <ul class="text-xs text-gray-500 space-y-1 ml-4">
                      <li>• First audio = Background music (lower volume)</li>
                      <li>• Other audios = Voiceover/narration (full volume)</li>
                      <li>• Both layers mixed together</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- STEP 4: Advanced Options (Optional) -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">4</div>
        <div class="step-title">
          <h4>Advanced <span class="text-xs text-gray-500">(Optional)</span></h4>
          <p>Extra features</p>
        </div>
      </div>
      <div class="step-content">
        <div class="flex items-center gap-3">
          <!-- Auto Upload Toggle -->
          <div class="flex items-center gap-2">
            <i class="ti ti-upload text-primary text-sm"></i>
            <span class="text-xs text-white">Auto Upload</span>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="autoUploadToYoutube" class="sr-only peer">
              <div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:bg-primary transition-colors"></div>
              <div class="absolute left-[2px] top-[2px] w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-4"></div>
            </label>
          </div>
          
          <!-- Overlay Video -->
          <div class="flex items-center gap-2 flex-1">
            <i class="ti ti-layers-intersect text-blue-400 text-sm"></i>
            <input type="file" id="overlayVideoFile" accept="video/mp4" class="hidden" onchange="handleOverlayVideoUpload(event)">
            <button onclick="document.getElementById('overlayVideoFile').click()" class="flex-1 bg-gray-700 hover:bg-gray-600 text-gray-200 px-2 py-1.5 rounded transition-colors flex items-center justify-center gap-1.5 text-xs">
              <i class="ti ti-upload text-sm"></i>
              <span id="overlayFileName" class="truncate">Overlay</span>
            </button>
            
            <!-- Overlay Options -->
            <div id="overlayOptions" class="hidden">
              <button onclick="removeOverlayVideo()" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-2 py-1.5 rounded text-xs transition-colors">
                <i class="ti ti-x text-sm"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- STEP 5: Start Render -->
    <div class="step-section">
      <div class="step-header">
        <div class="step-number">5</div>
        <div class="step-title">
          <h4>Ready to Render!</h4>
          <p>Start your job</p>
        </div>
      </div>
      <div class="step-content">
        <div class="grid grid-cols-3 gap-2">
          <button id="createBtn" class="bg-gradient-to-r from-primary to-secondary hover:from-secondary hover:to-primary text-white px-2 py-2.5 md:px-4 md:py-3 rounded-lg font-semibold transition-all flex flex-col items-center justify-center gap-1 shadow-lg shadow-primary/30">
            <i class="ti ti-player-play text-base md:text-xl"></i>
            <span class="text-xs">Render</span>
          </button>
          <button onclick="saveAsTemplate()" class="bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 px-2 py-2.5 md:px-4 md:py-3 rounded-lg font-semibold transition-all flex flex-col items-center justify-center gap-1">
            <i class="ti ti-device-floppy text-base md:text-xl"></i>
            <span class="text-xs">Template</span>
          </button>
          <button id="resetBtn" class="bg-gray-700 hover:bg-gray-600 text-gray-300 px-2 py-2.5 md:px-4 md:py-3 rounded-lg font-semibold transition-all flex flex-col items-center justify-center gap-1">
            <i class="ti ti-eraser text-base md:text-xl"></i>
            <span class="text-xs">Reset</span>
          </button>
        </div>
      </div>
    </div>
    
  </div>
</div>

<!-- Advanced Features Grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
  
  <!-- Mini Live Preview -->
  <div class="bg-gray-800 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-white flex items-center gap-2">
        <i class="ti ti-eye text-primary"></i>
        Mini Live Preview
      </h3>
      <button onclick="refreshMiniPreview()" class="text-xs text-gray-400 hover:text-primary">
        <i class="ti ti-refresh"></i>
      </button>
    </div>
    <div class="mini-preview" id="miniPreview">
      <div class="mini-preview-placeholder">
        <i class="ti ti-video text-4xl mb-2"></i>
        <span class="text-xs">Select videos to preview</span>
      </div>
    </div>
    <div class="mt-2 text-xs text-gray-400 text-center" id="previewInfo">
      No preview available
