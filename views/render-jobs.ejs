}

function applyVizPreset(name) {
  const presets = {
    lofi: { type:'waveform', color:'ocean', intensity:35, sensitivity:0.8, barCount:32, smoothing:0.9, mirror:false, glow:true, roundBars:true, gradient:true, reflection:false },
    edm: { type:'spectrum', color:'neon', intensity:90, sensitivity:2.0, barCount:128, smoothing:0.5, mirror:true, glow:true, roundBars:false, gradient:true, reflection:true },
    cinematic: { type:'bars_center', color:'gold', intensity:60, sensitivity:1.2, barCount:48, smoothing:0.85, mirror:true, glow:true, roundBars:true, gradient:true, reflection:true },
    minimal: { type:'waveform', color:'white', intensity:30, sensitivity:1.0, barCount:24, smoothing:0.9, mirror:false, glow:false, roundBars:false, gradient:false, reflection:false },
    retro: { type:'spectrum', color:'fire', intensity:75, sensitivity:1.5, barCount:32, smoothing:0.6, mirror:false, glow:true, roundBars:false, gradient:true, reflection:false },
    ambient: { type:'nebula', color:'aurora', intensity:45, sensitivity:0.7, barCount:48, smoothing:0.95, mirror:false, glow:true, roundBars:false, gradient:true, reflection:false }
  };
  const p = presets[name];
  if (!p) return;

  // Update UI
  document.querySelectorAll('#vizTypeGrid .viz-type-btn').forEach(b => b.classList.toggle('active', b.dataset.type === p.type));
  document.querySelectorAll('#vizColorGrid .viz-color-btn').forEach(b => b.classList.toggle('active', b.dataset.color === p.color));
  document.getElementById('vizIntensity').value = p.intensity;
  document.getElementById('vizSensitivity').value = p.sensitivity * 10;
  document.getElementById('vizBarCount').value = p.barCount;
  document.getElementById('vizSmoothing').value = p.smoothing * 100;
  document.getElementById('vizIntensityVal').textContent = p.intensity + '%';
  document.getElementById('vizSensitivityVal').textContent = p.sensitivity.toFixed(1) + 'x';
  document.getElementById('vizBarCountVal').textContent = p.barCount;
  document.getElementById('vizSmoothingVal').textContent = p.smoothing.toFixed(2);
  document.getElementById('vizMirror').checked = p.mirror;
  document.getElementById('vizGlow').checked = p.glow;
  document.getElementById('vizRoundBars').checked = p.roundBars;
  document.getElementById('vizGradient').checked = p.gradient;
  document.getElementById('vizReflection').checked = p.reflection;

  // Apply to preview
  if (vizPreview) vizPreview.updateSettings(p);
}

function getVisualizerSettings() {
  if (!vizEnabled) return { type: 'none' };
  
  const activeType = document.querySelector('#vizTypeGrid .viz-type-btn.active');
  const activeColor = document.querySelector('#vizColorGrid .viz-color-btn.active');
  
  return {
    type: activeType?.dataset.type || 'spectrum',
    color: activeColor?.dataset.color || 'purple',
    intensity: parseInt(document.getElementById('vizIntensity').value),
    sensitivity: parseFloat(document.getElementById('vizSensitivity').value) / 10,
    barCount: parseInt(document.getElementById('vizBarCount').value),
    smoothing: parseFloat(document.getElementById('vizSmoothing').value) / 100,
    mirror: document.getElementById('vizMirror').checked,
    glow: document.getElementById('vizGlow').checked,
    roundBars: document.getElementById('vizRoundBars').checked,
    gradient: document.getElementById('vizGradient').checked,
    reflection: document.getElementById('vizReflection').checked,
    opacity: 0.85,
    position: vizPosition,
    height: vizHeightPercent,
    offsetX: vizOffsetX
  };
}

async function deleteJob(id){
  if(!confirm('Hapus project ini?'))return;
  const r=await fetch(`/api/render/jobs/${id}`,{method:'DELETE'});
  const d=await r.json();
  if(!d.success)return alert(d.message||'Gagal hapus');
  loadJobs();
}

async function loadJobs(){
  const r=await fetch('/api/render/jobs');
  const d=await r.json();
  const jobsArray = toArray(d,'jobs');
  const cards=jobsArray.map((j, index)=>{
    const jobNumber = jobsArray.length - index;
    const progress = Math.max(0,Math.min(100,Number(j.progress||0)));
    const isActive = j.status === 'processing' || j.status === 'pending' || j.status === 'queued';
    
    // Calculate ETA and speed
    let etaText = '';
    let speedText = '';
    let phaseText = '';
    if (isActive && progress > 0) {
      const elapsed = j.elapsed_seconds || 0;
      const remaining = elapsed > 0 ? (elapsed / progress) * (100 - progress) : 0;
      
      if (remaining > 0) {
        if (remaining > 3600) {
          const hrs = Math.floor(remaining / 3600);
          const mins = Math.floor((remaining % 3600) / 60);
          etaText = `~${hrs}h ${mins}m left`;
        } else if (remaining > 60) {
          const mins = Math.floor(remaining / 60);
          const secs = Math.floor(remaining % 60);
          etaText = `~${mins}m ${secs}s left`;
        } else {
          etaText = `~${Math.floor(remaining)}s left`;
        }
      }
      
      // Phase detection
      if (progress < 20) phaseText = 'Preparing...';
      else if (progress < 50) phaseText = 'Processing video...';
      else if (progress < 80) phaseText = 'Encoding...';
      else if (progress < 95) phaseText = 'Finalizing...';
      else phaseText = 'Almost done!';
    }
    
    // Status badge
    let statusBadge = '';
    switch(j.status) {
      case 'processing': statusBadge = '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-blue-500/20 text-blue-400"><span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-pulse"></span>Rendering</span>'; break;
      case 'queued': case 'pending': statusBadge = '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-yellow-500/20 text-yellow-400"><i class="ti ti-clock text-[10px]"></i>Queued</span>'; break;
      case 'completed': statusBadge = '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-green-500/20 text-green-400"><i class="ti ti-check text-[10px]"></i>Done</span>'; break;
      case 'failed': statusBadge = '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-red-500/20 text-red-400"><i class="ti ti-x text-[10px]"></i>Failed</span>'; break;
      default: statusBadge = `<span class="text-[10px] text-gray-400">${j.status}</span>`;
    }
    
    // Progress bar color
    const barColor = j.status === 'failed' ? 'bg-red-500' : j.status === 'completed' ? 'bg-green-500' : 'bg-primary';
    
    return `
    <div class="render-progress-card ${isActive ? 'active' : ''} mb-3" data-job-id="${j.id}">
      <div class="flex items-start justify-between mb-2">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-primary/20 text-primary text-[10px] font-bold flex-shrink-0">${jobNumber}</span>
            <h4 class="text-sm font-semibold text-white truncate">${j.title||'Untitled'}</h4>
            ${statusBadge}
          </div>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-gray-400">
            ${phaseText ? `<span class="text-primary font-medium">${phaseText}</span>` : ''}
            ${etaText ? `<span class="flex items-center gap-1"><i class="ti ti-hourglass-low"></i>${etaText}</span>` : ''}
            <span class="flex items-center gap-1"><i class="ti ti-clock"></i>${j.target_duration_seconds ? Math.round(j.target_duration_seconds/60)+'min' : '-'}</span>
          </div>
        </div>
        <!-- Circular progress -->
        <div class="relative flex-shrink-0 ml-3">
          <svg class="progress-ring" width="44" height="44">
            <circle class="text-gray-700" stroke-width="3.5" stroke="currentColor" fill="transparent" r="18" cx="22" cy="22"/>
            <circle class="text-primary progress-ring-circle" stroke-width="3.5" stroke-dasharray="${2*Math.PI*18}" stroke-dashoffset="${2*Math.PI*18 - (progress/100)*2*Math.PI*18}" stroke-linecap="round" stroke="currentColor" fill="transparent" r="18" cx="22" cy="22"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-[11px] font-bold text-white">${Math.round(progress)}%</span>
          </div>
        </div>
      </div>
      
      <!-- Progress bar -->
      <div class="w-full bg-gray-700 rounded-full h-1.5 mb-3 overflow-hidden">
        <div class="${barColor} h-1.5 rounded-full transition-all duration-500 ${isActive ? 'progress-active' : ''}" style="width:${progress}%"></div>
      </div>
      
      ${j.output_path ? `
        <video controls preload="metadata" src="${j.output_path}" class="w-full rounded-lg mb-3 bg-black max-h-48"></video>
      ` : ''}
      
      ${j.error_message ? `<div class="text-xs text-red-400 bg-red-500/10 rounded-lg p-2 mb-3"><i class="ti ti-alert-circle mr-1"></i>${j.error_message}</div>` : ''}
      
      <div class="flex gap-2">
        ${j.output_path ? `
