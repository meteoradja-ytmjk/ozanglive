}

// Generate visualizer bars dynamically
function generateVisualizerBars(count = 64) {
  const container = document.getElementById('visualizerBars');
  if (!container) return;
  
  container.innerHTML = '';
  
  for (let i = 0; i < count; i++) {
    const bar = document.createElement('div');
    bar.className = 'visualizer-bar';
    bar.style.animationDelay = `${(i * 0.05)}s`;
    container.appendChild(bar);
  }
  
  updateVisualizerPreview();
}

function updateVisualizerPreview() {
  const color = visualizerColor?.value || 'purple';
  const mirror = visualizerMirror?.checked || false;
  const glow = visualizerGlow?.checked || false;
  const bars = document.querySelectorAll('.visualizer-bar');
  
  const colorSchemes = {
    purple: 'linear-gradient(to top, #8B5CF6, #EC4899)',
    blue: 'linear-gradient(to top, #3B82F6, #06B6D4)',
    green: 'linear-gradient(to top, #10B981, #34D399)',
    rainbow: 'linear-gradient(to top, #EF4444, #F59E0B, #10B981, #3B82F6, #8B5CF6)',
    fire: 'linear-gradient(to top, #DC2626, #F59E0B, #FCD34D)',
    neon: 'linear-gradient(to top, #FF00FF, #00FFFF)',
    ocean: 'linear-gradient(to top, #0EA5E9, #06B6D4, #22D3EE)',
    sunset: 'linear-gradient(to top, #F97316, #FB923C, #FBBF24)'
  };
  
  bars.forEach((bar, index) => {
    bar.style.background = colorSchemes[color] || colorSchemes.purple;
    
    if (glow) {
      bar.style.boxShadow = '0 0 10px currentColor';
      bar.style.filter = 'brightness(1.2)';
    } else {
      bar.style.boxShadow = 'none';
      bar.style.filter = 'none';
    }
    
    // Mirror effect
    if (mirror) {
      const mirrorIndex = bars.length - 1 - index;
      bar.style.animationDelay = `${(Math.min(index, mirrorIndex) * 0.05)}s`;
    }
  });
}

// Save visualizer preset
function saveVisualizerPreset() {
  const presetName = prompt('Enter preset name:');
  if (!presetName) return;
  
  const preset = {
    name: presetName,
    type: visualizerType?.value || 'spectrum',
    intensity: visualizerIntensity?.value || 50,
    sensitivity: visualizerSensitivity?.value || 1.0,
    smoothing: visualizerSmoothing?.value || 0.8,
    barCount: visualizerBarCount?.value || 64,
    color: visualizerColor?.value || 'purple',
    mirror: visualizerMirror?.checked || false,
    glow: visualizerGlow?.checked || false,
    customFiles: uploadedSpectrumFiles.map(f => f.name),
    createdAt: new Date().toISOString()
  };
  
  const presets = JSON.parse(localStorage.getItem('visualizerPresets') || '[]');
  presets.push(preset);
  localStorage.setItem('visualizerPresets', JSON.stringify(presets));
  
  showToast(`✓ Preset "${presetName}" saved`);
}

// Load visualizer preset
function loadVisualizerPreset() {
  const presets = JSON.parse(localStorage.getItem('visualizerPresets') || '[]');
  
  if (presets.length === 0) {
    alert('No presets saved');
    return;
  }
  
  // Create simple selection dialog
  const presetNames = presets.map((p, i) => `${i + 1}. ${p.name}`).join('\n');
  const selection = prompt(`Select preset:\n\n${presetNames}\n\nEnter number:`);
  
  if (!selection) return;
  
  const index = parseInt(selection) - 1;
  const preset = presets[index];
  
  if (!preset) {
    alert('Invalid selection');
    return;
  }
  
  // Apply preset
  if (visualizerType) visualizerType.value = preset.type || 'spectrum';
  if (visualizerIntensity) {
    visualizerIntensity.value = preset.intensity || 50;
    intensityValue.textContent = preset.intensity + '%';
  }
  if (visualizerSensitivity) {
    visualizerSensitivity.value = preset.sensitivity || 1.0;
    sensitivityValue.textContent = preset.sensitivity + 'x';
  }
  if (visualizerSmoothing) {
    visualizerSmoothing.value = preset.smoothing || 0.8;
    smoothingValue.textContent = preset.smoothing;
  }
  if (visualizerBarCount) {
    visualizerBarCount.value = preset.barCount || 64;
    barCountValue.textContent = preset.barCount;
    generateVisualizerBars(preset.barCount);
  }
  if (visualizerColor) visualizerColor.value = preset.color || 'purple';
  if (visualizerMirror) visualizerMirror.checked = preset.mirror || false;
  if (visualizerGlow) visualizerGlow.checked = preset.glow || false;
  
  updateVisualizerType();
  updateVisualizerPreview();
  showToast(`✓ Loaded: ${preset.name}`);
}

// Initialize visualizer with default bars
generateVisualizerBars(64);

