// ===== SCHEDULE RENDER FUNCTIONS =====
let scheduleType = 'datetime'; // 'datetime' or 'delay'

function openScheduleModal() {
  // Validate form first
  const videoIds = [...document.querySelectorAll("input[name='video']:checked")].map(i => i.value);
  if (videoIds.length === 0) {
    alert('Please select at least 1 video before scheduling');
    return;
  }
  
  // Set default date and time (1 hour from now)
  const now = new Date();
  now.setHours(now.getHours() + 1);
  
  const dateStr = now.toISOString().split('T')[0];
  const timeStr = now.toTimeString().slice(0, 5);
  
  document.getElementById('scheduleDate').value = dateStr;
  document.getElementById('scheduleTime').value = timeStr;
  document.getElementById('scheduleDate').min = new Date().toISOString().split('T')[0];
  
  // Show modal
  document.getElementById('scheduleModal').classList.remove('hidden');
  updateSchedulePreview();
}

function closeScheduleModal() {
  document.getElementById('scheduleModal').classList.add('hidden');
}

function setScheduleType(type) {
  scheduleType = type;
  
  const dateTimeBtn = document.getElementById('scheduleTypeDateTime');
  const delayBtn = document.getElementById('scheduleTypeDelay');
  const dateTimeSection = document.getElementById('dateTimeSection');
  const delaySection = document.getElementById('delaySection');
  
  if (type === 'datetime') {
    dateTimeBtn.className = 'px-4 py-2.5 bg-purple-500/20 text-purple-400 rounded-lg font-medium transition-colors border border-purple-500/50';
    delayBtn.className = 'px-4 py-2.5 bg-gray-700 text-gray-300 rounded-lg font-medium transition-colors hover:bg-gray-600';
    dateTimeSection.classList.remove('hidden');
    delaySection.classList.add('hidden');
  } else {
    delayBtn.className = 'px-4 py-2.5 bg-purple-500/20 text-purple-400 rounded-lg font-medium transition-colors border border-purple-500/50';
    dateTimeBtn.className = 'px-4 py-2.5 bg-gray-700 text-gray-300 rounded-lg font-medium transition-colors hover:bg-gray-600';
    dateTimeSection.classList.add('hidden');
    delaySection.classList.remove('hidden');
  }
  
  updateSchedulePreview();
}

function updateSchedulePreview() {
  const preview = document.getElementById('schedulePreview');
  const previewText = document.getElementById('schedulePreviewText');
  
  let scheduledTime;
  
  if (scheduleType === 'datetime') {
    const date = document.getElementById('scheduleDate').value;
    const time = document.getElementById('scheduleTime').value;
    
    if (date && time) {
      scheduledTime = new Date(`${date}T${time}`);
    }
  } else {
    const hours = parseInt(document.getElementById('delayHours').value || 0);
    const minutes = parseInt(document.getElementById('delayMinutes').value || 0);
    const seconds = parseInt(document.getElementById('delaySeconds').value || 0);
    
    scheduledTime = new Date();
    scheduledTime.setHours(scheduledTime.getHours() + hours);
    scheduledTime.setMinutes(scheduledTime.getMinutes() + minutes);
    scheduledTime.setSeconds(scheduledTime.getSeconds() + seconds);
  }
  
  if (scheduledTime) {
    preview.classList.remove('hidden');
    previewText.textContent = scheduledTime.toLocaleString('id-ID', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  } else {
    preview.classList.add('hidden');
  }
}

async function confirmSchedule() {
  try {
    // Calculate scheduled time
    let scheduledTime;
    
    if (scheduleType === 'datetime') {
      const date = document.getElementById('scheduleDate').value;
      const time = document.getElementById('scheduleTime').value;
      
      if (!date || !time) {
        alert('Please select date and time');
        return;
      }
      
      scheduledTime = new Date(`${date}T${time}`);
    } else {
      const hours = parseInt(document.getElementById('delayHours').value || 0);
      const minutes = parseInt(document.getElementById('delayMinutes').value || 0);
      const seconds = parseInt(document.getElementById('delaySeconds').value || 0);
      
      if (hours === 0 && minutes === 0 && seconds === 0) {
        alert('Please set a delay duration');
        return;
      }
      
      scheduledTime = new Date();
      scheduledTime.setHours(scheduledTime.getHours() + hours);
      scheduledTime.setMinutes(scheduledTime.getMinutes() + minutes);
      scheduledTime.setSeconds(scheduledTime.getSeconds() + seconds);
    }
    
    // Check if scheduled time is in the past
    if (scheduledTime <= new Date()) {
      alert('Scheduled time must be in the future');
      return;
    }
    
    // Prepare render data
    const titleV = el.title.value;
    const h = parseInt(el.durationHours.value || 0, 10);
    const m = parseInt(el.durationMinutes.value || 0, 10);
    const targetDurationSeconds = (h * 3600) + (m * 60);
    const videoIds = [...document.querySelectorAll("input[name='video']:checked")].map(i => i.value);
    const audioIds = [...document.querySelectorAll("input[name='audio']:checked")].map(i => i.value);
    const followAudio = el.followAudioDuration.checked;
    
    // Validation
    if (videoIds.length === 0) {
      alert('Please select at least 1 video');
      return;
    }
    
    if (followAudio && audioIds.length === 0) {
      alert('Please select at least 1 audio when using "Follow Audio Duration"');
      return;
    }
    
    if (!followAudio && targetDurationSeconds === 0) {
      alert('Set duration to at least 1 minute or enable "Follow Audio Duration"');
      return;
    }
    
    const renderData = {
      title: titleV,
      targetDurationSeconds,
      durationHours: h,
      durationMinutes: m,
      targetAccountId: el.targetAccountId.value,
      autoUploadToYoutube: false,
      followAudioDuration: followAudio,
      muteVideoAudio: el.muteVideoAudio.checked,
      videoIds,
      audioIds,
      scheduledAt: scheduledTime.toISOString()
    };
    
    // Disable button
    const btn = document.getElementById('confirmScheduleBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader animate-spin mr-1"></i>Scheduling...';
    
    // Create scheduled job
    const resp = await fetch('/api/render/jobs/schedule', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(renderData)
    });
    
    const data = await resp.json();
    
    if (!resp.ok || !data.success) {
      throw new Error(data.message || 'Failed to schedule render');
    }
    
    showToast(`✓ Render scheduled for ${scheduledTime.toLocaleString('id-ID')}`);
    closeScheduleModal();
    loadJobs();
    
  } catch (error) {
    console.error('Schedule error:', error);
    alert(error.message || 'Failed to schedule render');
    
    // Re-enable button
    const btn = document.getElementById('confirmScheduleBtn');
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-clock-check mr-1"></i>Schedule';
  }
}

