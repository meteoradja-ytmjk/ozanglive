async function startUpload() {
  if (selectedFiles.length === 0) return;
  
  const progressSection = document.getElementById('uploadProgressSection');
  const progressBar = document.getElementById('uploadProgressBar');
  const progressText = document.getElementById('uploadProgressText');
  const statusText = document.getElementById('uploadStatusText');
  const startBtn = document.getElementById('startUploadBtn');
  
  // Show progress section
  progressSection.classList.remove('hidden');
  startBtn.disabled = true;
  startBtn.innerHTML = '<i class="ti ti-loader animate-spin mr-1"></i>Uploading...';
  
  let successCount = 0;
  let failCount = 0;
  let completedCount = 0;
  const totalFiles = selectedFiles.length;
  
  // Function to upload single file with progress tracking
  const uploadFile = (file, index) => {
    return new Promise((resolve, reject) => {
      const formData = new FormData();
      formData.append(uploadMediaType === 'video' ? 'video' : 'audio', file);
      
      const endpoint = uploadMediaType === 'video' ? '/api/videos/upload' : '/api/audios/upload';
      
      const xhr = new XMLHttpRequest();
      
      // Track upload progress
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) {
          const fileProgress = (e.loaded / e.total) * 100;
          const totalProgress = ((completedCount + (fileProgress / 100)) / totalFiles) * 100;
          progressBar.style.width = totalProgress.toFixed(0) + '%';
          progressText.textContent = totalProgress.toFixed(0) + '%';
          statusText.textContent = `Uploading ${index + 1}/${totalFiles}: ${file.name} (${fileProgress.toFixed(0)}%)`;
        }
      });
      
      xhr.addEventListener('load', () => {
        completedCount++;
        if (xhr.status >= 200 && xhr.status < 300) {
          try {
            const data = JSON.parse(xhr.responseText);
            if (data.success) {
              successCount++;
              resolve({ success: true, file: file.name });
            } else {
              failCount++;
              resolve({ success: false, file: file.name, error: data.message });
            }
          } catch (e) {
            failCount++;
            resolve({ success: false, file: file.name, error: 'Invalid response' });
          }
        } else {
          failCount++;
          resolve({ success: false, file: file.name, error: `HTTP ${xhr.status}` });
        }
      });
      
      xhr.addEventListener('error', () => {
        completedCount++;
        failCount++;
        resolve({ success: false, file: file.name, error: 'Network error' });
      });
      
      xhr.open('POST', endpoint);
      xhr.send(formData);
    });
  };
  
  // Upload all files in parallel for maximum speed
  const uploadPromises = selectedFiles.map((file, index) => uploadFile(file, index));
  await Promise.all(uploadPromises);
  
  // Update progress to 100%
  progressBar.style.width = '100%';
  progressText.textContent = '100%';
  statusText.textContent = `Upload complete! ${successCount} succeeded${failCount > 0 ? `, ${failCount} failed` : ''}`;
  
  // Show success message
  if (successCount > 0) {
    showToast(`✓ Uploaded ${successCount} file(s) successfully!`);
  }
  if (failCount > 0) {
    showToast(`⚠ ${failCount} file(s) failed to upload`, 'warning');
  }
  
  // Reload media lists immediately (non-blocking)
  loadMedia();
  
  // Close modal quickly
  setTimeout(() => {
    closeUploadMediaModal();
  }, 800); // Reduced to 800ms for faster UX
}

// Drag and Drop functionality
document.addEventListener('DOMContentLoaded', () => {
  const dropZone = document.getElementById('dropZone');
  
  if (dropZone) {
    // Remove click event on dropZone to prevent double-click issue
    // Only button will trigger file input
    
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-primary', 'bg-primary/10');
    });
    
    dropZone.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-primary', 'bg-primary/10');
    });
    
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-primary', 'bg-primary/10');
      
      const files = Array.from(e.dataTransfer.files);
      addFilesToList(files);
    });
  }
  
  // Schedule modal event listeners
  const scheduleDate = document.getElementById('scheduleDate');
  const scheduleTime = document.getElementById('scheduleTime');
  const delayHours = document.getElementById('delayHours');
  const delayMinutes = document.getElementById('delayMinutes');
  const delaySeconds = document.getElementById('delaySeconds');
  
  if (scheduleDate) scheduleDate.addEventListener('change', updateSchedulePreview);
  if (scheduleTime) scheduleTime.addEventListener('change', updateSchedulePreview);
  if (delayHours) delayHours.addEventListener('input', updateSchedulePreview);
  if (delayMinutes) delayMinutes.addEventListener('input', updateSchedulePreview);
  if (delaySeconds) delaySeconds.addEventListener('input', updateSchedulePreview);
});

