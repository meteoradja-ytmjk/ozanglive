// Handle spectrum JSON file upload
function handleSpectrumJsonUpload(event) {
  const files = Array.from(event.target.files);
  
  files.forEach(file => {
    if (file.type === 'application/json') {
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const jsonData = JSON.parse(e.target.result);
          
          // Validate JSON structure
          if (validateSpectrumJson(jsonData)) {
            uploadedSpectrumFiles.push({
              name: file.name,
              data: jsonData,
              uploadedAt: new Date().toISOString()
            });
            
            updateSpectrumFilesList();
            showToast(`✓ ${file.name} loaded successfully`);
          } else {
            showToast(`✗ ${file.name} has invalid format`);
          }
        } catch (err) {
          console.error('JSON parse error:', err);
          showToast(`✗ ${file.name} is not valid JSON`);
        }
      };
      reader.readAsText(file);
    }
  });
}

// Validate spectrum JSON structure
function validateSpectrumJson(json) {
  const requiredFields = ['name', 'type'];
  return requiredFields.every(field => json.hasOwnProperty(field));
}

// Update spectrum files list UI
function updateSpectrumFilesList() {
  const list = document.getElementById('spectrumFilesList');
  
  if (uploadedSpectrumFiles.length === 0) {
    list.innerHTML = '';
    return;
  }
  
  list.innerHTML = uploadedSpectrumFiles.map((file, idx) => `
    <div class="flex items-center justify-between p-2 bg-dark-700 rounded border border-gray-600">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <i class="ti ti-file-code text-primary"></i>
        <div class="flex-1 min-w-0">
          <div class="text-xs font-medium text-white truncate">${file.data.name || file.name}</div>
          <div class="text-xs text-gray-400">${file.data.type} • ${file.data.bars || 64} bars</div>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button onclick="applySpectrumConfig(${idx})" class="text-primary hover:text-primary/80 p-1" title="Apply">
          <i class="ti ti-check text-sm"></i>
        </button>
        <button onclick="removeSpectrumFile(${idx})" class="text-red-400 hover:text-red-300 p-1" title="Remove">
          <i class="ti ti-x text-sm"></i>
        </button>
      </div>
    </div>
  `).join('');
}

// Apply spectrum configuration
function applySpectrumConfig(index) {
  const file = uploadedSpectrumFiles[index];
  if (!file) return;
  
  const config = file.data;
  currentVisualizerConfig = config;
  
  // Apply settings from JSON
  if (config.bars && visualizerBarCount) {
    visualizerBarCount.value = config.bars;
    barCountValue.textContent = config.bars;
  }
  
  if (config.smoothing && visualizerSmoothing) {
    visualizerSmoothing.value = config.smoothing;
    smoothingValue.textContent = config.smoothing;
  }
  
  if (config.sensitivity && visualizerSensitivity) {
    visualizerSensitivity.value = config.sensitivity;
    sensitivityValue.textContent = config.sensitivity + 'x';
  }
  
  if (config.mirror !== undefined && visualizerMirror) {
    visualizerMirror.checked = config.mirror;
  }
  
  if (config.colors && config.colors.length > 0) {
    // Apply custom colors
    applyCustomColors(config.colors);
  }
  
  updateVisualizerPreview();
  showToast(`✓ Applied: ${config.name}`);
}

// Remove spectrum file
function removeSpectrumFile(index) {
  uploadedSpectrumFiles.splice(index, 1);
  updateSpectrumFilesList();
}

