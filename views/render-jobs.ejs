function setVizHeight(val) {
  vizHeightPercent = parseInt(val);
  document.getElementById('vizHeightVal').textContent = val + '%';
  applyVizCanvasPosition();
  if (vizPreview) vizPreview.updateSettings({ height: vizHeightPercent });
}

let vizOffsetX = 0;
let vizScale = 100;

function setVizOffsetX(val) {
  vizOffsetX = parseInt(val);
  document.getElementById('vizOffsetXVal').textContent = val + '%';
  applyVizCanvasPosition();
}

function setVizScale(val) {
  vizScale = parseInt(val);
  document.getElementById('vizScaleVal').textContent = val + '%';
  applyVizCanvasPosition();
}

function applyVizCanvasPosition() {
  const canvas = document.getElementById('vizPreviewCanvas');
  if (!canvas) return;
  
  // Reset all positioning
  canvas.style.top = '';
  canvas.style.bottom = '';
  canvas.style.left = '0';
  canvas.style.right = '0';
  canvas.style.width = '100%';
  canvas.style.transform = '';
  
  if (vizPosition === 'full') {
    canvas.style.top = '0';
    canvas.style.bottom = '0';
    canvas.style.height = '100%';
  } else if (vizPosition === 'top') {
    canvas.style.top = '0';
    canvas.style.bottom = '';
    canvas.style.height = vizHeightPercent + '%';
  } else if (vizPosition === 'center') {
    canvas.style.top = ((100 - vizHeightPercent) / 2) + '%';
    canvas.style.bottom = '';
    canvas.style.height = vizHeightPercent + '%';
  } else {
    // bottom (default)
    canvas.style.top = '';
    canvas.style.bottom = '0';
    canvas.style.height = vizHeightPercent + '%';
  }
  
  // Apply horizontal offset and scale
  const transforms = [];
  if (vizOffsetX !== 0) transforms.push(`translateX(${vizOffsetX}%)`);
  if (vizScale !== 100) transforms.push(`scale(${vizScale / 100})`);
  canvas.style.transform = transforms.length > 0 ? transforms.join(' ') : '';
  
  // Resize canvas internal resolution after position change
  setTimeout(() => {
    if (vizPreview) vizPreview._resizeCanvas();
  }, 20);
}

