  document.getElementById('loopModal').classList.add('hidden');
  currentLoopJobId = null;
}

async function loadAccountsForLoop() {
  try {
    const r = await fetch('/api/youtube/accounts');
    const d = await r.json();
    const select = document.getElementById('loopTargetAccountId');
    select.innerHTML = '<option value="">-- Pilih Channel (Optional) --</option>' + 
      toArray(d, 'accounts').map(a => `<option value="${a.id}">${a.channelName || ('Channel ' + a.id)}</option>`).join('');
  } catch (err) {
    console.error('Failed to load accounts:', err);
  }
}

async function processLoop() {
  if (!currentLoopJobId) return;
  
  const loopCount = parseInt(document.getElementById('loopCount').value, 10);
  const targetAccountId = document.getElementById('loopTargetAccountId').value;
  
  if (!loopCount || loopCount < 2 || loopCount > 100) {
    alert('Jumlah loop harus antara 2-100');
    return;
  }
  
  // Disable button and show progress
  const btn = document.getElementById('loopProcessBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="ti ti-loader animate-spin mr-1"></i>Processing...';
  
  const progressDiv = document.getElementById('loopProgress');
  const progressBar = document.getElementById('loopProgressBar');
  const progressText = document.getElementById('loopProgressText');
  progressDiv.classList.remove('hidden');
  
  try {
    const response = await fetch(`/api/render/jobs/${currentLoopJobId}/loop`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        loopCount: loopCount,
        targetAccountId: targetAccountId || null
      })
    });
    
    const data = await response.json();
    
    if (!response.ok || !data.success) {
      throw new Error(data.message || 'Failed to process loop');
    }
    
    // Poll for progress
    const newJobId = data.jobId;
    const pollInterval = setInterval(async () => {
      try {
        const jobResponse = await fetch(`/api/render/jobs/${newJobId}`);
        const jobData = await jobResponse.json();
        
        if (jobData.job) {
          const progress = jobData.job.progress || 0;
          progressBar.style.width = progress + '%';
          progressText.textContent = progress + '%';
          
          if (jobData.job.status === 'completed') {
            clearInterval(pollInterval);
            progressBar.style.width = '100%';
            progressText.textContent = '100%';
            
            showToast('✓ Loop completed successfully!');
            
            // Close modal and reload jobs
            setTimeout(() => {
              closeLoopModal();
              loadJobs();
              startSmartRefresh(); // Restart auto-refresh
            }, 1000);
          } else if (jobData.job.status === 'failed') {
            clearInterval(pollInterval);
            throw new Error(jobData.job.error_message || 'Loop failed');
          }
        }
      } catch (err) {
        clearInterval(pollInterval);
        console.error('Poll error:', err);
      }
    }, 1000);
    
  } catch (error) {
    console.error('Loop error:', error);
    alert(error.message || 'Failed to process loop');
    
    // Re-enable button
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-repeat mr-1"></i>Process Loop';
    progressDiv.classList.add('hidden');
  }
}

// ===== FEATURE 4: NOTIFICATIONS =====
let notificationPermission = false;

async function requestNotificationPermission() {
  if ('Notification' in window && Notification.permission === 'default') {
    const permission = await Notification.requestPermission();
    notificationPermission = permission === 'granted';
    
    if (notificationPermission) {
      showBadge('Notifications enabled!', 'success');
    }
  } else if (Notification.permission === 'granted') {
    notificationPermission = true;
  }
}

function showNotification(title, body) {
  // Browser notification
  if (notificationPermission && 'Notification' in window) {
    new Notification(title, {
      body: body,
      icon: '/images/logo.svg',
      badge: '/images/logo.svg'
    });
  }
  
  // In-app toast
  showToast(title + ': ' + body);
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'fixed top-4 right-4 bg-gray-800 border border-primary text-white px-4 py-3 rounded-lg shadow-lg z-50 animate-in';
  toast.innerHTML = `
    <div class="flex items-center gap-2">
      <i class="ti ti-check-circle text-primary"></i>
      <span class="text-sm">${message}</span>
    </div>
  `;
  document.body.appendChild(toast);
  
  setTimeout(() => {
    toast.remove();
  }, 3000);
}

function showBadge(message, type = 'info') {
  const badge = document.createElement('div');
  badge.className = `notification-badge bg-${type === 'success' ? 'green' : 'blue'}-500 text-white px-4 py-2 rounded-lg shadow-lg`;
  badge.textContent = message;
  document.body.appendChild(badge);
  
  setTimeout(() => {
    badge.remove();
  }, 3000);
}

// Monitor job completion for notifications
let lastJobCount = 0;
async function checkJobCompletion() {
  const r = await fetch('/api/render/jobs');
  const d = await r.json();
  const jobs = toArray(d, 'jobs');
  
  const completedJobs = jobs.filter(j => j.status === 'completed' && j.output_path);
  const failedJobs = jobs.filter(j => j.status === 'failed');
  
  if (completedJobs.length > lastJobCount) {
    const newCompleted = completedJobs.slice(lastJobCount);
    newCompleted.forEach(job => {
      showNotification('Render Complete!', `${job.title} has finished rendering`);
      addToHistory(job, 'success');
    });
  }
  
  failedJobs.forEach(job => {
    if (!job.notified) {
      showNotification('Render Failed', `${job.title} failed to render`);
      addToHistory(job, 'failed');
    }
  });
  
  lastJobCount = completedJobs.length;
}

// ===== FEATURE 5: RENDER HISTORY & FILTER =====
function addToHistory(job, status) {
  const history = JSON.parse(localStorage.getItem('renderHistory') || '[]');
  history.unshift({
    id: job.id,
    title: job.title,
    status: status,
    completedAt: new Date().toISOString(),
    duration: job.target_duration_seconds,
    outputPath: job.output_path
  });
  
  // Keep only last 50 items
  if (history.length > 50) history.pop();
  
  localStorage.setItem('renderHistory', JSON.stringify(history));
}

function loadHistory() {
  const history = JSON.parse(localStorage.getItem('renderHistory') || '[]');
  const historyList = document.getElementById('historyList');
  
  if (history.length === 0) {
    historyList.innerHTML = '<div class="text-sm text-gray-400 text-center py-8">No history yet</div>';
    return;
  }
  
  historyList.innerHTML = history.map(h => `
    <div class="bg-dark-700 rounded-lg p-4 border border-gray-600 mb-3" data-status="${h.status}" data-title="${h.title.toLowerCase()}">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <h4 class="text-sm font-semibold text-white mb-1">${h.title}</h4>
          <div class="flex items-center gap-2 text-xs text-gray-400">
            <span class="flex items-center gap-1 ${h.status === 'success' ? 'text-green-400' : 'text-red-400'}">
              <i class="ti ti-${h.status === 'success' ? 'check' : 'x'}"></i>
              ${h.status}
            </span>
            <span>${new Date(h.completedAt).toLocaleString()}</span>
            <span>${h.duration}s</span>
          </div>
        </div>
      </div>
      ${h.outputPath ? `
        <div class="mt-3">
          <a href="${h.outputPath}" target="_blank" class="inline-flex items-center gap-2 px-3 py-2 bg-primary hover:bg-secondary text-white text-sm rounded-lg transition-colors">
            <i class="ti ti-player-play"></i>
            View Result
          </a>
        </div>
      ` : ''}
    </div>
  `).join('');
}

function filterHistory(status) {
  // Update active filter chip
  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.classList.remove('active');
  });
  event.target.classList.add('active');
  
  const items = document.querySelectorAll('#historyList > div[data-status]');
  items.forEach(item => {
    if (status === 'all' || item.dataset.status === status) {
      item.style.display = 'block';
    } else {
      item.style.display = 'none';
    }
  });
}

function searchHistory(query) {
  const items = document.querySelectorAll('#historyList > div[data-title]');
  const lowerQuery = query.toLowerCase();
  
  items.forEach(item => {
    if (item.dataset.title.includes(lowerQuery)) {
      item.style.display = 'block';
    } else {
      item.style.display = 'none';
    }
  });
}

function clearHistory() {
  if (!confirm('Clear all history?')) return;
  localStorage.setItem('renderHistory', '[]');
  loadHistory();
}

