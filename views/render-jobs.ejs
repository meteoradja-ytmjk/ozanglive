<style>
.main-content-wrapper{background:#0b1730!important}.rd{max-width:1200px;margin:0 auto;color:#dbeafe;font-family:Inter,sans-serif}.hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}.badge{background:#183a5b;border:1px solid #2e5d85;border-radius:999px;padding:7px 12px;font-size:12px}
.panel{border:1px solid #2e4a76;background:#122446;border-radius:14px;padding:14px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.card{border:1px solid #2d4268;background:#0d1d3a;border-radius:12px;padding:12px}.lbl{font-size:13px;color:#bfdbfe;margin:8px 0 5px;display:block}.inp,select{width:100%;background:#07162f;border:1px solid #37537f;color:#e0f2fe;border-radius:9px;padding:10px}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}.btn{background:#23d3f3;border:0;color:#032b3a;border-radius:9px;padding:10px 13px;font-weight:700;cursor:pointer}.btn2{background:transparent;color:#cfe8ff;border:1px solid #426188;border-radius:9px;padding:10px 13px;cursor:pointer}
.list{max-height:170px;overflow:auto;border:1px solid #35527f;border-radius:10px;background:#08172f;padding:8px}.chip{display:inline-flex;align-items:center;gap:7px;background:#132846;border:1px solid #34547d;color:#dbeafe;border-radius:999px;padding:6px 10px;margin:4px;font-size:12px}
.job{border:1px solid #36527a;background:#0a1831;border-radius:10px;padding:10px;margin-top:10px}.muted{font-size:12px;color:#93c5fd}.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
@media(max-width:980px){.grid,.row2{grid-template-columns:1fr}}
</style>
<div class="rd">
  <div class="hd"><div><h2 style="margin:0">Render Dashboard</h2><div class="muted">Pilih channel, jam, menit, video, dan audio untuk proses render.</div></div><div class="badge">● Sistem siap render</div></div>
  <div class="panel">
    <div class="grid">
      <div class="card">
        <b>Pengaturan Render</b>
        <label class="lbl">Target Channel</label><select id="targetAccountId"></select>
        <label class="lbl">Judul</label><input id="title" class="inp" value="1"/>
        <div class="row2"><div><label class="lbl">Jam</label><input id="durationHours" class="inp" type="number" min="0" value="1"></div><div><label class="lbl">Menit</label><input id="durationMinutes" class="inp" type="number" min="0" max="59" value="0"></div></div>
        <label class="lbl"><input type="checkbox" id="autoUploadToYoutube"> Upload otomatis</label>
        <div class="actions"><button id="createBtn" class="btn">Render Sekarang</button><button id="resetBtn" class="btn2">Reset</button></div>
      </div>
      <div>
        <div class="card"><b>Video Terpilih</b><div id="videoList" class="list"></div></div>
        <div class="card" style="margin-top:10px"><b>Audio Terpilih</b><div id="audioList" class="list"></div></div>
      </div>
    </div>
    <div class="muted" style="margin-top:8px">Tips: gunakan chip agar pilihan video/audio lebih rapi.</div>
  </div>

  <div class="panel" style="margin-top:14px"><b>Daftar List Job</b><div id="jobs"></div></div>
</div>
<script>
const toArray=(d,k)=>Array.isArray(d)?d:(Array.isArray(d?.[k])?d[k]:[]);
async function loadAccounts(){const r=await fetch('/api/youtube/accounts');const d=await r.json();document.getElementById('targetAccountId').innerHTML=`<option value=''>-- Pilih Channel --</option>`+toArray(d,'accounts').map(a=>`<option value='${a.id}'>${a.channelName||('Channel '+a.id)}</option>`).join('')}
function chips(data,name){return data.map(x=>`<label class='chip'><input type='checkbox' name='${name}' value='${x.id}'> ${x.title}</label>`).join('')}
async function loadMedia(){const [vr,ar]=await Promise.all([fetch('/api/videos'),fetch('/api/stream/audios')]);const vd=await vr.json();const ad=await ar.json();document.getElementById('videoList').innerHTML=chips(toArray(vd,'videos'),'video')||'Tidak ada video';document.getElementById('audioList').innerHTML=chips(toArray(ad,'audios'),'audio')||'Tidak ada audio';}
async function uploadJob(id){const targetAccountId=document.getElementById('targetAccountId').value;const r=await fetch(`/api/render/jobs/${id}/upload`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({targetAccountId})});const d=await r.json();if(!d.success)return alert(d.message||'Upload gagal');alert('Upload berhasil');loadJobs();}
async function deleteJob(id){if(!confirm('Hapus project/job ini?'))return;const r=await fetch(`/api/render/jobs/${id}`,{method:'DELETE'});const d=await r.json();if(!d.success)return alert(d.message||'Gagal hapus');loadJobs();}
async function loadJobs(){const r=await fetch('/api/render/jobs');const d=await r.json();document.getElementById('jobs').innerHTML=toArray(d,'jobs').map(j=>`<div class='job'><b>${j.title||'Tanpa judul'}</b><div class='muted'>${j.status} • ${j.progress||0}% • target ${j.target_duration_seconds||0}s</div>${j.output_path?`<video controls style='width:100%;margin-top:8px;border-radius:8px' src='${j.output_path}'></video>`:''}<div class='actions'>${j.output_path?`<a class='btn2' href='${j.output_path}' target='_blank'>Preview/Download</a><button class='btn' onclick="uploadJob('${j.id}')">Upload ke Channel Target</button>`:''}<button class='btn2' onclick="deleteJob('${j.id}')">Hapus Project</button></div></div>`).join('')||'<div class="muted">Belum ada job</div>'}

document.getElementById('createBtn').addEventListener('click',async()=>{const btn=document.getElementById('createBtn');const title=document.getElementById('title').value;const durationHours=parseInt(document.getElementById('durationHours').value||0,10);const durationMinutes=parseInt(document.getElementById('durationMinutes').value||0,10);const targetDurationSeconds=(durationHours*3600)+(durationMinutes*60);const targetAccountId=document.getElementById('targetAccountId').value;const autoUploadToYoutube=document.getElementById('autoUploadToYoutube').checked;const videoIds=[...document.querySelectorAll(\"input[name='video']:checked\")].map(i=>i.value);const audioIds=[...document.querySelectorAll(\"input[name='audio']:checked\")].map(i=>i.value);if(videoIds.length===0)return alert('Pilih minimal 1 video');btn.disabled=true;btn.textContent='Memproses...';const resp=await fetch('/api/render/jobs',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({title,targetDurationSeconds,durationHours,durationMinutes,targetAccountId,autoUploadToYoutube,videoIds,audioIds})});const data=await resp.json();btn.disabled=false;btn.textContent='Render Sekarang';if(!resp.ok||!data.success)return alert(data.message||'Gagal membuat render job');loadJobs();});
document.getElementById('resetBtn').addEventListener('click',()=>{document.getElementById('title').value='';document.getElementById('durationHours').value=1;document.getElementById('durationMinutes').value=0;document.querySelectorAll("input[name='video'],input[name='audio']").forEach(x=>x.checked=false);});
loadAccounts();loadMedia();loadJobs();setInterval(loadJobs,5000);
</script>
