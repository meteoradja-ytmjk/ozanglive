async function processUpload() {
  if (!currentUploadJobId || !currentUploadJob) return;
  
  const title = document.getElementById('uploadTitle').value.trim();
  const channelId = document.getElementById('uploadTargetChannel').value;
  const description = document.getElementById('uploadDescription').value.trim();
  const tagsInput = document.getElementById('uploadTags').value.trim();
  const categoryId = document.getElementById('uploadCategory').value;
  const privacyStatus = document.getElementById('uploadPrivacy').value;
  
  if (!title) {
    alert('Please enter a video title');
    return;
  }
  
  if (!channelId) {
    alert('Please select a target channel');
    return;
  }
  
  // Parse tags from comma-separated string
  const tags = tagsInput ? tagsInput.split(',').map(t => t.trim()).filter(t => t) : [];
  
  // Get channel name for widget
  const channelSelect = document.getElementById('uploadTargetChannel');
  const channelName = channelSelect.options[channelSelect.selectedIndex].text;
  
  // Mark as uploading
  isUploading = true;
  uploadStartTime = Date.now();
  
  // Disable button and show progress
  const btn = document.getElementById('uploadProcessBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="ti ti-loader animate-spin mr-1"></i>Uploading...';
  
  const progressDiv = document.getElementById('uploadProgress');
  const progressBar = document.getElementById('uploadProgressBar');
  const progressText = document.getElementById('uploadProgressText');
  const statusText = document.getElementById('uploadStatus');
  
  progressDiv.classList.remove('hidden');
  progressBar.style.width = '0%';
  progressText.textContent = '0%';
  statusText.textContent = 'Preparing upload...';
  
  // Initialize widget
  updateUploadWidget(0, 'Preparing upload...', title, channelName);
  
  try {
    // Simulate smooth progress (since actual upload progress is hard to track)
    let simulatedProgress = 0;
    const progressInterval = setInterval(() => {
      if (simulatedProgress < 90) {
        simulatedProgress += Math.random() * 5;
        simulatedProgress = Math.min(90, simulatedProgress);
        progressBar.style.width = simulatedProgress + '%';
        progressText.textContent = Math.round(simulatedProgress) + '%';
        
        let currentStatus = '';
        if (simulatedProgress < 30) {
          currentStatus = 'Uploading video file...';
        } else if (simulatedProgress < 60) {
          currentStatus = 'Processing video...';
        } else {
          currentStatus = 'Finalizing upload...';
        }
        statusText.textContent = currentStatus;
        
        // Update widget
        updateUploadWidget(simulatedProgress, currentStatus, title, channelName);
      }
    }, 500);
    
    // Actual upload request with custom metadata
    const response = await fetch(`/api/render/jobs/${currentUploadJobId}/upload`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        targetAccountId: channelId,
        title: title,
        description: description,
        tags: tags,
        categoryId: categoryId,
        privacyStatus: privacyStatus
      })
    });
    
    clearInterval(progressInterval);
    
    const data = await response.json();
    
    if (!response.ok || !data.success) {
      throw new Error(data.message || 'Upload failed');
    }
    
    // Complete progress
    progressBar.style.width = '100%';
    progressText.textContent = '100%';
    statusText.textContent = 'Upload completed successfully!';
    
    // Update widget to 100%
    updateUploadWidget(100, 'Upload completed!', title, channelName);
    
    // Show success notifications
    showToast('✓ Video uploaded to YouTube!');
    showNotification('Upload Complete', `"${title}" has been uploaded to YouTube successfully!`);
    
    // Mark as not uploading
    isUploading = false;
    
    // Hide widget after 3 seconds
    setTimeout(() => {
      hideUploadWidget();
    }, 3000);
    
    // Close modal and reload jobs
    setTimeout(() => {
      closeUploadModal();
      loadJobs();
    }, 1500);
    
  } catch (error) {
    console.error('Upload error:', error);
    
    // Update widget with error
    updateUploadWidget(0, 'Upload failed!', title, channelName);
    
    alert(error.message || 'Failed to upload video');
    
    // Re-enable button
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-upload mr-1"></i>Upload to YouTube';
    progressDiv.classList.add('hidden');
    
    isUploading = false;
    
    // Hide widget after 2 seconds
    setTimeout(() => {
      hideUploadWidget();
    }, 2000);
  }
}

