// FEATURE 4: BATCH RENDER QUEUE
let batchQueue = [];

function addToBatchQueue() {
  const titleV = el.title.value;
  const h = parseInt(el.durationHours.value || 0, 10);
  const m = parseInt(el.durationMinutes.value || 0, 10);
  const videoIds = [...document.querySelectorAll("input[name='video']:checked")].map(i=>i.value);
  const audioIds = [...document.querySelectorAll("input[name='audio']:checked")].map(i=>i.value);
  
  if (videoIds.length === 0) {
    alert('Please select at least one video');
    return;
  }
  
  const queueItem = {
    id: Date.now(),
    title: titleV || `Render ${batchQueue.length + 1}`,
    durationHours: h,
    durationMinutes: m,
    targetDurationSeconds: (h * 3600) + (m * 60),
    targetAccountId: el.targetAccountId.value,
    autoUploadToYoutube: el.autoUploadToYoutube.checked,
    visualizerPreset: el.visualizerPreset.value,
    visualizerIntensity: visualizerIntensity?.value || 50,
    visualizerColor: visualizerColor?.value || 'purple',
    followAudioDuration: el.followAudioDuration.checked,
    videoIds: videoIds,
    audioIds: audioIds,
    watermark: watermarkImageData ? {
      image: watermarkImageData,
      position: document.getElementById('watermarkPosition')?.value || 'bottom-right',
      opacity: document.getElementById('watermarkOpacity')?.value || 70
    } : null,
    status: 'pending'
  };
  
  batchQueue.push(queueItem);
  updateBatchQueueUI();
  showToast(`Added "${queueItem.title}" to queue`);
}

function updateBatchQueueUI() {
  const batchCount = document.getElementById('batchCount');
  const batchCountTab = document.getElementById('batchCountTab');
  const batchQueueList = document.getElementById('batchQueueList');
  
  if (batchCount) batchCount.textContent = batchQueue.length;
  if (batchCountTab) batchCountTab.textContent = batchQueue.length;
  
  if (batchQueue.length === 0) {
    batchQueueList.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No items in queue</div>';
    return;
  }
  
  batchQueueList.innerHTML = batchQueue.map((item, idx) => `
    <div class="batch-queue-item bg-dark-700 p-2 rounded-lg border border-gray-600 ${item.status === 'processing' ? 'processing' : ''}">
      <div class="flex items-center justify-between">
        <div class="flex-1 min-w-0">
          <div class="text-xs font-medium text-white truncate">${item.title}</div>
          <div class="text-xs text-gray-400">${item.videoIds.length} videos • ${item.durationHours}h ${item.durationMinutes}m</div>
        </div>
        <div class="flex items-center gap-1">
          ${item.status === 'processing' ? '<i class="ti ti-loader animate-spin text-green-400"></i>' : ''}
          <button onclick="removeBatchItem(${idx})" class="text-red-400 hover:text-red-300 p-1">
            <i class="ti ti-x text-sm"></i>
          </button>
        </div>
      </div>
    </div>
  `).join('');
}

function removeBatchItem(index) {
  batchQueue.splice(index, 1);
  updateBatchQueueUI();
}

function clearBatchQueue() {
  if (!confirm('Clear all items from queue?')) return;
  batchQueue = [];
  updateBatchQueueUI();
}

async function processBatchQueue() {
  if (batchQueue.length === 0) {
    alert('Queue is empty');
    return;
  }
  
  if (!confirm(`Process ${batchQueue.length} render job(s)?`)) return;
  
  showToast(`Processing ${batchQueue.length} jobs...`);
  
  for (let i = 0; i < batchQueue.length; i++) {
    const item = batchQueue[i];
    item.status = 'processing';
    updateBatchQueueUI();
    
    try {
      const resp = await fetch('/api/render/jobs', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(item)
      });
      
      const data = await resp.json();
      
      if (resp.ok && data.success) {
        showToast(`✓ ${item.title} queued`);
      } else {
        showToast(`✗ ${item.title} failed: ${data.message}`);
      }
    } catch (err) {
      console.error('Batch render error:', err);
      showToast(`✗ ${item.title} error`);
    }
    
    // Small delay between jobs
    await new Promise(resolve => setTimeout(resolve, 500));
  }
  
  // Clear queue after processing
  batchQueue = [];
  updateBatchQueueUI();
  loadJobs();
  showNotification('Batch Processing Complete', `All ${batchQueue.length} jobs have been queued`);
}

// FEATURE 5: ENHANCED REAL-TIME PROGRESS (already implemented, adding circular progress)
function createProgressRing(progress) {
  const radius = 18;
  const circumference = 2 * Math.PI * radius;
  const offset = circumference - (progress / 100) * circumference;
  
  return `
    <svg class="progress-ring" width="40" height="40">
      <circle class="text-gray-600" stroke-width="3" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
      <circle class="progress-ring-circle text-primary" stroke-width="3" stroke-dasharray="${circumference}" stroke-dashoffset="${offset}" stroke-linecap="round" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
    </svg>
  `;
}

// Initialize
Promise.resolve()
  .then(loadAccounts)
  .then(loadMedia)
  .then(loadJobs)
  .then(requestNotificationPermission)
  .catch((err) => console.error('Render dashboard init error:', err));

// Auto-refresh jobs every 3 seconds (faster for real-time updates)
setInterval(() => {
  loadJobs().catch(() => {});
  checkJobCompletion().catch(() => {});
}, 3000);
</script>
