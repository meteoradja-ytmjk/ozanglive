let currentLoopJobId = null;

function openLoopModal(jobId) {
  currentLoopJobId = jobId;
  
  // Load accounts for loop target
  loadAccountsForLoop();
  
  // Reset form
  document.getElementById('loopCount').value = 2;
  document.getElementById('loopTargetAccountId').value = '';
  document.getElementById('loopProgress').classList.add('hidden');
  document.getElementById('loopProcessBtn').disabled = false;
  
