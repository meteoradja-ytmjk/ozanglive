function updateUploadWidget(progress, status, videoTitle, channelName) {
  // Update minimized state
  document.getElementById('widgetProgressText').textContent = Math.round(progress);
  
  // Update expanded state
  document.getElementById('widgetVideoTitle').textContent = videoTitle || 'Video Title';
  document.getElementById('widgetChannelName').textContent = channelName || 'Channel Name';
  document.getElementById('widgetStatus').textContent = status || 'Uploading...';
  document.getElementById('widgetProgressPercent').textContent = Math.round(progress) + '%';
  document.getElementById('widgetProgressBar').style.width = progress + '%';
  
  // Calculate time remaining
  if (uploadStartTime && progress > 0 && progress < 100) {
    const elapsed = (Date.now() - uploadStartTime) / 1000; // seconds
    const totalTime = (elapsed / progress) * 100;
    const remaining = totalTime - elapsed;
    
    if (remaining > 60) {
      const mins = Math.floor(remaining / 60);
      const secs = Math.floor(remaining % 60);
      document.getElementById('widgetTimeRemaining').textContent = `${mins}m ${secs}s remaining`;
    } else {
      document.getElementById('widgetTimeRemaining').textContent = `${Math.floor(remaining)}s remaining`;
    }
  } else if (progress >= 100) {
    document.getElementById('widgetTimeRemaining').textContent = 'Complete!';
  }
}

function handleCloseUploadModal() {
  if (isUploading) {
    // Minimize to widget instead of closing
    closeUploadModal();
    showUploadWidget();
    minimizeUploadWidget();
  } else {
    closeUploadModal();
  }
}

