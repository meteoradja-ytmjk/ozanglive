    audioTab.className = 'px-4 py-2 text-sm font-medium transition-colors border-b-2 border-primary text-primary';
    videoTab.className = 'px-4 py-2 text-sm font-medium transition-colors border-b-2 border-transparent text-gray-400 hover:text-white';
    audioContent.classList.remove('hidden');
    videoContent.classList.add('hidden');
  }
  
  updateMediaSelectionCount();
}

function selectAllMedia() {
  const checkboxes = currentMediaTab === 'video' 
    ? document.querySelectorAll("input[name='video']")
    : document.querySelectorAll("input[name='audio']");
  
  checkboxes.forEach(cb => cb.checked = true);
  updateMediaSelectionCount();
  
  if (currentMediaTab === 'video') {
    refreshMiniPreview();
  }
  
  showToast(`✓ All ${currentMediaTab}s selected`);
}

function deselectAllMedia() {
  const checkboxes = currentMediaTab === 'video' 
    ? document.querySelectorAll("input[name='video']")
    : document.querySelectorAll("input[name='audio']");
  
  checkboxes.forEach(cb => cb.checked = false);
  updateMediaSelectionCount();
  
  if (currentMediaTab === 'video') {
    refreshMiniPreview();
  }
  
  showToast(`✓ All ${currentMediaTab}s deselected`);
}

function shuffleMedia() {
  const checkboxes = currentMediaTab === 'video' 
    ? Array.from(document.querySelectorAll("input[name='video']"))
    : Array.from(document.querySelectorAll("input[name='audio']"));
  
  if (checkboxes.length === 0) {
    showToast('No media available to shuffle');
    return;
  }
  
  // Get currently selected items
  const selectedIds = checkboxes.filter(cb => cb.checked).map(cb => cb.value);
  
  if (selectedIds.length === 0) {
    showToast('Please select some items first');
    return;
  }
  
  // Deselect all
  checkboxes.forEach(cb => cb.checked = false);
  
  // Shuffle the selected IDs using Fisher-Yates algorithm
  const shuffled = [...selectedIds];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  
  // Reselect in shuffled order
  shuffled.forEach(id => {
    const checkbox = checkboxes.find(cb => cb.value === id);
    if (checkbox) checkbox.checked = true;
  });
  
  updateMediaSelectionCount();
  
  if (currentMediaTab === 'video') {
    refreshMiniPreview();
  }
  
  showToast(`🔀 ${selectedIds.length} ${currentMediaTab}(s) shuffled`);
}

function updateMediaSelectionCount() {
  const videoCount = document.querySelectorAll("input[name='video']:checked").length;
  const audioCount = document.querySelectorAll("input[name='audio']:checked").length;
  
  const videoCountEl = document.getElementById('videoSelectedCount');
  const audioCountEl = document.getElementById('audioSelectedCount');
  
  if (videoCountEl) videoCountEl.textContent = `(${videoCount})`;
  if (audioCountEl) audioCountEl.textContent = `(${audioCount})`;
}

// Update selection count when checkboxes change
