<% layout('layout') -%>

<style>
/* Mobile action buttons */
@media (max-width: 1023px) {
  .mobile-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding: 1rem;
    margin-bottom: 1rem;
  }
  
  .mobile-action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0.5rem;
    background: #1F2937;
    border: 1px solid #4B5563;
    border-radius: 0.75rem;
    color: #D1D5DB;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .mobile-action-btn:active {
    transform: scale(0.95);
  }
  
  .mobile-action-btn.primary {
    background: #8B5CF6;
    color: white;
    border-color: #8B5CF6;
  }
  
  .mobile-action-btn i {
    font-size: 1.5rem;
  }
}

@media (min-width: 1024px) {
  .mobile-actions {
    display: none !important;
  }
}
</style>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold">Render Dashboard</h2>
    <p class="text-gray-400 text-sm mt-1">Pilih channel, jam, menit, video, dan audio untuk proses render</p>
  </div>
</div>

<!-- Mobile Action Buttons -->
<div class="mobile-actions">
  <button class="mobile-action-btn primary" id="mobileCreateBtn">
    <i class="ti ti-plus"></i>
    <span>New</span>
  </button>
  <button class="mobile-action-btn" id="mobileRefreshBtn">
    <i class="ti ti-refresh"></i>
    <span>Refresh</span>
  </button>
  <button class="mobile-action-btn" id="mobileResetBtn">
    <i class="ti ti-eraser"></i>
    <span>Reset</span>
  </button>
</div>

<!-- Main Form Card -->
<div class="bg-gray-800 rounded-lg p-4 md:p-6 mb-6">
  <h3 class="text-lg font-semibold mb-4">Render Settings</h3>
  
  <div class="space-y-4">
    <!-- Target Channel -->
    <div>
      <label class="text-sm font-medium text-white block mb-2">Target Channel</label>
      <select id="targetAccountId" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        <option value="">-- Pilih Channel --</option>
      </select>
    </div>
    
    <!-- Title -->
    <div>
      <label class="text-sm font-medium text-white block mb-2">Judul</label>
      <input type="text" id="title" value="1" placeholder="Masukkan judul" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
    </div>
    
    <!-- Duration -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="text-sm font-medium text-white block mb-2">Jam</label>
        <input type="number" id="durationHours" min="0" value="0" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
      </div>
      <div>
        <label class="text-sm font-medium text-white block mb-2">Menit</label>
        <input type="number" id="durationMinutes" min="0" max="59" value="0" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
      </div>
    </div>
    
    <!-- Visualizer -->
    <div>
      <label class="text-sm font-medium text-white block mb-2">Overlay / Spectrum Effect</label>
      <select id="visualizerPreset" class="w-full bg-dark-700 text-white px-4 py-2.5 border border-gray-600 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        <option value="none">Tanpa overlay</option>
        <option value="spectrum">Spectrum</option>
        <option value="bars">Bars</option>
        <option value="wave">Wave</option>
      </select>
    </div>
    
    <!-- Follow Audio Duration -->
    <div class="flex items-center gap-2">
      <input type="checkbox" id="followAudioDuration" class="w-4 h-4 rounded border-gray-500 bg-dark-700 text-primary focus:ring-primary">
      <label for="followAudioDuration" class="text-sm text-gray-300">Loop mengikuti total durasi audio</label>
    </div>
    
    <!-- Auto Upload -->
    <div class="flex items-center justify-between p-4 bg-dark-700 rounded-lg border border-gray-600">
      <div>
        <div class="text-sm font-medium text-white">Upload otomatis</div>
        <div class="text-xs text-gray-400 mt-1">Upload otomatis setelah render selesai</div>
      </div>
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" id="autoUploadToYoutube" class="sr-only peer">
        <div class="w-11 h-6 bg-gray-600 rounded-full peer peer-checked:bg-primary transition-colors"></div>
        <div class="absolute left-[2px] top-[2px] w-5 h-5 bg-white rounded-full transition-all peer-checked:translate-x-5"></div>
      </label>
    </div>
    
    <!-- Action Buttons (Desktop) -->
    <div class="flex gap-3 pt-2">
      <button id="createBtn" class="flex-1 bg-primary hover:bg-secondary text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
        Render Sekarang
      </button>
      <button id="resetBtn" class="px-6 py-2.5 bg-dark-700 hover:bg-dark-600 border border-gray-600 text-gray-300 rounded-lg font-medium transition-colors">
        Reset
      </button>
    </div>
  </div>
</div>

<!-- Video & Audio Selection -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <!-- Video Selection -->
  <div class="bg-gray-800 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-white">Video</h3>
      <span class="text-xs text-gray-400">Multi-select</span>
    </div>
    <div id="videoList" class="max-h-80 overflow-y-auto bg-dark-700 rounded-lg p-2 border border-gray-600">
      <div class="text-sm text-gray-400 text-center py-4">Loading...</div>
    </div>
  </div>
  
  <!-- Audio Selection -->
  <div class="bg-gray-800 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-white">Audio</h3>
      <span class="text-xs text-gray-400">Opsional</span>
    </div>
    <div id="audioList" class="max-h-80 overflow-y-auto bg-dark-700 rounded-lg p-2 border border-gray-600">
      <div class="text-sm text-gray-400 text-center py-4">Loading...</div>
    </div>
  </div>
</div>

<!-- Jobs List -->
<div class="bg-gray-800 rounded-lg p-4 md:p-6">
  <h3 class="text-lg font-semibold mb-4">Daftar Render Jobs</h3>
  <div id="jobs">
    <div class="text-sm text-gray-400 text-center py-8">Belum ada job</div>
  </div>
</div>

<script>
const toArray=(d,k)=>Array.isArray(d)?d:((d && Array.isArray(d[k])) ? d[k] : []);
const el = {
  targetAccountId: document.getElementById('targetAccountId'),
  title: document.getElementById('title'),
  durationHours: document.getElementById('durationHours'),
  durationMinutes: document.getElementById('durationMinutes'),
  visualizerPreset: document.getElementById('visualizerPreset'),
  followAudioDuration: document.getElementById('followAudioDuration'),
  autoUploadToYoutube: document.getElementById('autoUploadToYoutube'),
  createBtn: document.getElementById('createBtn'),
  resetBtn: document.getElementById('resetBtn'),
  videoList: document.getElementById('videoList'),
  audioList: document.getElementById('audioList'),
  jobs: document.getElementById('jobs')
};

const ensureEl = (name) => {
  if (!el[name]) throw new Error(`Element "${name}" tidak ditemukan`);
  return el[name];
};

const normalizeName=(title)=>String(title||'').toLowerCase().replace(/[0-9]+([.,][0-9]+)?/g,'').replace(/[_-]+/g,' ').replace(/\s+/g,' ').trim();
const groupByName=(items)=>items.reduce((acc,item)=>{const key=normalizeName(item.title)||'lainnya';if(!acc[key])acc[key]=[];acc[key].push(item);return acc;},{});
const fmtMB=(bytes)=>{const n=Number(bytes||0);if(!n)return '-';return `${(n/1024/1024).toFixed(1)} MB`;};

const renderGroupedRows=(items,name,type)=>{
  const grouped=groupByName(items);
  return Object.entries(grouped).map(([nameGroup,rows],idx)=>`
    <details ${idx===0?'open':''} class="mb-2 bg-gray-800 rounded-lg border border-gray-700 overflow-hidden">
      <summary class="cursor-pointer px-3 py-2 flex items-center justify-between hover:bg-gray-700/50 transition-colors">
        <div class="flex items-center gap-2">
          <i class="ti ti-chevron-down text-xs text-primary"></i>
          <span class="text-sm font-medium text-white capitalize">${nameGroup}</span>
        </div>
        <span class="text-xs text-gray-400">${rows.length} ${type}</span>
      </summary>
      <div class="border-t border-gray-700">
        ${rows.map(x=>`
          <label class="flex items-center gap-3 px-3 py-2 hover:bg-gray-700/30 cursor-pointer border-t border-gray-700/50 first:border-t-0">
            <input type="checkbox" name="${name}" value="${x.id}" class="w-4 h-4 rounded border-gray-500 bg-dark-700 text-primary focus:ring-primary">
            <div class="w-16 h-10 rounded bg-gray-900 flex-shrink-0 overflow-hidden">
              ${x.thumbnail_path?`<img src="${x.thumbnail_path}" class="w-full h-full object-cover">`:`<div class="w-full h-full flex items-center justify-center text-xs text-primary">${type==='videos'?'VID':'AUD'}</div>`}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm text-white truncate">${x.title}</div>
              <div class="text-xs text-gray-400">${x.duration||'-'} • ${fmtMB(x.file_size)}</div>
            </div>
          </label>
        `).join('')}
      </div>
    </details>
  `).join('');
};

async function loadAccounts(){
  const target=ensureEl('targetAccountId');
  const r=await fetch('/api/youtube/accounts');
  const d=await r.json();
  target.innerHTML=`<option value="">-- Pilih Channel --</option>`+toArray(d,'accounts').map(a=>`<option value="${a.id}">${a.channelName||('Channel '+a.id)}</option>`).join('');
}

async function loadMedia(){
  ensureEl('videoList');
  ensureEl('audioList');
  const [vr,ar]=await Promise.all([fetch('/api/videos'),fetch('/api/stream/audios')]);
  const vd=await vr.json();
  const ad=await ar.json();
  el.videoList.innerHTML=renderGroupedRows(toArray(vd,'videos'),'video','videos')||'<div class="text-sm text-gray-400 text-center py-4">Tidak ada video</div>';
  el.audioList.innerHTML=renderGroupedRows(toArray(ad,'audios'),'audio','audios')||'<div class="text-sm text-gray-400 text-center py-4">Tidak ada audio</div>';
}

async function uploadJob(id){
  const r=await fetch(`/api/render/jobs/${id}/upload`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({targetAccountId:el.targetAccountId.value})});
  const d=await r.json();
  if(!d.success)return alert(d.message||'Upload gagal');
  loadJobs();
}

async function deleteJob(id){
  if(!confirm('Hapus project ini?'))return;
  const r=await fetch(`/api/render/jobs/${id}`,{method:'DELETE'});
  const d=await r.json();
  if(!d.success)return alert(d.message||'Gagal hapus');
  loadJobs();
}

async function loadJobs(){
  const r=await fetch('/api/render/jobs');
  const d=await r.json();
  const cards=toArray(d,'jobs').map(j=>`
    <div class="bg-dark-700 rounded-lg p-4 border border-gray-600 hover:border-primary transition-colors mb-3">
      <div class="flex items-start justify-between mb-2">
        <div class="flex-1">
          <h4 class="text-sm font-semibold text-white mb-1">${j.title||'Tanpa judul'}</h4>
          <div class="text-xs text-gray-400">${j.status} • ${j.progress||0}% • target ${j.target_duration_seconds||0}s</div>
        </div>
      </div>
      <div class="w-full bg-gray-600 rounded-full h-1.5 mb-3">
        <div class="bg-primary h-1.5 rounded-full transition-all" style="width:${Math.max(0,Math.min(100,Number(j.progress||0)))}%"></div>
      </div>
      ${j.output_path?`<video controls preload="metadata" src="${j.output_path}" class="w-full rounded-lg mb-3 bg-black"></video>`:''}
      <div class="flex gap-2">
        ${j.output_path?`
          <a href="${j.output_path}" target="_blank" class="flex-1 text-center px-3 py-2 bg-gray-600 hover:bg-gray-500 text-white text-sm rounded-lg transition-colors">Preview</a>
          <button onclick="uploadJob('${j.id}')" class="flex-1 px-3 py-2 bg-primary hover:bg-secondary text-white text-sm rounded-lg transition-colors">Upload</button>
        `:''}
        <button onclick="deleteJob('${j.id}')" class="px-3 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm rounded-lg transition-colors">Hapus</button>
      </div>
    </div>
  `).join('');
  el.jobs.innerHTML=cards||'<div class="text-sm text-gray-400 text-center py-8">Belum ada job</div>';
}

if (el.createBtn) {
  el.createBtn.addEventListener('click',async()=>{
    try{
      const titleV=el.title.value;
      const h=parseInt(el.durationHours.value||0,10);
      const m=parseInt(el.durationMinutes.value||0,10);
      const targetDurationSeconds=(h*3600)+(m*60);
      const videoIds=[...document.querySelectorAll("input[name='video']:checked")].map(i=>i.value);
      const audioIds=[...document.querySelectorAll("input[name='audio']:checked")].map(i=>i.value);
      if(videoIds.length===0)return alert('Pilih minimal 1 video');
      const resp=await fetch('/api/render/jobs',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({title:titleV,targetDurationSeconds,durationHours:h,durationMinutes:m,targetAccountId:el.targetAccountId.value,autoUploadToYoutube:el.autoUploadToYoutube.checked,visualizerPreset:el.visualizerPreset.value,followAudioDuration:el.followAudioDuration.checked,videoIds,audioIds})});
      const data=await resp.json();
      if(!resp.ok||!data.success)return alert(data.message||'Gagal');
      loadJobs();
    }catch(err){
      console.error('Create render job error:', err);
      alert('Terjadi error saat membuat render job');
    }
  });
}

if (el.resetBtn) {
  el.resetBtn.addEventListener('click',()=>{
    el.title.value='';
    el.durationHours.value=0;
    el.durationMinutes.value=0;
    document.querySelectorAll("input[name='video'],input[name='audio']").forEach(x=>x.checked=false);
  });
}

const toggleDurationInputs = () => {
  const follow = el.followAudioDuration.checked;
  el.durationHours.disabled = follow;
  el.durationMinutes.disabled = follow;
  el.durationHours.style.opacity = follow ? '0.5' : '1';
  el.durationMinutes.style.opacity = follow ? '0.5' : '1';
};

if (el.followAudioDuration) {
  el.followAudioDuration.addEventListener('change', toggleDurationInputs);
}
toggleDurationInputs();

// Mobile buttons
const mobileCreateBtn = document.getElementById('mobileCreateBtn');
const mobileRefreshBtn = document.getElementById('mobileRefreshBtn');
const mobileResetBtn = document.getElementById('mobileResetBtn');

if (mobileCreateBtn) {
  mobileCreateBtn.addEventListener('click', () => {
    if (el.createBtn) el.createBtn.click();
  });
}

if (mobileRefreshBtn) {
  mobileRefreshBtn.addEventListener('click', () => {
    Promise.resolve()
      .then(loadAccounts)
      .then(loadMedia)
      .then(loadJobs)
      .catch((err) => console.error('Refresh error:', err));
  });
}

if (mobileResetBtn) {
  mobileResetBtn.addEventListener('click', () => {
    if (el.resetBtn) el.resetBtn.click();
  });
}

// Initialize
Promise.resolve()
  .then(loadAccounts)
  .then(loadMedia)
  .then(loadJobs)
  .catch((err) => console.error('Render dashboard init error:', err));

setInterval(() => loadJobs().catch(() => {}), 5000);
</script>
