}

function minimizeUploadWidget() {
  document.getElementById('uploadWidgetMinimized').classList.remove('hidden');
  document.getElementById('uploadWidgetExpanded').classList.add('hidden');
}

function expandUploadWidget() {
  document.getElementById('uploadWidgetMinimized').classList.add('hidden');
  document.getElementById('uploadWidgetExpanded').classList.remove('hidden');
}

function closeUploadWidget() {
  if (isUploading) {
    if (!confirm('Upload is still in progress. Are you sure you want to cancel?')) {
      return;
    }
  }
  hideUploadWidget();
  isUploading = false;
