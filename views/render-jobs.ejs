// Show/hide advanced audio settings when audio is selected
function updateAdvancedAudioVisibility() {
  const audioChecked = document.querySelectorAll("input[name='audio']:checked").length;
  const advancedSettings = document.getElementById('advancedAudioSettings');
  
  if (audioChecked > 0) {
    advancedSettings?.classList.remove('hidden');
  } else {
    advancedSettings?.classList.add('hidden');
  }
}

// Update volume value display
document.getElementById('audioVolume')?.addEventListener('input', (e) => {
  document.getElementById('volumeValue').textContent = e.target.value + '%';
});

// Update background music volume display
document.getElementById('bgMusicVolume')?.addEventListener('input', (e) => {
  document.getElementById('bgVolumeValue').textContent = e.target.value + '%';
});

// Update voiceover volume display
document.getElementById('voiceoverVolume')?.addEventListener('input', (e) => {
  document.getElementById('voiceVolumeValue').textContent = e.target.value + '%';
});

// Toggle dual audio controls
document.getElementById('enableDualAudio')?.addEventListener('change', (e) => {
  const controls = document.getElementById('dualAudioControls');
  if (e.target.checked) {
    controls?.classList.remove('hidden');
  } else {
    controls?.classList.add('hidden');
  }
});

// Reset audio settings
function resetAudioSettings() {
  document.getElementById('audioFadeIn').value = 0;
  document.getElementById('audioFadeOut').value = 0;
  document.getElementById('audioVolume').value = 100;
  document.getElementById('volumeValue').textContent = '100%';
  document.getElementById('audioCrossfade').value = 0;
  document.getElementById('audioNormalize').checked = false;
  document.getElementById('enableDualAudio').checked = false;
  document.getElementById('dualAudioControls')?.classList.add('hidden');
  document.getElementById('bgMusicVolume').value = 30;
  document.getElementById('bgVolumeValue').textContent = '30%';
  document.getElementById('voiceoverVolume').value = 100;
  document.getElementById('voiceVolumeValue').textContent = '100%';
  
  showToast('Audio settings reset');
}

// Listen to audio checkbox changes
document.addEventListener('change', (e) => {
  if (e.target.name === 'audio') {
    updateAdvancedAudioVisibility();
  }
});

// Get advanced audio settings
function getAdvancedAudioSettings() {
  return {
    fadeIn: parseFloat(document.getElementById('audioFadeIn')?.value || 0),
    fadeOut: parseFloat(document.getElementById('audioFadeOut')?.value || 0),
    volume: parseInt(document.getElementById('audioVolume')?.value || 100),
    crossfade: parseFloat(document.getElementById('audioCrossfade')?.value || 0),
    normalize: document.getElementById('audioNormalize')?.checked || false,
    dualLayer: {
      enabled: document.getElementById('enableDualAudio')?.checked || false,
      bgVolume: parseInt(document.getElementById('bgMusicVolume')?.value || 30),
      voiceVolume: parseInt(document.getElementById('voiceoverVolume')?.value || 100)
    }
  };
}

