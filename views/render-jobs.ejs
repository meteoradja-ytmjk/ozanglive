// ===== AUDIO VISUALIZER LIVE PREVIEW =====
let vizPreview = null;
let vizEnabled = false;
let vizCurrentAudioUrl = null;
let vizPosition = 'bottom';
let vizHeightPercent = 30;

function toggleVisualizerPanel() {
  vizEnabled = document.getElementById('vizEnabled').checked;
  const panel = document.getElementById('vizSettingsPanel');
  const canvas = document.getElementById('vizPreviewCanvas');
  
  panel.classList.toggle('hidden', !vizEnabled);
  
  if (vizEnabled) {
    // Stop direct audio to prevent double playback
    stopDirectAudio();
    
    canvas.style.display = 'block';
    
    // Initialize visualizer preview after canvas is visible
    setTimeout(() => {
      if (!vizPreview) {
        vizPreview = new AudioVisualizerPreview('vizPreviewCanvas');
      }
      vizPreview._resizeCanvas();
      
      const audioIds = [...document.querySelectorAll("input[name='audio']:checked")].map(i => i.value);
      if (audioIds.length > 0) {
        loadVizAudioPreview();
      } else {
        vizPreview.startSimulated();
      }
      
      applyVizCanvasPosition();
    }, 50);
    
    document.getElementById('vizAudioControls').classList.remove('hidden');
  } else {
    // Stop visualizer audio
    if (vizPreview) {
      vizPreview.stop();
    }
    canvas.style.display = 'none';
    
    // Resume direct audio if audio is selected
    const audioCheckboxes = document.querySelectorAll("input[name='audio']:checked");
    if (audioCheckboxes.length > 0) {
      document.getElementById('vizAudioControls').classList.remove('hidden');
      loadDirectAudioPreview();
    } else {
      document.getElementById('vizAudioControls').classList.add('hidden');
    }
  }
}

// Auto-load preview when video/audio is selected (independent of visualizer)
function loadPreviewOnSelection() {
  const videoPlayer = document.getElementById('vizVideoPlayer');
  const placeholder = document.getElementById('vizPlaceholder');
  const videoCheckboxes = document.querySelectorAll("input[name='video']:checked");
  
  if (videoCheckboxes.length > 0) {
    loadVizVideoPreview();
  } else {
    videoPlayer.src = '';
    videoPlayer.style.display = 'none';
    placeholder.classList.remove('hidden');
  }
}

// ===== AUTO-PLAY AUDIO ON SELECTION =====
let previewAudioElement = null;

function autoPlayAudioPreview() {
  const audioCheckboxes = document.querySelectorAll("input[name='audio']:checked");
  const audioControls = document.getElementById('vizAudioControls');
  
  if (audioCheckboxes.length > 0) {
    // Show audio controls
    audioControls.classList.remove('hidden');
    
    if (vizEnabled && vizPreview) {
      // Stop direct audio first to prevent double playback
      stopDirectAudio();
      loadVizAudioPreview();
    } else {
      // Stop visualizer audio first to prevent double playback
      if (vizPreview && vizPreview.audioElement) {
        vizPreview.audioElement.pause();
      }
      loadDirectAudioPreview();
    }
  } else {
    audioControls.classList.add('hidden');
    stopDirectAudio();
    if (vizPreview) vizPreview.stop();
  }
}

async function loadDirectAudioPreview() {
  const audioCheckboxes = document.querySelectorAll("input[name='audio']:checked");
  if (audioCheckboxes.length === 0) return;
  
  const audioId = audioCheckboxes[0].value;
  try {
    const resp = await fetch('/api/audios/' + audioId);
    const data = await resp.json();
    const audio = data.audio || data;
    
    if (audio && audio.filepath) {
      if (!previewAudioElement) {
        previewAudioElement = new Audio();
        previewAudioElement.volume = 0.5;
        previewAudioElement.loop = true;
        
        // Update progress bar
        previewAudioElement.addEventListener('timeupdate', () => {
          if (previewAudioElement.duration) {
            const pct = (previewAudioElement.currentTime / previewAudioElement.duration) * 100;
            const bar = document.getElementById('vizAudioProgress');
            if (bar) bar.style.width = pct + '%';
          }
        });
      }
      
      const audioPath = audio.filepath.startsWith('/') ? audio.filepath : '/' + audio.filepath;
      if (previewAudioElement.src !== location.origin + audioPath) {
        previewAudioElement.src = audioPath;
        previewAudioElement.play().catch(() => {});
        document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-pause text-sm"></i>';
      }
    }
  } catch (err) {
    console.error('[Preview] Failed to load audio:', err);
  }
}

function stopDirectAudio() {
  if (previewAudioElement) {
    previewAudioElement.pause();
    previewAudioElement.src = '';
    document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-play text-sm"></i>';
  }
}

// ===== FLOATING PREVIEW =====
let isFloatingPreview = false;

function toggleFloatingPreview() {
  const preview = document.getElementById('vizLivePreview');
  const floatBtn = document.getElementById('floatPreviewBtn');
  const closeBtn = document.getElementById('floatCloseBtn');
  
  isFloatingPreview = !isFloatingPreview;
  
  if (isFloatingPreview) {
    preview.classList.add('floating-preview');
    floatBtn.innerHTML = '<i class="ti ti-picture-in-picture-off text-xs"></i><span>Dock</span>';
    floatBtn.title = 'Kembalikan preview ke posisi semula';
    closeBtn.classList.remove('hidden');
    closeBtn.classList.add('flex');
  } else {
    preview.classList.remove('floating-preview');
    floatBtn.innerHTML = '<i class="ti ti-picture-in-picture text-xs"></i><span>Float</span>';
    floatBtn.title = 'Pop-up preview (tetap terlihat saat scroll)';
    closeBtn.classList.add('hidden');
    closeBtn.classList.remove('flex');
  }
}

async function loadVizVideoPreview() {
  const videoCheckboxes = document.querySelectorAll("input[name='video']:checked");
  const videoPlayer = document.getElementById('vizVideoPlayer');
  const placeholder = document.getElementById('vizPlaceholder');
  
  if (videoCheckboxes.length === 0) {
    videoPlayer.src = '';
    videoPlayer.style.display = 'none';
    placeholder.classList.remove('hidden');
    return;
  }
  
  const videoId = videoCheckboxes[0].value;
  try {
    const resp = await fetch('/api/videos/' + videoId);
    const data = await resp.json();
    const video = data.video || data;
    
    if (video && video.filepath) {
      const videoPath = video.filepath.startsWith('/') ? video.filepath : '/' + video.filepath;
      videoPlayer.src = videoPath;
      videoPlayer.style.display = 'block';
      videoPlayer.play().catch(() => {});
      placeholder.classList.add('hidden');
    }
  } catch (err) {
    console.error('[Viz] Failed to load video:', err);
  }
}

async function loadVizAudioPreview() {
  if (!vizPreview || !vizEnabled) return;
  
  const audioCheckboxes = document.querySelectorAll("input[name='audio']:checked");
  if (audioCheckboxes.length === 0) {
    vizPreview.startSimulated();
    return;
  }
  
  // Get first selected audio's filepath
  const audioId = audioCheckboxes[0].value;
  try {
    const resp = await fetch('/api/audios/' + audioId);
    const data = await resp.json();
    const audio = data.audio || data;
    
    if (audio && audio.filepath) {
      vizCurrentAudioUrl = audio.filepath;
      const success = await vizPreview.loadAudio(audio.filepath);
      if (success) {
        document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-pause text-sm"></i>';
      } else {
        vizPreview.startSimulated();
      }
    } else {
      vizPreview.startSimulated();
    }
  } catch (err) {
    console.error('[Viz] Failed to load audio:', err);
    vizPreview.startSimulated();
  }
}

function toggleVizAudioPlayback() {
  // Handle visualizer audio
  if (vizEnabled && vizPreview && vizPreview.audioElement) {
    if (!vizPreview.audioElement.paused) {
      vizPreview.audioElement.pause();
      document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-play text-sm"></i>';
    } else if (vizPreview.audioElement.src) {
      vizPreview.audioElement.play();
      document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-pause text-sm"></i>';
    } else {
      loadVizAudioPreview();
    }
    return;
  }
  
  // Handle direct audio preview
  if (previewAudioElement) {
    if (!previewAudioElement.paused) {
      previewAudioElement.pause();
      document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-play text-sm"></i>';
    } else if (previewAudioElement.src) {
      previewAudioElement.play();
      document.getElementById('vizPlayBtn').innerHTML = '<i class="ti ti-player-pause text-sm"></i>';
    } else {
      loadDirectAudioPreview();
    }
  } else {
    loadDirectAudioPreview();
  }
}

function setVizVolume(val) {
  if (vizEnabled && vizPreview) {
