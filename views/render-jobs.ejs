async function loadJobs(){
  const r=await fetch('/api/render/jobs');
  const d=await r.json();
  const cards=toArray(d,'jobs').map(j=>{
    const progress = Math.max(0,Math.min(100,Number(j.progress||0)));
    const isActive = j.status === 'processing' || j.status === 'pending';
    
    // Calculate ETA
    let etaText = '';
    let speedText = '';
    if (isActive && j.progress > 0) {
      const elapsed = j.elapsed_seconds || 0;
      const remaining = elapsed > 0 ? (elapsed / j.progress) * (100 - j.progress) : 0;
      const fps = j.render_speed || 0;
      
      if (remaining > 0) {
        const mins = Math.floor(remaining / 60);
        const secs = Math.floor(remaining % 60);
        etaText = `${mins}m ${secs}s tersisa`;
      }
      
      if (fps > 0) {
        speedText = `${fps.toFixed(1)} fps`;
      }
    }
    
    // Create circular progress
    const radius = 18;
    const circumference = 2 * Math.PI * radius;
    const offset = circumference - (progress / 100) * circumference;
    
    return `
    <div class="bg-dark-700 rounded-lg p-4 border border-gray-600 hover:border-primary transition-colors mb-3">
      <div class="flex items-start justify-between mb-3">
        <div class="flex items-start gap-3 flex-1">
          <!-- Circular Progress -->
          <div class="relative flex-shrink-0">
            <svg class="progress-ring" width="40" height="40">
              <circle class="text-gray-600" stroke-width="3" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
              <circle class="progress-ring-circle text-primary" stroke-width="3" stroke-dasharray="${circumference}" stroke-dashoffset="${offset}" stroke-linecap="round" stroke="currentColor" fill="transparent" r="${radius}" cx="20" cy="20"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-xs font-bold text-white">${Math.round(progress)}</span>
            </div>
          </div>
          
          <!-- Job Info -->
          <div class="flex-1 min-w-0">
            <h4 class="text-sm font-semibold text-white mb-1 truncate">${j.title||'Tanpa judul'}</h4>
            <div class="flex flex-wrap gap-2 text-xs">
              <span class="flex items-center gap-1 text-gray-400">
                <i class="ti ti-clock"></i>
                ${j.status}
              </span>
              ${speedText ? `<span class="flex items-center gap-1 text-primary"><i class="ti ti-activity"></i>${speedText}</span>` : ''}
              ${etaText ? `<span class="flex items-center gap-1 text-green-400"><i class="ti ti-hourglass"></i>${etaText}</span>` : ''}
            </div>
          </div>
        </div>
        ${isActive ? '<div class="w-2 h-2 bg-green-400 rounded-full animate-pulse flex-shrink-0"></div>' : ''}
      </div>
      
      <!-- Linear Progress Bar -->
      <div class="w-full bg-gray-600 rounded-full h-2 mb-3">
        <div class="bg-primary h-2 rounded-full transition-all ${isActive ? 'progress-active' : ''}" style="width:${progress}%"></div>
      </div>
      
      <div class="flex items-center justify-between text-xs mb-3">
        <span class="text-gray-400">${progress}% complete</span>
        <span class="text-gray-400">Target: ${j.target_duration_seconds||0}s</span>
      </div>
      
      ${j.output_path?`<video controls preload="metadata" src="${j.output_path}" class="w-full rounded-lg mb-3 bg-black"></video>`:''}
      
      <div class="flex gap-2">
        ${j.output_path?`
          <button onclick="uploadJob('${j.id}')" class="flex-1 px-3 py-2 bg-primary hover:bg-secondary text-white text-sm rounded-lg transition-colors">Upload</button>
          <button onclick="openLoopModal('${j.id}')" class="flex-1 px-3 py-2 bg-yellow-500/20 hover:bg-yellow-500/30 border border-yellow-500/50 text-yellow-400 text-sm rounded-lg transition-colors">Loop</button>
        `:''}
        <button onclick="deleteJob('${j.id}')" class="px-3 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm rounded-lg transition-colors">Hapus</button>
      </div>
    </div>
  `;
  }).join('');
  el.jobs.innerHTML=cards||'<div class="text-sm text-gray-400 text-center py-8">Belum ada job</div>';
}

