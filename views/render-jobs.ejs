let currentUploadJobId = null;
let currentUploadJob = null;
let channelDefaults = null;
let isUploading = false;
let uploadStartTime = null;

// Upload Widget Functions
function showUploadWidget() {
  document.getElementById('uploadWidget').classList.remove('hidden');
  document.getElementById('uploadWidgetMinimized').classList.remove('hidden');
  document.getElementById('uploadWidgetExpanded').classList.add('hidden');
