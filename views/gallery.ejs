  // Search functionality
  document.getElementById('searchInput').addEventListener('input', function(e) {
    const query = e.target.value.toLowerCase();
    const cards = document.querySelectorAll(currentTab === 'audio' ? '.audio-card' : '.video-card');
    cards.forEach(card => {
      const title = card.dataset.title;
      card.style.display = title.includes(query) ? '' : 'none';
    });
  });
  
  // Sort functionality
  document.getElementById('sortSelect').addEventListener('change', function(e) {
    const grid = document.getElementById(currentTab === 'audio' ? 'audioGrid' : 'videoGrid');
    const cards = Array.from(grid.querySelectorAll(currentTab === 'audio' ? '.audio-card' : '.video-card'));
    cards.sort((a, b) => {
      const dateA = new Date(a.dataset.date);
      const dateB = new Date(b.dataset.date);
      return e.target.value === 'newest' ? dateB - dateA : dateA - dateB;
    });
    cards.forEach(card => grid.appendChild(card));
  });
  
  // File upload handlers
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize tab display on page load - ensure correct visibility
    const videoGrid = document.getElementById('videoGrid');
    const audioGrid = document.getElementById('audioGrid');
    const videoButtonsCol = document.getElementById('videoButtonsCol');
    const audioButtonsCol = document.getElementById('audioButtonsCol');
    const uploadVideoBtnDesktop = document.getElementById('uploadVideoBtnDesktop');
    const uploadAudioBtnDesktop = document.getElementById('uploadAudioBtnDesktop');
    const gdriveBtnDesktop = document.getElementById('gdriveBtnDesktop');
    const gdriveAudioBtnDesktop = document.getElementById('gdriveAudioBtnDesktop');
    
    if (currentTab === 'audio') {
      // Audio tab active - hide video, show audio
      if (videoGrid) videoGrid.style.display = 'none';
      if (audioGrid) audioGrid.style.display = 'flex';
      if (videoButtonsCol) videoButtonsCol.style.display = 'none';
      if (audioButtonsCol) audioButtonsCol.style.display = 'flex';
      if (uploadVideoBtnDesktop) uploadVideoBtnDesktop.style.display = 'none';
      if (uploadAudioBtnDesktop) uploadAudioBtnDesktop.style.display = 'flex';
      if (gdriveBtnDesktop) gdriveBtnDesktop.style.display = 'none';
      if (gdriveAudioBtnDesktop) gdriveAudioBtnDesktop.style.display = 'flex';
    } else {
      // Video tab active - hide audio, show video
      if (videoGrid) videoGrid.style.display = 'flex';
      if (audioGrid) audioGrid.style.display = 'none';
      if (videoButtonsCol) videoButtonsCol.style.display = 'flex';
      if (audioButtonsCol) audioButtonsCol.style.display = 'none';
      if (uploadVideoBtnDesktop) uploadVideoBtnDesktop.style.display = 'flex';
      if (uploadAudioBtnDesktop) uploadAudioBtnDesktop.style.display = 'none';
      if (gdriveBtnDesktop) gdriveBtnDesktop.style.display = 'flex';
      if (gdriveAudioBtnDesktop) gdriveAudioBtnDesktop.style.display = 'none';
    }
    
    // Video file input
    const videoInput = document.getElementById('videoFileInput');
    const videoBtn = document.getElementById('videoUploadButton');
    videoInput.addEventListener('change', function() {
      if (this.files.length > 0) {
        document.getElementById('videoFileName').textContent = this.files[0].name;
        document.getElementById('videoSelectedInfo').classList.remove('hidden');
        videoBtn.disabled = false;
      }
    });
    
    videoBtn.addEventListener('click', async function() {
      const file = videoInput.files[0];
      if (!file) return;
      const formData = new FormData();
      formData.append('video', file);
      formData.append('_csrf', '<%= csrfToken %>');
      
      document.getElementById('videoUploadProgress').classList.remove('hidden');
      videoBtn.disabled = true;
      
      const xhr = new XMLHttpRequest();
      xhr.upload.onprogress = (e) => {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          document.getElementById('videoUploadBar').style.width = pct + '%';
          document.getElementById('videoUploadPercent').textContent = pct + '%';
        }
      };
      xhr.onload = () => {
        const res = JSON.parse(xhr.responseText);
        if (res.success) { showToast('success', 'Video uploaded'); setTimeout(() => location.reload(), 1000); }
        else { showToast('error', res.error || 'Upload failed'); videoBtn.disabled = false; }
      };
      xhr.onerror = () => { showToast('error', 'Upload failed'); videoBtn.disabled = false; };
      xhr.open('POST', '/api/videos/upload');
      xhr.setRequestHeader('X-CSRF-Token', '<%= csrfToken %>');
      xhr.send(formData);
    });
    
    // Audio file input
    const audioInput = document.getElementById('audioFileInput');
    const audioBtn = document.getElementById('audioUploadButton');
    audioInput.addEventListener('change', function() {
      if (this.files.length > 0) {
        document.getElementById('audioFileName').textContent = this.files[0].name;
        document.getElementById('audioSelectedInfo').classList.remove('hidden');
        audioBtn.disabled = false;
      }
    });
    
    audioBtn.addEventListener('click', async function() {
      const file = audioInput.files[0];
      if (!file) return;
      const formData = new FormData();
      formData.append('audio', file);
      formData.append('_csrf', '<%= csrfToken %>');
      
      document.getElementById('audioUploadProgress').classList.remove('hidden');
      audioBtn.disabled = true;
      
      const xhr = new XMLHttpRequest();
      xhr.upload.onprogress = (e) => {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          document.getElementById('audioUploadBar').style.width = pct + '%';
          document.getElementById('audioUploadPercent').textContent = pct + '%';
        }
      };
      xhr.onload = () => {
        const res = JSON.parse(xhr.responseText);
        if (res.success) { showToast('success', 'Audio uploaded'); setTimeout(() => location.reload(), 1000); }
        else { showToast('error', res.error || 'Upload failed'); audioBtn.disabled = false; }
      };
      xhr.onerror = () => { showToast('error', 'Upload failed'); audioBtn.disabled = false; };
      xhr.open('POST', '/api/audios/upload');
      xhr.setRequestHeader('X-CSRF-Token', '<%= csrfToken %>');
      xhr.send(formData);
    });
    
    // Google Drive import (Video)
    document.getElementById('closeGDriveBtn').addEventListener('click', closeGDriveModal);
    document.getElementById('import-drive-button').addEventListener('click', async function() {
      const link = document.getElementById('gdrive-link').value.trim();
      if (!link) { showToast('error', 'Please enter a Google Drive link'); return; }
      
      // Validate URL format
      if (!link.includes('drive.google.com') && !link.includes('docs.google.com')) {
        showToast('error', 'Please enter a valid Google Drive link');
        return;
      }
      
      this.disabled = true;
      
      // Show progress section
      document.getElementById('gdrive-input-section').classList.add('hidden');
      document.getElementById('gdrive-progress-section').classList.remove('hidden');
      document.getElementById('gdrive-status-text').textContent = 'Starting import...';
      document.getElementById('gdrive-progress-bar').style.width = '0%';
      document.getElementById('gdrive-progress-text').textContent = '0%';
      
      try {
        const res = await fetch('/api/videos/import-drive', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
          body: JSON.stringify({ driveUrl: link })
        });
        const data = await res.json();
        
        if (data.success && data.jobId) {
          // Poll for progress
          const pollProgress = async () => {
            try {
              const statusRes = await fetch(`/api/videos/import-status/${data.jobId}`);
              const statusData = await statusRes.json();
              
              if (statusData.success && statusData.status) {
                const status = statusData.status;
                document.getElementById('gdrive-progress-bar').style.width = status.progress + '%';
                document.getElementById('gdrive-progress-text').textContent = status.progress + '%';
                document.getElementById('gdrive-status-text').textContent = status.message || status.status;
                
                if (status.status === 'completed') {
                  showToast('success', 'Video imported successfully!');
                  setTimeout(() => location.reload(), 1500);
                  return;
                } else if (status.status === 'error') {
                  showToast('error', status.message || 'Import failed');
                  resetGDriveModal();
                  return;
                }
                
                // Continue polling
                setTimeout(pollProgress, 2000);
              }
            } catch (e) {
              console.error('Error polling status:', e);
              setTimeout(pollProgress, 3000);
            }
          };
          
          showToast('success', 'Import started - downloading from Google Drive...');
          setTimeout(pollProgress, 2000);
        } else {
          showToast('error', data.error || 'Import failed');
          resetGDriveModal();
        }
      } catch (e) {
        console.error('Import error:', e);
        showToast('error', 'Import failed - please try again');
        resetGDriveModal();
      }
    });
    
    function resetGDriveModal() {
      document.getElementById('gdrive-input-section').classList.remove('hidden');
      document.getElementById('gdrive-progress-section').classList.add('hidden');
      document.getElementById('import-drive-button').disabled = false;
      document.getElementById('gdrive-link').value = '';
    }
    
    // Google Drive import (Audio)
    document.getElementById('import-audio-drive-button').addEventListener('click', async function() {
      const link = document.getElementById('gdrive-audio-link').value;
      if (!link) { showToast('error', 'Please enter a Google Drive link'); return; }
      this.disabled = true;
      this.innerHTML = '<i class="ti ti-loader animate-spin mr-2"></i>Processing...';
      try {
        const res = await fetch('/api/audios/import-drive', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
          body: JSON.stringify({ driveUrl: link })
        });
        const data = await res.json();
        if (data.success) { showToast('success', 'Audio import started'); closeAudioGDriveModal(); }
        else { showToast('error', data.error || 'Import failed'); }
      } catch (e) { showToast('error', 'Import failed'); }
      this.disabled = false;
      this.innerHTML = '<i class="ti ti-download mr-2"></i>Import Audio';
    });
  });
</script>
